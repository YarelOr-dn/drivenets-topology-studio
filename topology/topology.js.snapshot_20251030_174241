                    this.saveState(); // Save before dragging
                    
                    this.dragging = false; // Don't start dragging immediately
                    this.lastMousePos = pos; // Store initial position for movement detection
                    this.updatePropertiesPanel();
                    
                    // Immediate movement - no long-press delay
                    this.dragging = true;
