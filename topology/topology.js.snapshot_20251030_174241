    findUnboundLinkEndpoint(x, y) {
        for (let i = this.objects.length - 1; i >= 0; i--) {
            const obj = this.objects[i];
            if (obj.type === 'unbound') {
                // Check if click is near start point
                const distStart = Math.sqrt(Math.pow(x - obj.start.x, 2) + Math.pow(y - obj.start.y, 2));
                if (distStart < 10 / this.zoom) {
                    return { link: obj, endpoint: 'start' };
                }
                // Check if click is near end point
                const distEnd = Math.sqrt(Math.pow(x - obj.end.x, 2) + Math.pow(y - obj.end.y, 2));
                if (distEnd < 10 / this.zoom) {
                    return { link: obj, endpoint: 'end' };
                }
            }
        }
        return null;
    }
    
