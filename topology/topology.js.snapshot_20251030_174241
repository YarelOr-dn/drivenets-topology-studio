    createLink(device1, device2) {
        this.saveState(); // Save before creating link
        
        // BIDIRECTIONAL: Count existing links between these devices (both directions)
        // A→B and B→A count as links in the same pair
        const existingLinks = this.objects.filter(obj => 
            obj.type === 'link' && 
            ((obj.device1 === device1.id && obj.device2 === device2.id) ||
             (obj.device1 === device2.id && obj.device2 === device1.id))
        );
        
        const linkIndex = existingLinks.length;
        // Index 0: center, Index 1: bottom, Index 2: top, Index 3: bottom, etc.
        
        const link = {
            id: `link_${this.linkIdCounter++}`,
            type: 'link',
            device1: device1.id,
            device2: device2.id,
            color: '#666',
            start: { x: device1.x, y: device1.y },
            end: { x: device2.x, y: device2.y },
            linkIndex: linkIndex  // Track which link this is (for bidirectional offset)
        };
        
        this.objects.push(link);
        
        if (this.debugger) {
            const d1Label = device1.label || 'Device';
            const d2Label = device2.label || 'Device';
            this.debugger.logSuccess(`Link created: ${d1Label} → ${d2Label}`);
        }
        
