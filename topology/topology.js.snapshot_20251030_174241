            // New radius: min 10px, NO maximum limit!
            const newRadius = Math.max(10, Math.round(currentDist));
            this.resizingDevice.radius = newRadius;
            
            if (this.resizingDevice === this.selectedObject) {
                document.getElementById('device-radius').value = newRadius;
            }
            
            this.draw();
            this.updateHud(pos);
            return;
