            // Only place text if not already placed in this session
            if (!this.textPlaced) {
                this.saveState(); // Save before creating
                const text = this.createText(pos.x, pos.y);
                this.objects.push(text);
                this.selectedObject = text;
                this.selectedObjects = [text];
                this.updateTextProperties();
                this.textPlaced = true;
                // Return to select tool after placing
                this.setTool('select');
            }
        }
        
        this.draw();
