    getMousePos(e) {
        const rect = this.canvas.getBoundingClientRect();
        const scaleX = this.canvas.width / rect.width;
        const scaleY = this.canvas.height / rect.height;
        return {
            x: (e.clientX - rect.left) * scaleX / this.zoom - this.panOffset.x,
            y: (e.clientY - rect.top) * scaleY / this.zoom - this.panOffset.y
        };
    }
    
    getTouchPos(e) {
        const touch = e.touches[0] || e.changedTouches[0];
        const rect = this.canvas.getBoundingClientRect();
        const scaleX = this.canvas.width / rect.width;
        const scaleY = this.canvas.height / rect.height;
        return {
            x: (touch.clientX - rect.left) * scaleX / this.zoom - this.panOffset.x,
            y: (touch.clientY - rect.top) * scaleY / this.zoom - this.panOffset.y
        };
    }
    
