                { "id": "text_tier_spine", "type": "text", "x": 40, "y": 180, "text": "SPINE", "fontSize": "10px", "fontFamily": "Arial, sans-serif", "color": "#9b59b6", "backgroundColor": "transparent", "rotation": 0 }
            ],
