                    '─────────────────────────────────────────────\n\n' +
                    '2. SSH to device and run these commands:\n\n' +
                    '   show network-services bridge domain | no-more\n' +
                    '   show network-services evpn instance | no-more\n' +
                    '   show l2vpn bridge domain | no-more';
                
                this.showInfoDialog('Find Bridge Domains', msg);
                
                if (this.debugger) {
                    this.debugger.logInfo(`DNAAS BD search: ${deviceSerial}`);
                }
            }
        );
    }
    
    // Show device inventory dialog
    showDnaasInventoryDialog() {
        // Try to load the inventory file from multiple possible paths
        const paths = ['/device_inventory.json', 'device_inventory.json', './device_inventory.json'];
        
        const tryPath = (index) => {
            if (index >= paths.length) {
                // No paths worked, show message
                const msg = 'Device inventory not found.\n\n' +
                    'Run a path discovery first:\n' +
                    'python3 /home/dn/CURSOR/dnaas_path_discovery.py <serial>\n\n' +
                    'Then refresh this page.';
                this.showInfoDialog('Device Inventory', msg);
                return;
            }
            
            fetch(paths[index])
                .then(response => {
                    if (!response.ok) throw new Error('Not found');
                    return response.json();
                })
                .then(data => {
                    const devices = data.devices || {};
                    const deviceCount = Object.keys(devices).length;
                    
                    if (deviceCount === 0) {
                        this.showInfoDialog('Device Inventory', 
                            'Device inventory is empty.\n\n' +
                            'Run a path discovery to populate:\n' +
                            'python3 /home/dn/CURSOR/dnaas_path_discovery.py <serial>');
                        return;
                    }
                    
                    let msg = `Found ${deviceCount} device(s):\n`;
                    msg += '─'.repeat(45) + '\n\n';
                    
                    Object.entries(devices).forEach(([serial, info]) => {
                        const dnaasCount = (info.dnaas_interfaces || []).length;
                        const hostname = info.hostname || 'Unknown';
                        msg += `▸ ${hostname}\n`;
                        msg += `    Serial: ${serial}\n`;
                        msg += `    Mgmt IP: ${info.mgmt_ip || 'N/A'}\n`;
                        msg += `    DNAAS Interfaces: ${dnaasCount}\n`;
                        if (info.dnaas_interfaces && info.dnaas_interfaces.length > 0) {
                            msg += `      → ${info.dnaas_interfaces.join(', ')}\n`;
                        }
                        msg += '\n';
                    });
                    
                    this.showInfoDialog('DNAAS Device Inventory', msg);
                })
                .catch(() => tryPath(index + 1));
        };
        
        tryPath(0);
    }
    
    /**
     * Show dialog with all devices currently on the canvas, organized by type
     * Shows SSH status, Serial Number, and management IP for each device
     */
    showDnaasPathDevicesDialog() {
        const devices = this.objects.filter(o => o.type === 'device');
        
        if (devices.length === 0) {
            this.showInfoDialog('Path Devices', 'No devices on canvas.\n\nRun a DNAAS discovery first to populate the topology.');
            return;
        }
        
        // Organize devices by type (from label patterns)
        const devicesByType = {
            'SuperSpine': [],
            'Spine': [],
            'Leaf': [],
            'PE/Router': [],
            'Other': []
        };
        
        devices.forEach(d => {
            const label = (d.label || d.id || '').toUpperCase();
            const hasSSH = d.sshConfig && (d.sshConfig.host || d.sshConfig.hostBackup);
            const hasSN = d.deviceSerial && d.deviceSerial.trim() !== '';
            
            const deviceEntry = {
                label: d.label || d.id,
                sshHost: d.sshConfig?.host || '',
                sshBackup: d.sshConfig?.hostBackup || '',
                serial: d.deviceSerial || '',
                hasSSH: hasSSH,
                hasSN: hasSN,
                user: d.sshConfig?.user || 'dnroot'
            };
            
            if (label.includes('SUPERSPINE')) {
                devicesByType['SuperSpine'].push(deviceEntry);
            } else if (label.includes('SPINE')) {
                devicesByType['Spine'].push(deviceEntry);
            } else if (label.includes('LEAF')) {
                devicesByType['Leaf'].push(deviceEntry);
            } else if (label.includes('PE') || label.includes('ROUTER') || label.includes('NCP') || label.includes('NCF')) {
                devicesByType['PE/Router'].push(deviceEntry);
            } else {
                devicesByType['Other'].push(deviceEntry);
            }
        });
        
        // Build message
        let msg = `📊 DNAAS Path Devices Summary\n`;
        msg += `Total: ${devices.length} device(s)\n`;
        msg += '═'.repeat(50) + '\n\n';
        
        for (const [type, devs] of Object.entries(devicesByType)) {
            if (devs.length === 0) continue;
            
            const icon = type === 'SuperSpine' ? '🔴' : 
                         type === 'Spine' ? '🟣' : 
                         type === 'Leaf' ? '🟠' : 
                         type === 'PE/Router' ? '🔵' : '⚪';
            
            msg += `${icon} ${type} (${devs.length})\n`;
            msg += '─'.repeat(40) + '\n';
            
            devs.forEach(d => {
                const sshIcon = d.hasSSH ? '✅' : '❌';
                msg += `  ${sshIcon} ${d.label}\n`;
                if (d.sshHost) {
                    msg += `      IP: ${d.sshHost}\n`;
                }
                if (d.serial || d.sshBackup) {
                    msg += `      SN: ${d.serial || d.sshBackup}\n`;
                }
                if (!d.hasSSH && !d.hasSN) {
                    msg += `      ⚠️ No SSH credentials\n`;
                }
            });
            msg += '\n';
        }
        
        // Summary
        const withSSH = devices.filter(d => d.sshConfig && (d.sshConfig.host || d.sshConfig.hostBackup)).length;
        const withoutSSH = devices.length - withSSH;
        
        msg += '═'.repeat(50) + '\n';
        msg += `✅ With SSH: ${withSSH}  |  ❌ Without SSH: ${withoutSSH}\n`;
        
        if (withoutSSH > 0) {
            msg += '\n💡 Tip: Right-click a device → "Set SSH Address" to add credentials';
        }
        
        this.showInfoDialog('DNAAS Path Devices', msg);
    }
    
    // Load DNAAS discovery data directly (from API result)
    /**
     * Enrich termination devices in discovery data with SSH config from managed devices.
     * When discovery reaches the edge of the DNAAS network and finds termination devices,
     * check if their LLDP neighbors (the PE/CE devices) are already registered in the
     * managed devices (SCALER config). If so, copy the SSH credentials.
     * 
     * @param {Object} data - Discovery result data with objects array
     * @returns {Object} - Enriched data with SSH configs from managed devices
     */
    async enrichTerminationDevicesWithManagedConfig(data) {
        if (!data || !data.objects) return data;
        
        try {
            // Get all managed devices from SCALER API
            let managedDevices = [];
            if (typeof ScalerAPI !== 'undefined' && ScalerAPI.getDevices) {
                try {
                    const result = await ScalerAPI.getDevices();
                    managedDevices = result.devices || [];
                } catch (err) {
                    console.log('[DNAAS] Could not fetch managed devices:', err.message);
                }
            }
            
            if (managedDevices.length === 0) {
                console.log('[DNAAS] No managed devices available for SSH enrichment');
                return data;
            }
            
            // Build lookup maps for managed devices by hostname and IP
            const managedByHostname = {};
            const managedByIP = {};
            const managedDevicesList = [];
            managedDevices.forEach(device => {
                if (device.hostname) {
                    managedByHostname[device.hostname.toLowerCase()] = device;
                }
                if (device.ip) {
                    managedByIP[device.ip] = device;
                }
                // Also index by ID/serial
                if (device.id) {
                    managedByHostname[device.id.toLowerCase()] = device;
                }
                managedDevicesList.push(device);
            });
            
            // Helper function for fuzzy hostname matching
            // E.g., "YOR_PE-1" should match managed device "PE-1"
            const findManagedDeviceByPartialMatch = (lldpName) => {
                if (!lldpName) return null;
                const nameLower = lldpName.toLowerCase();
                
                for (const managed of managedDevicesList) {
                    const managedHostname = (managed.hostname || '').toLowerCase();
                    const managedId = (managed.id || '').toLowerCase();
                    
                    // Exact match
                    if (nameLower === managedHostname || nameLower === managedId) {
                        return managed;
                    }
                    
                    // Partial match: LLDP name contains managed hostname (e.g., "YOR_PE-1" contains "PE-1")
                    if (managedHostname && managedHostname.length >= 3) {
                        // Check if managed hostname appears at the end or as a suffix
                        // E.g., "YOR_PE-1" ends with "PE-1", or "lab-pe1-router" contains "pe1"
                        if (nameLower.includes(managedHostname) || 
                            nameLower.endsWith(managedHostname) ||
                            nameLower.replace(/[_\-\.]/g, '').includes(managedHostname.replace(/[_\-\.]/g, ''))) {
                            console.log(`[DNAAS] Fuzzy match: "${lldpName}" → "${managed.hostname}"`);
                            return managed;
                        }
                    }
                    
                    // Also try matching by ID (e.g., "pe1")
                    if (managedId && managedId.length >= 2) {
                        if (nameLower.includes(managedId) || 
                            nameLower.replace(/[_\-\.]/g, '').includes(managedId.replace(/[_\-\.]/g, ''))) {
                            console.log(`[DNAAS] Fuzzy match by ID: "${lldpName}" → "${managed.id}"`);
                            return managed;
                        }
                    }
                }
                return null;
            };
            
            // Find termination devices in discovery data (non-DNAAS devices at edge)
            const dnaasKeywords = ['DNAAS', 'LEAF', 'SPINE', 'FABRIC', 'TOR', 'AGGREGATION', 'AGG-', 'CORE-'];
            
            data.objects.forEach(obj => {
                if (obj.type !== 'device') return;
                
                const label = (obj.label || '').toUpperCase();
                const isDnaasDevice = dnaasKeywords.some(kw => label.includes(kw));
                
                // Only enrich termination devices (non-DNAAS)
                if (isDnaasDevice) return;
                
                // Check if this device matches a managed device
                const labelLower = (obj.label || '').toLowerCase();
                const serial = (obj.deviceSerial || '').toLowerCase();
                const sshHost = obj.sshConfig?.host || obj.sshConfig?.hostBackup || '';
                
                let matchedDevice = null;
                
                // 1. Try exact match by hostname/label
                if (labelLower && managedByHostname[labelLower]) {
                    matchedDevice = managedByHostname[labelLower];
                }
                // 2. Try exact match by serial number
                else if (serial && managedByHostname[serial]) {
                    matchedDevice = managedByHostname[serial];
                }
                // 3. Try exact match by IP
                else if (sshHost && managedByIP[sshHost]) {
                    matchedDevice = managedByIP[sshHost];
                }
                // 4. Try fuzzy/partial hostname match (e.g., "YOR_PE-1" → "PE-1")
                else {
                    matchedDevice = findManagedDeviceByPartialMatch(obj.label);
                }
                
                if (matchedDevice) {
                    // Found a managed device - enrich SSH config
                    console.log(`[DNAAS] Enriching termination device "${obj.label}" with managed device SSH config`);
                    
                    obj.sshConfig = obj.sshConfig || {};
                    
                    // Use managed device's IP as primary host
                    if (matchedDevice.ip && !obj.sshConfig.host) {
                        obj.sshConfig.host = matchedDevice.ip;
                    }
                    
                    // Use managed device's credentials
                    if (matchedDevice.username) {
                        obj.sshConfig.user = matchedDevice.username;
                    }
                    if (matchedDevice.password) {
                        obj.sshConfig.password = matchedDevice.password;
                    }
                    
                    // Mark as enriched from managed device
                    obj.sshConfig.enrichedFromManaged = true;
                    obj.sshConfig.managedDeviceId = matchedDevice.id || matchedDevice.hostname;
                    
                    if (this.debugger) {
                        this.debugger.logSuccess(`📡 Termination device "${obj.label}" enriched with SSH from managed device`);
                    }
                }
            });
            
            return data;
        } catch (err) {
            console.warn('[DNAAS] Error enriching termination devices:', err);
            return data;
        }
    }
    
    /**
     * Calculate the display width of a device label for spacing calculations
     * Uses approximate character width based on typical font rendering
     */
    calculateLabelWidth(label) {
        if (!label) return 100;
        // Approximate width: ~9px per character for typical device labels
        // Plus 60px for the device icon radius on each side
        const charWidth = 9;
        const iconBuffer = 70; // Half device icon + padding
        return Math.max(120, label.length * charWidth + iconBuffer * 2);
    }
    
    /**
     * Calculate minimum spacing needed for a row of devices based on their labels
     */
    calculateRowSpacing(devices, minSpacing = 160) {
        if (devices.length <= 1) return minSpacing;
        
        // Find the maximum label width in this row
        let maxLabelWidth = 0;
        devices.forEach(device => {
            const labelWidth = this.calculateLabelWidth(device.label);
            if (labelWidth > maxLabelWidth) maxLabelWidth = labelWidth;
        });
        
        // Add padding between labels
        const labelPadding = 40;
        return Math.max(minSpacing, maxLabelWidth + labelPadding);
    }
    
    /**
     * Sort devices by their label suffix for logical ordering
     * e.g., DNAAS-LEAF-B15, DNAAS-LEAF-D18 → sorted by B15, D18
     */
    sortDevicesByLabel(devices) {
        return devices.sort((a, b) => {
            const labelA = a.label || '';
            const labelB = b.label || '';
            
            // Extract suffix (last part after dash or underscore)
            const suffixA = labelA.split(/[-_]/).pop() || labelA;
            const suffixB = labelB.split(/[-_]/).pop() || labelB;
            
            // Natural sort (handles B1, B2, B10 correctly)
            return suffixA.localeCompare(suffixB, undefined, { numeric: true, sensitivity: 'base' });
        });
    }
    
    /**
     * Auto-correct device credentials based on device type
     * Called when loading topologies to ensure correct SSH credentials
     * 
     * Credential mapping:
     * - DNAAS fabric (LEAF, SPINE, SUPERSPINE in name): sisaev / Drive1234!
     * - Interop at SuperSpine (non-DNAAS at top tier, ONLY if topology has DNAAS devices): dn / drive1234!
     * - PE/DUT devices (all others): dnroot / dnroot (DEFAULT)
     * 
     * FIX: Only apply DNAAS/interop logic if the topology actually contains DNAAS devices.
     * Regular topologies without DNAAS devices keep dnroot/dnroot for all devices.
     */
    _correctDeviceCredentials() {
        // CRITICAL FIX (Jan 2026): This function was being too aggressive and overwriting
        // user-set credentials. Now it ONLY sets default credentials for devices that
        // have NO credentials at all. It does NOT auto-correct based on device labels
        // or position - that was causing "flipped" credentials bugs.
        
        const devices = this.objects.filter(o => o.type === 'device');
        if (devices.length === 0) return;
        
        let setDefaults = 0;
        
        devices.forEach(device => {
            // Initialize sshConfig if missing
            if (!device.sshConfig) {
                device.sshConfig = {};
            }
            
            // ONLY set defaults if BOTH user AND password are missing/empty
            // This respects user-set credentials and doesn't overwrite them
            if (!device.sshConfig.user && !device.sshConfig.password) {
                // Check device label for DNAAS infrastructure hints
                const label = (device.label || '').toUpperCase();
                const isDnaasFabric = label.includes('LEAF') || label.includes('SPINE') || 
                                      label.includes('SUPERSPINE') || label.includes('SS-');
                
                if (isDnaasFabric) {
                    // DNAAS infrastructure devices get sisaev credentials
                    device.sshConfig.user = 'sisaev';
                    device.sshConfig.password = 'Drive1234!';
                    setDefaults++;
                    console.log(`[Credentials] Set default for DNAAS device "${device.label}": sisaev`);
                } else {
                    // All other devices (PE, DUT, etc.) get dnroot credentials
                    device.sshConfig.user = 'dnroot';
                    device.sshConfig.password = 'dnroot';
                    setDefaults++;
                    console.log(`[Credentials] Set default for device "${device.label}": dnroot`);
                }
            }
        });
        
        if (setDefaults > 0) {
            console.log(`[Credentials] Set default credentials for ${setDefaults} device(s)`);
        } else {
            console.log(`[Credentials] All devices already have credentials configured`);
        }
    }
    
    /**
     * Apply hierarchical tree layout to DNAAS devices
     * Creates a professional network diagram: SuperSpine (top) → Spines → Leafs → PEs (below connected leafs)
     * 
     * Layout Features:
     * - Dynamic spacing based on label width (no overlapping labels)
     * - Centered tiers with proper pyramid structure
     * - PE/Routers positioned BELOW their connected LEAF
     * - Sorted devices within each tier for visual consistency
     */
    applyDnaasHierarchicalLayout(objects) {
        const devices = objects.filter(o => o.type === 'device');
        const links = objects.filter(o => o.type === 'link' || o.type === 'unbound');
        if (devices.length === 0) return;
        
        console.log(`[DNAAS Layout] Starting hierarchical layout for ${devices.length} devices, ${links.length} links`);
        
        // ═══════════════════════════════════════════════════════════════════════════
        // STEP 1: Categorize devices by role based on label patterns
        // ═══════════════════════════════════════════════════════════════════════════
        const categories = {
            superSpine: [],
            spine: [],
            leaf: [],
            pe: [],           // PE/Router devices (edge/termination)
            other: []
        };
        
        // Create device lookup map by ID AND by label
        const deviceById = {};
        const deviceByLabel = {};
        devices.forEach(device => {
            deviceById[device.id] = device;
            if (device.label) {
                deviceByLabel[device.label] = device;
                deviceByLabel[device.label.toUpperCase()] = device;
            }
        });
        
        // ENHANCED categorization with more patterns
        devices.forEach(device => {
            const label = (device.label || '').toUpperCase();
            const color = device.color || '';
            const style = device.visualStyle || '';
            
            // Check for DNAAS fabric roles - BROAD pattern matching
            if (label.includes('SUPERSPINE') || label.includes('SUPER-SPINE') || label.includes('SUPER_SPINE') || label.includes('SS-')) {
                categories.superSpine.push(device);
            } else if ((label.includes('SPINE') && !label.includes('SUPERSPINE')) || label.match(/SPINE[-_]?[A-Z]?\d/i)) {
                categories.spine.push(device);
            } else if (label.includes('LEAF') || label.includes('TOR') || label.includes('ACCESS') || label.match(/LEAF[-_]?[A-Z]?\d/i)) {
                categories.leaf.push(device);
            } else if (label.includes('DNAAS') && !label.includes('SPINE') && !label.includes('LEAF')) {
                // Generic DNAAS device - try to classify by connection pattern later
                categories.other.push(device);
            } else {
                // Everything else is PE/CE/Router/termination
                categories.pe.push(device);
            }
        });
        
        console.log(`[DNAAS Layout] Initial: SS=${categories.superSpine.length}, Spine=${categories.spine.length}, Leaf=${categories.leaf.length}, PE=${categories.pe.length}, Other=${categories.other.length}`);
        
        // ═══════════════════════════════════════════════════════════════════════════
        // RE-CATEGORIZE devices based on their connections (connection-aware placement)
        // ═══════════════════════════════════════════════════════════════════════════
        if (links.length > 0) {
            const leafIds = new Set(categories.leaf.map(d => d.id));
            const spineIds = new Set(categories.spine.map(d => d.id));
            const ssIds = new Set(categories.superSpine.map(d => d.id));
            
            // Helper to analyze device connections
            const getConnectionProfile = (device) => {
                const connections = links.filter(l => l.device1 === device.id || l.device2 === device.id);
                let connectsToLeaf = false, connectsToSpine = false, connectsToSS = false;
                
                connections.forEach(link => {
                    const otherId = link.device1 === device.id ? link.device2 : link.device1;
                    if (leafIds.has(otherId)) connectsToLeaf = true;
                    if (spineIds.has(otherId)) connectsToSpine = true;
                    if (ssIds.has(otherId)) connectsToSS = true;
                });
                
                return { connectsToLeaf, connectsToSpine, connectsToSS };
            };
            
            // Re-categorize "other" devices
            const toReclassifyOther = [...categories.other];
            categories.other = [];
            
            toReclassifyOther.forEach(device => {
                const { connectsToLeaf, connectsToSpine, connectsToSS } = getConnectionProfile(device);
                
                if (connectsToSS && !connectsToLeaf && !connectsToSpine) {
                    categories.superSpine.push(device); // Connects ONLY to SS = SS peer/interop
                } else if (connectsToSS && !connectsToLeaf) {
                    categories.spine.push(device); // Connects to SS (and maybe spine) = SPINE level
                } else if (connectsToSpine && !connectsToLeaf) {
                    categories.spine.push(device);
                } else if (connectsToLeaf) {
                    categories.pe.push(device);
                } else {
                    categories.other.push(device);
                }
            });
            
            // ALSO re-categorize PE devices that connect to SuperSpine (interop routers)
            const toReclassifyPE = [...categories.pe];
            categories.pe = [];
            
            toReclassifyPE.forEach(device => {
                const { connectsToLeaf, connectsToSpine, connectsToSS } = getConnectionProfile(device);
                
                if (connectsToSS && !connectsToLeaf && !connectsToSpine) {
                    // Device connects ONLY to SuperSpine = place at SS tier (interop peer)
                    categories.superSpine.push(device);
                    console.log(`[DNAAS Layout] Promoted ${device.label} to SuperSpine tier (connects only to SS)`);
                } else if (connectsToSS && !connectsToLeaf) {
                    // Device connects to SS (and maybe spine) but NOT leaf = SPINE tier
                    categories.spine.push(device);
                    console.log(`[DNAAS Layout] Promoted ${device.label} to Spine tier (connects to SS, not LEAF)`);
                } else {
                    // Normal PE - connects to LEAF
                    categories.pe.push(device);
                }
            });
            
            console.log(`[DNAAS Layout] After reclassification: SS=${categories.superSpine.length}, Spine=${categories.spine.length}, PE=${categories.pe.length}, Other=${categories.other.length}`);
        }
        
        // Sort each category for consistent ordering (alphabetically by label)
        const sortByLabel = (a, b) => {
            const labelA = a.label || '';
            const labelB = b.label || '';
            return labelA.localeCompare(labelB, undefined, { numeric: true });
        };
        
        Object.keys(categories).forEach(key => {
            categories[key].sort(sortByLabel);
        });
        
        // ═══════════════════════════════════════════════════════════════════════════
        // STEP 2: Build connection maps for intelligent placement
        // ═══════════════════════════════════════════════════════════════════════════
        
        const leafIds = new Set(categories.leaf.map(l => l.id));
        const peIds = new Set(categories.pe.map(p => p.id));
        const spineIds = new Set(categories.spine.map(s => s.id));
        
        // Map PE device IDs to their connected LEAF device(s)
        const peToLeafConnections = {};  // peId -> [leafDevice, ...]
        
        // Also track which LEAFs connect to which SPINEs (for ordering)
        const leafToSpineConnections = {};  // leafId -> [spineDevice, ...]
        
        links.forEach(link => {
            const dev1Id = link.device1;
            const dev2Id = link.device2;
            
            // PE to LEAF connections
            if (peIds.has(dev1Id) && leafIds.has(dev2Id)) {
                if (!peToLeafConnections[dev1Id]) peToLeafConnections[dev1Id] = [];
                if (!peToLeafConnections[dev1Id].includes(deviceById[dev2Id])) {
                    peToLeafConnections[dev1Id].push(deviceById[dev2Id]);
                }
            } else if (peIds.has(dev2Id) && leafIds.has(dev1Id)) {
                if (!peToLeafConnections[dev2Id]) peToLeafConnections[dev2Id] = [];
                if (!peToLeafConnections[dev2Id].includes(deviceById[dev1Id])) {
                    peToLeafConnections[dev2Id].push(deviceById[dev1Id]);
                }
            }
            
            // LEAF to SPINE connections
            if (leafIds.has(dev1Id) && spineIds.has(dev2Id)) {
                if (!leafToSpineConnections[dev1Id]) leafToSpineConnections[dev1Id] = [];
                if (!leafToSpineConnections[dev1Id].includes(deviceById[dev2Id])) {
                    leafToSpineConnections[dev1Id].push(deviceById[dev2Id]);
                }
            } else if (leafIds.has(dev2Id) && spineIds.has(dev1Id)) {
                if (!leafToSpineConnections[dev2Id]) leafToSpineConnections[dev2Id] = [];
                if (!leafToSpineConnections[dev2Id].includes(deviceById[dev1Id])) {
                    leafToSpineConnections[dev2Id].push(deviceById[dev1Id]);
                }
            }
        });
        
        // ═══════════════════════════════════════════════════════════════════════════
        // STEP 3: SYMMETRICAL LAYOUT - Calculate global dimensions
        // ═══════════════════════════════════════════════════════════════════════════
        
        // Find the WIDEST tier - this sets our global width reference
        const tierCounts = {
            superSpine: categories.superSpine.length,
            spine: categories.spine.length,
            leaf: categories.leaf.length,
            pe: categories.pe.length,
            other: categories.other.length
        };
        
        const maxTierCount = Math.max(...Object.values(tierCounts), 1);
        
        // Base spacing - enough for longest device names
        const baseSpacing = 320;  // Comfortable spacing
        
        // Calculate canvas size based on widest tier
        const globalWidth = maxTierCount * baseSpacing;
        const canvasWidth = Math.max(2000, globalWidth + 600);
        const fabricCenterX = canvasWidth / 2;
        
        // Vertical layout
        const tierSpacing = 280;  // Vertical space between tiers
        const startY = 200;
        
        console.log(`[DNAAS Layout] Global width: ${globalWidth}px, Center: ${fabricCenterX}px, Max tier: ${maxTierCount} devices`);
        
        // ═══════════════════════════════════════════════════════════════════════════
        // STEP 4: SYMMETRICAL tier layout function
        // ═══════════════════════════════════════════════════════════════════════════
        
        /**
         * Layout devices SYMMETRICALLY centered on fabricCenterX
         * Uses ADAPTIVE spacing: fewer devices = more spacing (up to baseSpacing)
         * This ensures all tiers look balanced regardless of device count
         */
        const layoutTierSymmetric = (deviceList, y, tierName) => {
            if (deviceList.length === 0) return;
            
            const count = deviceList.length;
            
            // ADAPTIVE SPACING: scale based on count relative to max tier
            // Fewer devices = wider spacing (but capped at baseSpacing)
            let spacing;
            if (count === 1) {
                spacing = 0; // Single device = centered
            } else if (count <= 3) {
                spacing = baseSpacing * 1.2;  // Extra wide for small groups
            } else if (count <= maxTierCount) {
                // Scale spacing so this tier spans similar width to larger tiers
                spacing = Math.min(baseSpacing * 1.1, globalWidth / (count - 1));
            } else {
                spacing = baseSpacing;
            }
            
            const tierWidth = (count - 1) * spacing;
            const startX = fabricCenterX - tierWidth / 2;
            
            deviceList.forEach((device, i) => {
                device.x = startX + i * spacing;
                device.y = y;
            });
            
            console.log(`[DNAAS Layout] ${tierName}: ${count} devices, spacing=${Math.round(spacing)}px, width=${Math.round(tierWidth)}px`);
        };
        
        // ═══════════════════════════════════════════════════════════════════════════
        // STEP 5: Layout ALL tiers symmetrically
        // ═══════════════════════════════════════════════════════════════════════════
        
        let currentY = startY;
        
        // Tier 1: SuperSpines at TOP
        if (categories.superSpine.length > 0) {
            layoutTierSymmetric(categories.superSpine, currentY, 'SuperSpine');
            currentY += tierSpacing;
        }
        
        // Tier 2: Spines
        if (categories.spine.length > 0) {
            layoutTierSymmetric(categories.spine, currentY, 'Spine');
            currentY += tierSpacing;
        }
        
        // Tier 3: Leafs
        if (categories.leaf.length > 0) {
            layoutTierSymmetric(categories.leaf, currentY, 'Leaf');
            currentY += tierSpacing;
        }
        
        // Tier 4: PEs - sorted by connected LEAF position for cleaner link routing
        if (categories.pe.length > 0) {
            // Sort PEs by their connected LEAF's X position
            const pesWithOrder = categories.pe.map(pe => {
                const connectedLeafs = peToLeafConnections[pe.id];
                let orderValue = fabricCenterX;
                if (connectedLeafs && connectedLeafs.length > 0) {
                    orderValue = connectedLeafs.reduce((sum, leaf) => sum + (leaf.x || fabricCenterX), 0) / connectedLeafs.length;
                }
                return { pe, orderValue };
            });
            pesWithOrder.sort((a, b) => a.orderValue - b.orderValue);
            
            // Extract sorted PEs
            const sortedPEs = pesWithOrder.map(item => item.pe);
            
            // Layout PEs symmetrically
            layoutTierSymmetric(sortedPEs, currentY, 'PE');
            currentY += tierSpacing;
        }
        
        // Tier 5: Other devices
        if (categories.other.length > 0) {
            layoutTierSymmetric(categories.other, currentY, 'Other');
        }
        
        // ═══════════════════════════════════════════════════════════════════════════
        // STEP 6: Log summary
        // ═══════════════════════════════════════════════════════════════════════════
        
        console.log(`[DNAAS Layout] ✓ Symmetrical layout complete:`);
        console.log(`   Canvas: ${canvasWidth}px wide, center at ${fabricCenterX}px`);
        console.log(`   Tiers: SS=${tierCounts.superSpine}, Spine=${tierCounts.spine}, Leaf=${tierCounts.leaf}, PE=${tierCounts.pe}, Other=${tierCounts.other}`);
        
        if (this.debugger) {
            this.debugger.logSuccess(`🌳 Symmetric Layout: ${devices.length} devices in ${Object.values(tierCounts).filter(c => c > 0).length} tiers`);
        }
    }
    
    loadDnaasData(data) {
        if (!data || !data.objects) {
            this.showToast('Invalid discovery data', 'error');
            return;
        }
        
        // Cache discovery data for Link Table auto-fill
        if (data.metadata) {
            window._dnaasDiscoveryData = data;
            console.log('[DNAAS] Discovery data cached:', 
                        data.metadata?.bridge_domains?.length || 0, 'BDs');
        }
        
        const doLoad = () => {
            this.saveState();
            this.objects = data.objects || [];
            
            // Apply hierarchical layout FIRST (before validation fixes random positions)
            this.applyDnaasHierarchicalLayout(this.objects);
            
            // Validate and fix loaded objects
            this.objects.forEach((obj, index) => {
                if (obj.type === 'device') {
                    // Ensure device has valid x/y coordinates (only if not set by layout)
                    if (obj.x === undefined || obj.y === undefined || isNaN(obj.x) || isNaN(obj.y)) {
                        console.warn(`DNAAS: Device "${obj.label || obj.id}" missing coordinates, placing at grid position ${index}`);
                        obj.x = 200 + (index % 5) * 150;
                        obj.y = 200 + Math.floor(index / 5) * 150;
                    }
                    // Ensure device has a radius
                    if (!obj.radius) {
                        obj.radius = 50;
                    }
                    
                    // Preserve and normalize sshConfig from DNAAS discovery
                    // This enables immediate terminal access without manual credential entry
                    if (obj.sshConfig) {
                        obj.sshConfig = {
                            host: obj.sshConfig.host || obj.sshConfig.hostBackup || '',
                            hostBackup: obj.sshConfig.hostBackup || '',
                            user: obj.sshConfig.user || 'dnroot',
                            password: obj.sshConfig.password || 'dnroot'
                        };
                        if (this.debugger) {
                            this.debugger.logInfo(`DNAAS: Device "${obj.label}" has SSH config (${obj.sshConfig.host || obj.sshConfig.hostBackup})`);
                        }
                    }
                    
                    // Preserve deviceSerial for backup connection
                    if (obj.deviceSerial) {
                        // deviceSerial is already set, ensure it's accessible
                        obj.deviceSerial = obj.deviceSerial;
                    }
                }
            });
            
            // Reset counters based on loaded objects
            const deviceIds = this.objects.filter(o => o.type === 'device').map(o => parseInt(o.id.replace(/\D/g, '')) || 0);
            const linkIds = this.objects.filter(o => o.type === 'link' || o.type === 'unbound').map(o => parseInt(o.id.replace(/\D/g, '')) || 0);
            const textIds = this.objects.filter(o => o.type === 'text').map(o => parseInt(o.id.replace(/\D/g, '')) || 0);
            this.deviceIdCounter = deviceIds.length > 0 ? Math.max(...deviceIds) + 1 : 0;
            this.linkIdCounter = linkIds.length > 0 ? Math.max(...linkIds) + 1 : 0;
            this.textIdCounter = textIds.length > 0 ? Math.max(...textIds) + 1 : 0;
            
            this.selectedObject = null;
            this.selectedObjects = [];
            
            // Smart zoom-to-fit: Calculate bounds and fit topology in viewport with padding
            const devices = this.objects.filter(o => o.type === 'device');
            if (devices.length > 0) {
                // Calculate bounding box of all devices (with extra space for labels)
                const labelBuffer = 100; // Extra space for device labels
                let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
                
                devices.forEach(device => {
                    const radius = device.radius || 50;
                    minX = Math.min(minX, device.x - radius - labelBuffer);
                    maxX = Math.max(maxX, device.x + radius + labelBuffer);
                    minY = Math.min(minY, device.y - radius - 30);  // Less buffer on top
                    maxY = Math.max(maxY, device.y + radius + 50);  // More buffer for labels below
                });
                
                // Calculate required zoom to fit everything
                const topologyWidth = maxX - minX;
                const topologyHeight = maxY - minY;
                const padding = 80; // Viewport padding
                
                const availableWidth = this.canvas.width - padding * 2;
                const availableHeight = this.canvas.height - padding * 2;
                
                const zoomX = availableWidth / topologyWidth;
                const zoomY = availableHeight / topologyHeight;
                
                // Use the smaller zoom to ensure everything fits, but cap at 1.0 (don't zoom in)
                this.zoom = Math.min(1.0, Math.min(zoomX, zoomY));
                
                // Ensure minimum zoom level for readability
                this.zoom = Math.max(0.4, this.zoom);
                
                // Center the topology
                const centerX = (minX + maxX) / 2;
                const centerY = (minY + maxY) / 2;
                this.panOffset = {
                    x: (this.canvas.width / 2) - centerX * this.zoom,
                    y: (this.canvas.height / 2) - centerY * this.zoom
                };
                
                if (this.debugger) {
                    this.debugger.logInfo(`Zoom-to-fit: ${(this.zoom * 100).toFixed(0)}% (bounds: ${topologyWidth.toFixed(0)}x${topologyHeight.toFixed(0)}px)`);
                }
            } else {
                // Default view if no devices
                this.zoom = 1;
                this.panOffset = { x: 0, y: 0 };
            }
            
            this.draw();
            
            // Check for Multi-BD metadata and show BD legend
            if (data.metadata && data.metadata.bridge_domains && data.metadata.bridge_domains.length > 0) {
                this._multiBDMetadata = data.metadata;
                this.showBDLegend(data.metadata.bridge_domains);
                
                // Show the BD Hierarchy button in top bar
                this.updateBDHierarchyButton();
                
                if (this.debugger) {
                    this.debugger.logInfo(`🌈 Multi-BD topology: ${data.metadata.bridge_domains.length} Bridge Domains`);
                }
            } else {
                // No BD metadata - hide the BD Hierarchy button
                this.updateBDHierarchyButton();
            }
            
            if (this.debugger) {
                this.debugger.logSuccess(`DNAAS discovery loaded: ${this.objects.length} objects`);
            }
        };
        
        // Confirm before replacing if canvas has objects
        if (this.objects.length > 0) {
            this.showConfirmDialog(
                'Replace Current Canvas?',
                `This will replace the current canvas (${this.objects.length} objects) with the discovered topology. Continue?`,
                doLoad
            );
        } else {
            doLoad();
        }
    }
    
    /**
     * Show BD Legend panel for Multi-BD topology
     * Positioned ON the canvas grid with checkboxes for individual BD visibility
     * Persists state to localStorage for refresh survival
     */
    showBDLegend(bridgeDomains) {
        if (window.BDLegend) {
            return window.BDLegend.showBDLegend(this, bridgeDomains);
        }
    }
    
    toggleBDVisibility(bdName, visible) {
        if (!this._bdVisibility) this._bdVisibility = {};
        this._bdVisibility[bdName] = visible;
        
        // Update link visibility
        this.objects.forEach(obj => {
            if (obj.type === 'link') {
                const linkBdName = obj.linkDetails?.bd_name || obj._bdName;
                if (linkBdName === bdName) {
                    obj._hidden = !visible;
                }
            }
        });
        
        // Update device visibility - hide devices that ONLY participate in hidden BDs
        this._updateDeviceVisibilityByBD();
        
        // Save state for refresh persistence
        this._saveBDPanelState();
        
        this.draw();
    }
    
    /**
     * Update device visibility based on BD visibility states
     * Devices that ONLY participate in hidden BDs should be hidden
     * Devices that participate in at least one visible BD should be shown
     * Also hides text attached to hidden links
     */
    _updateDeviceVisibilityByBD() {
        if (!this._bdVisibility) return;
        
        // Build a map of device -> BDs it participates in
        const deviceBDs = {};
        
        // Collect BD participation from links (check both linkDetails.bd_name and _bdName)
        this.objects.forEach(obj => {
            if (obj.type === 'link' || obj.type === 'unbound') {
                const bdName = obj.linkDetails?.bd_name || obj._bdName;
                if (!bdName) return;
                
                // Get connected devices (handle both link types)
                let device1, device2;
                if (obj.device1) {
                    device1 = this.objects.find(d => d.id === obj.device1);
                }
                if (obj.device2) {
                    device2 = this.objects.find(d => d.id === obj.device2);
                }
                
                if (device1 && device1.type === 'device') {
                    if (!deviceBDs[device1.id]) deviceBDs[device1.id] = new Set();
                    deviceBDs[device1.id].add(bdName);
                }
                if (device2 && device2.type === 'device') {
                    if (!deviceBDs[device2.id]) deviceBDs[device2.id] = new Set();
                    deviceBDs[device2.id].add(bdName);
                }
            }
        });
        
        // Also check device's _bridgeDomains property (set during discovery)
        this.objects.forEach(obj => {
            if (obj.type === 'device' && obj._bridgeDomains) {
                if (!deviceBDs[obj.id]) deviceBDs[obj.id] = new Set();
                obj._bridgeDomains.forEach(bd => deviceBDs[obj.id].add(bd));
            }
        });
        
        // Update device visibility
        this.objects.forEach(obj => {
            if (obj.type === 'device') {
                const bds = deviceBDs[obj.id];
                
                if (bds && bds.size > 0) {
                    // Device participates in at least one BD
                    // Check if any of its BDs are visible
                    let hasVisibleBD = false;
                    for (const bd of bds) {
                        if (this._bdVisibility[bd] !== false) {
                            hasVisibleBD = true;
                            break;
                        }
                    }
                    
                    // Hide device only if ALL its BDs are hidden
                    obj._hidden = !hasVisibleBD;
                } else {
                    // If device has no BD info, check if it's connected to any visible links
                    // If ALL its connected links are hidden, hide the device too
                    const connectedLinks = this.objects.filter(l => 
                        (l.type === 'link' || l.type === 'unbound') && 
                        (l.device1 === obj.id || l.device2 === obj.id)
                    );
                    
                    if (connectedLinks.length > 0) {
                        const hasVisibleLink = connectedLinks.some(l => !l._hidden);
                        obj._hidden = !hasVisibleLink;
                    }
                    // If device has no links, leave it visible
                }
            }
        });
        
        // Also hide text objects attached to hidden links
        this.objects.forEach(obj => {
            if (obj.type === 'text' && obj.linkId) {
                const parentLink = this.objects.find(l => l.id === obj.linkId);
                if (parentLink && parentLink._hidden) {
                    obj._hidden = true;
                } else {
                    obj._hidden = false;
                }
            }
        });
    }
    
    /**
     * Set visibility for all BDs at once
     */
    setBDVisibilityAll(visible) {
        if (!this._bdVisibility) this._bdVisibility = {};
        
        // Update all checkboxes
        const checkboxes = document.querySelectorAll('#bd-legend-list input[type="checkbox"]');
        checkboxes.forEach(cb => {
            cb.checked = visible;
            const item = cb.closest('.bd-legend-item');
            if (item) item.style.opacity = visible ? 1 : 0.5;
        });
        
        // Update visibility state and links
        Object.keys(this._bdVisibility).forEach(bdName => {
            this._bdVisibility[bdName] = visible;
        });
        
        this.objects.forEach(obj => {
            if (obj.type === 'link' && obj.linkDetails?.bd_name) {
                obj._hidden = !visible;
            }
        });
        
        // Update device visibility based on BD visibility
        this._updateDeviceVisibilityByBD();
        
        // Save state for refresh persistence
        this._saveBDPanelState();
        
        this.draw();
    }
    
    /**
     * Hide BD Legend panel
     */
    hideBDLegend() {
        const existing = document.getElementById('bd-legend-panel');
        if (existing) {
            // Cleanup resize event listeners
            if (existing._cleanupResize) {
                existing._cleanupResize();
            }
            existing.remove();
        }
    }
    
    /**
     * Toggle BD Legend panel visibility (called from BD Hierarchy badge)
     */
    toggleBDLegendPanel() {
        const existing = document.getElementById('bd-legend-panel');
        
        if (existing) {
            // Panel exists - hide it
            this.hideBDLegend();
            this._saveBDPanelState();
            
            // Update badge state
            this.updateBDHierarchyButton();
        } else {
            // Panel hidden - show it if we have BD metadata
            if (this._multiBDMetadata && this._multiBDMetadata.bridge_domains && this._multiBDMetadata.bridge_domains.length > 0) {
                this.showBDLegend(this._multiBDMetadata.bridge_domains);
                
                // Update badge state
                this.updateBDHierarchyButton();
            } else {
                this.showToast('No Bridge Domains loaded. Run DNAAS discovery first.', 'warning');
            }
        }
    }
    
    /**
     * Show/hide the BD Hierarchy badge on DNAAS button based on whether BD data exists
     */
    updateBDHierarchyButton() {
        const bdBadge = document.getElementById('btn-bd-hierarchy');
        if (!bdBadge) return;
        
        const hasBDs = this._multiBDMetadata && 
                       this._multiBDMetadata.bridge_domains && 
                       this._multiBDMetadata.bridge_domains.length > 0;
        
        // Show/hide the badge
        bdBadge.style.display = hasBDs ? 'inline-block' : 'none';
        
        // Update badge style based on panel visibility
        const panelExists = !!document.getElementById('bd-legend-panel');
        if (panelExists) {
            // Green when panel is visible
            bdBadge.style.background = 'linear-gradient(135deg, #27ae60, #1e8449)';
            bdBadge.style.boxShadow = '0 0 6px rgba(39, 174, 96, 0.6)';
        } else {
            // Purple when panel is hidden
            bdBadge.style.background = 'linear-gradient(135deg, #9b59b6, #8e44ad)';
            bdBadge.style.boxShadow = 'none';
        }
    }
    
    /**
     * Save BD Panel state to localStorage for refresh persistence
     */
    _saveBDPanelState() {
        const legend = document.getElementById('bd-legend-panel');
        const state = {
            visible: !!legend,
            top: legend ? parseInt(legend.style.top) || 80 : 80,
            left: legend ? parseInt(legend.style.left) || 10 : 10,
            width: legend ? legend.offsetWidth || 300 : 300,
            height: legend ? legend.offsetHeight || 'auto' : 'auto',
            bdVisibility: this._bdVisibility || {},
            viewMode: this._multiBDMetadata?.view_mode || 'separate',
            bridgeDomains: this._multiBDMetadata?.bridge_domains || []
        };
        localStorage.setItem('bd_panel_state', JSON.stringify(state));
    }
    
    /**
     * Load BD Panel state from localStorage
     */
    _loadBDPanelState() {
        try {
            const saved = localStorage.getItem('bd_panel_state');
            if (saved) {
                return JSON.parse(saved);
            }
        } catch (e) {
            console.warn('Failed to load BD panel state:', e);
        }
        return {};
    }
    
    /**
     * Restore BD Panel after page refresh if it was visible
     */
    restoreBDPanelIfNeeded() {
        const state = this._loadBDPanelState();
        console.log('[BD Panel] Checking restore state:', state);
        
        if (state.visible && state.bridgeDomains && state.bridgeDomains.length > 0) {
            console.log('[BD Panel] Restoring panel with', state.bridgeDomains.length, 'BDs');
            
            // Restore visibility states
            this._bdVisibility = state.bdVisibility || {};
            
            // Restore metadata
            this._multiBDMetadata = {
                bridge_domains: state.bridgeDomains,
                view_mode: state.viewMode || 'separate'
            };
            
            // Show the panel
            this.showBDLegend(state.bridgeDomains);
            
            // Apply visibility to links (use correct function name)
            if (this._bdVisibility) {
                for (const [bdName, visible] of Object.entries(this._bdVisibility)) {
                    if (!visible) {
                        this.toggleBDVisibility(bdName, false);
                    }
                }
            }
            
            console.log('[BD Panel] Restored from localStorage:', state.bridgeDomains.length, 'BDs');
        } else {
            console.log('[BD Panel] No saved state to restore, visible:', state.visible, 'BDs:', state.bridgeDomains?.length || 0);
        }
    }
    
    /**
     * Toggle between combined and separate link views
     */
    toggleBDLinkView() {
        if (!this._multiBDMetadata) return;
        
        const currentMode = this._multiBDMetadata.view_mode || 'combined';
        const newMode = currentMode === 'combined' ? 'separate' : 'combined';
        this._multiBDMetadata.view_mode = newMode;
        
        // Update toggle button text
        const toggleBtn = document.getElementById('bd-view-toggle');
        if (toggleBtn) {
            toggleBtn.textContent = newMode === 'combined' ? 'Separate' : 'Combined';
        }
        
        // Rebuild links based on view mode
        this.applyBDViewMode(newMode);
        this.draw();
        
        this.showToast(`Link view: ${newMode}`, 'info');
    }
    
    /**
     * Apply BD view mode (combined or separate links)
     * In 'separate' mode: Show all individual BD links (each BD has its own link)
     * In 'combined' mode: Show only first BD link per device pair, hide others
     */
    applyBDViewMode(mode) {
        if (!this._multiBDMetadata || !this._multiBDMetadata.bridge_domains) return;
        
        const links = this.objects.filter(o => o.type === 'link');
        
        if (mode === 'combined') {
            // Group links by device pair and show only first (primary BD)
            const pairsSeen = new Set();
            
            links.forEach(link => {
                // Create a unique key for this device pair
                const pairKey = [link.device1, link.device2].sort().join('|');
                
                if (pairsSeen.has(pairKey)) {
                    // Hide secondary BD links for this pair
                    link.hidden = true;
                } else {
                    // Show first link for this pair
                    link.hidden = false;
                    pairsSeen.add(pairKey);
                }
            });
            
            this.showToast('Combined view: Showing primary BD links', 'info');
        } else {
            // Show all links (separate mode - each BD visible)
            links.forEach(link => {
                link.hidden = false;
            });
            
            this.showToast('Separate view: Showing all BD links', 'info');
        }
    }
    
    /**
     * Highlight the path for a specific BD
     */
    highlightBDPath(bdName) {
        if (!this._multiBDMetadata) return;
        
        // Handle both "name" and "bd_name" keys
        const bd = this._multiBDMetadata.bridge_domains.find(b => 
            (b.name === bdName) || (b.bd_name === bdName)
        );
        if (!bd) return;
        
        // Clear previous highlights
        this.objects.forEach(obj => {
            if (obj._bdHighlight) {
                delete obj._bdHighlight;
            }
        });
        
        // Highlight devices in this BD's path
        if (bd.path_devices) {
            bd.path_devices.forEach(deviceName => {
                const device = this.objects.find(o => o.type === 'device' && o.label === deviceName);
                if (device) {
                    device._bdHighlight = bd.color;
                }
            });
        }
        
        // Highlight links with this BD
        this.objects.filter(o => o.type === 'link').forEach(link => {
            if (link.linkDetails && link.linkDetails.bridgeDomains) {
                const hasBD = link.linkDetails.bridgeDomains.some(b => b.bd_name === bdName);
                if (hasBD) {
                    link._bdHighlight = bd.color;
                }
            }
        });
        
        this.draw();
        
        // Clear highlight after 2 seconds
        setTimeout(() => {
            this.objects.forEach(obj => {
                if (obj._bdHighlight) {
                    delete obj._bdHighlight;
                }
            });
            this.draw();
        }, 2000);
    }
    
    /**
     * Create a BD Text Box for the legend area
     */
    createBDTextBox(bd, colorIndex) {
        const color = bd.color || BD_COLOR_PALETTE[colorIndex % BD_COLOR_PALETTE.length];
        
        return {
            id: `bd_text_${colorIndex}`,
            type: 'text',
            x: 80,
            y: 100 + colorIndex * 70,
            text: `${bd.name}\nType: ${bd.type || 'Unknown'}\nVLAN: ${bd.vlan || bd.global_vlan || 'N/A'}`,
            fontSize: 12,
            color: color,
            rotation: 0,
            showBackground: true,
            backgroundColor: color + '20',
            backgroundOpacity: 90,
            strokeColor: color,
            strokeWidth: 1
        };
    }
    
    // Load topology from discovery output file
    loadDnaasFromFile() {
        // Create a file input to select JSON file
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.json';
        
        input.onchange = (e) => {
            const file = e.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = (event) => {
                try {
                    const data = JSON.parse(event.target.result);
                    
                    // Check if canvas has objects and confirm
                    const doLoad = () => {
                        this.saveState();
                        this.objects = data.objects || [];
                        
                        // Apply hierarchical layout if this looks like a DNAAS topology
                        const hasDnaasDevices = this.objects.some(o => 
                            o.type === 'device' && (o.label || '').toUpperCase().includes('DNAAS')
                        );
                        if (hasDnaasDevices) {
                            this.applyDnaasHierarchicalLayout(this.objects);
                        }
                        
                        // AUTO-CORRECT CREDENTIALS based on device type
                        // This ensures loaded topologies get the right credentials
                        this._correctDeviceCredentials();
                        
                        // Reset counters based on loaded objects
                        const deviceIds = this.objects.filter(o => o.type === 'device').map(o => parseInt(o.id.replace(/\D/g, '')) || 0);
                        const linkIds = this.objects.filter(o => o.type === 'link').map(o => parseInt(o.id.replace(/\D/g, '')) || 0);
                        this.deviceIdCounter = deviceIds.length > 0 ? Math.max(...deviceIds) + 1 : 0;
                        this.linkIdCounter = linkIds.length > 0 ? Math.max(...linkIds) + 1 : 0;
                        
                        this.selectedObject = null;
                        this.selectedObjects = [];
                        
                        // Smart zoom-to-fit
                        const devices = this.objects.filter(o => o.type === 'device');
                        if (devices.length > 0) {
                            const labelBuffer = 100;
                            let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
                            
                            devices.forEach(device => {
                                const radius = device.radius || 50;
                                minX = Math.min(minX, device.x - radius - labelBuffer);
                                maxX = Math.max(maxX, device.x + radius + labelBuffer);
                                minY = Math.min(minY, device.y - radius - 30);
                                maxY = Math.max(maxY, device.y + radius + 50);
                            });
                            
                            const topologyWidth = maxX - minX;
                            const topologyHeight = maxY - minY;
                            const padding = 80;
                            
                            const availableWidth = this.canvas.width - padding * 2;
                            const availableHeight = this.canvas.height - padding * 2;
                            
                            const zoomX = availableWidth / topologyWidth;
                            const zoomY = availableHeight / topologyHeight;
                            
                            this.zoom = Math.min(1.0, Math.min(zoomX, zoomY));
                            this.zoom = Math.max(0.4, this.zoom);
                            
                            const centerX = (minX + maxX) / 2;
                            const centerY = (minY + maxY) / 2;
                            this.panOffset = {
                                x: (this.canvas.width / 2) - centerX * this.zoom,
                                y: (this.canvas.height / 2) - centerY * this.zoom
                            };
                        }
                        
                        this.draw();
                        this.showToast(`Loaded ${this.objects.length} objects from ${file.name}`, 'success');
                        
                        if (this.debugger) {
                            this.debugger.logSuccess(`DNAAS discovery loaded: ${file.name} (${this.objects.length} objects)`);
                        }
                    };
                    
                    // Confirm before replacing if canvas has objects
                    if (this.objects.length > 0) {
                        this.showConfirmDialog(
                            'Replace Current Canvas?',
                            `This will replace the current canvas (${this.objects.length} objects) with the loaded topology. Continue?`,
                            doLoad
                        );
                    } else {
                        doLoad();
                    }
                } catch (err) {
                    this.showInfoDialog('Error Loading File', 'Failed to parse JSON file:\n\n' + err.message);
                }
            };
            reader.readAsText(file);
        };
        
        input.click();
    }
    
    // Show confirmation dialog (replacement for confirm())
    showConfirmDialog(title, message, onConfirm, onCancel = null) {
        const overlay = document.createElement('div');
        overlay.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0,0,0,0.7);
            z-index: 9999999;
            display: flex;
            align-items: center;
            justify-content: center;
        `;
        
        const dialog = document.createElement('div');
        dialog.style.cssText = `
            background: #2c3e50;
            border-radius: 8px;
            padding: 20px;
            min-width: 350px;
            max-width: 90vw;
            max-height: 90vh;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            position: relative;
            overflow-y: auto;
        `;
        dialog.innerHTML = `
            <div style="color:#e67e22;font-size:16px;font-weight:bold;margin-bottom:15px;">${title}</div>
            <div style="color:#ecf0f1;font-size:14px;margin-bottom:20px;line-height:1.5;">${message}</div>
            <div style="display:flex;gap:10px;justify-content:flex-end;">
                <button id="dnaas-no" style="padding:8px 16px;border:none;border-radius:4px;background:#7f8c8d;color:white;cursor:pointer;">Cancel</button>
                <button id="dnaas-yes" style="padding:8px 16px;border:none;border-radius:4px;background:#e74c3c;color:white;cursor:pointer;font-weight:bold;">Yes, Replace</button>
            </div>
        `;
        
        overlay.appendChild(dialog);
        document.body.appendChild(overlay);
        
        const cleanup = () => document.body.removeChild(overlay);
        
        dialog.querySelector('#dnaas-yes').onclick = () => { cleanup(); if (onConfirm) onConfirm(); };
        dialog.querySelector('#dnaas-no').onclick = () => { cleanup(); if (onCancel) onCancel(); };
        overlay.onclick = (e) => { if (e.target === overlay) { cleanup(); if (onCancel) onCancel(); } };
    }
    
    // LOGICAL VIEW: Sub-interface labels attached to link
    getDnaasLogicalBD210Topology() {
        return {
            "version": "1.0",
            "objects": [
                // ===== DEVICES =====
                { "id": "device_pe1", "type": "device", "deviceType": "router", "x": 200, "y": 350, "radius": 70, "rotation": 0, "color": "#3498db", "label": "YOR_PE-1", "locked": false, "visualStyle": "circle" },
                { "id": "device_pe2", "type": "device", "deviceType": "router", "x": 1100, "y": 350, "radius": 70, "rotation": 0, "color": "#3498db", "label": "YOR_PE-2", "locked": false, "visualStyle": "circle" },
                
                // ===== LINK - L2 Service =====
                { "id": "link_l2", "type": "link", "originType": "QL", "device1": "device_pe1", "device2": "device_pe2", "color": "#2ecc71",
                  "start": { "x": 270, "y": 350 }, "end": { "x": 1030, "y": 350 }, "style": "solid", "width": 6,
                  "linkDetails": {
                    "interfaceA": "ge400-0/0/4.210", "interfaceB": "bundle-100.210",
                    "ipTypeA": "L2-Service", "ipTypeB": "L2-Service"
                  }
                },
                
                // ===== TITLE =====
                { "id": "text_title", "type": "text", "x": 650, "y": 120, "text": "L2 Service (Logical View)", "fontSize": "28px", "fontFamily": "Arial, sans-serif", "color": "#2ecc71", "backgroundColor": "transparent", "rotation": 0 },
                
                // ===== INTERFACE LABELS - ATTACHED TO LINK =====
                // PE-1 sub-interface (left side of link)
                { "id": "text_if_pe1", "type": "text", "x": 0, "y": 0, "text": "ge400-0/0/4.210", "fontSize": "14px", "fontFamily": "Consolas, monospace", "color": "#2ecc71", "backgroundColor": "transparent", "rotation": 0, "attachedTo": "link_l2", "attachmentSide": "left", "offset": { "x": 50, "y": -20 } },
                
                // PE-2 sub-interface (right side of link)
                { "id": "text_if_pe2", "type": "text", "x": 0, "y": 0, "text": "bundle-100.210", "fontSize": "14px", "fontFamily": "Consolas, monospace", "color": "#2ecc71", "backgroundColor": "transparent", "rotation": 0, "attachedTo": "link_l2", "attachmentSide": "right", "offset": { "x": -50, "y": -20 } },
                
                // Service label (middle of link)
                { "id": "text_svc", "type": "text", "x": 0, "y": 0, "text": "L2 Service", "fontSize": "12px", "fontFamily": "Arial, sans-serif", "color": "#27ae60", "backgroundColor": "transparent", "rotation": 0, "attachedTo": "link_l2", "attachmentSide": "middle", "offset": { "x": 0, "y": -20 } },
                
                // ===== DEVICE IPs =====
                { "id": "text_pe1_ip", "type": "text", "x": 200, "y": 440, "text": "100.64.2.33", "fontSize": "12px", "fontFamily": "Consolas, monospace", "color": "#7f8c8d", "backgroundColor": "transparent", "rotation": 0 },
                { "id": "text_pe2_ip", "type": "text", "x": 1100, "y": 440, "text": "100.64.0.220", "fontSize": "12px", "fontFamily": "Consolas, monospace", "color": "#7f8c8d", "backgroundColor": "transparent", "rotation": 0 }
            ],
            "metadata": { "deviceIdCounter": 2, "linkIdCounter": 1, "textIdCounter": 7, "description": "Logical view - sub-interfaces attached to link" }
        };
    }
    
    // PHYSICAL VIEW: Full hierarchical path with DNAAS leaf switches and fabric
    // Includes all interfaces, sub-interfaces, bundles, and VLAN manipulation
    // Layout: Spread devices horizontally, stagger interface labels to prevent overlap
    getDnaasBD210Topology() {
        return {
            "version": "1.0",
            "objects": [
                // ═══════════════════════════════════════════════════════════════════
                // DEVICES - Hierarchical Layout (3 tiers, wider spacing)
                // ═══════════════════════════════════════════════════════════════════
                
