            return btn;
        };
        
        const createSeparator = () => {
            const sep = document.createElement('div');
            // MODE-AWARE: Separator color matches mode
            const sepColor = isDarkMode ? 'rgba(255, 255, 255, 0.2)' : 'rgba(0, 0, 0, 0.12)';
            sep.style.cssText = `width: 1px; height: 18px; background: ${sepColor}; margin: 0 4px;`;
            return sep;
        };
        
        // === LINK TOOLBAR BUTTONS ===
        
        // Add Adjacent Text button - uses existing showAdjacentTextMenu
        toolbar.appendChild(createButton('text', 'Add Text', () => {
            this.hideLinkSelectionToolbar();
            // Use existing adjacent text menu (same as context menu)
            this.showAdjacentTextMenu(link);
        }));
        
        toolbar.appendChild(createSeparator());
        
        // Color button - shows color palette popup positioned relative to toolbar
        toolbar.appendChild(createButton('palette', 'Color', () => {
            // DON'T hide toolbar - popup positions relative to it
            this.showColorPalettePopupFromToolbar(link, 'link', toolbar);
        }, { autoClose: false }));
        
        // Width button - shows width slider positioned relative to toolbar
        toolbar.appendChild(createButton('ruler', 'Width', () => {
            // DON'T hide toolbar - popup positions relative to it
            this.showLinkWidthSlider(link);
        }, { autoClose: false }));
        
        // Style button - shows style options positioned relative to toolbar
        toolbar.appendChild(createButton('sparkle', 'Style', () => {
            // DON'T hide toolbar - popup positions relative to it
            this.showLinkStyleOptions(link);
        }, { autoClose: false }));
        
        // Curve button - shows curve options positioned relative to toolbar
        toolbar.appendChild(createButton('curve', 'Curve', () => {
            // DON'T hide toolbar - popup positions relative to it
            this.showLinkCurveOptions(link);
        }, { autoClose: false }));
        
        // Attach/Detach button - for unbound links or links with device connections
        // Only show for unbound links (they can attach/detach from devices)
        if (link.type === 'unbound') {
            // Check if link has any device attachments
            const hasStartAttachment = link.device1 || (link.connectedTo && link.connectedTo.thisEndpoint === 'start');
            const hasEndAttachment = link.device2 || (link.connectedTo && link.connectedTo.thisEndpoint === 'end');
            const hasAnyAttachment = hasStartAttachment || hasEndAttachment;
            
            // Determine button state based on attachment and sticky status
            // ENHANCED: Use new magnet icons with/without field waves
            let attachIcon, attachTitle, attachColor;
            if (hasAnyAttachment) {
                // Link is attached to device(s) - show magnet with waves (attached state)
                attachIcon = 'magnet';
                attachTitle = 'Detach from Device(s)';
                attachColor = 'rgba(46, 204, 113, 0.9)'; // Green when attached
            } else {
                // Link is not attached - check sticky status
                const isStickyDisabled = link.stickyDisabled === true;
                if (isStickyDisabled) {
                    // Sticky is disabled - show magnet-off icon (no field waves, dimmed)
                    attachIcon = 'magnet-off';
                    attachTitle = 'Enable Sticky (Attach to Devices)';
                    attachColor = 'rgba(150, 150, 150, 0.7)'; // Gray when disabled
                } else {
                    // Sticky is enabled - show magnet icon with waves (ready to attach)
                    attachIcon = 'magnet';
                    attachTitle = 'Disable Sticky';
                    attachColor = 'rgba(52, 152, 219, 0.9)'; // Blue when sticky enabled
                }
            }
            
            toolbar.appendChild(createButton(attachIcon, attachTitle, () => {
                if (hasAnyAttachment) {
                    // Detach from all devices
                    this.saveState();
                    
                    // Clear device attachments
                    if (link.device1) {
                        // Store current position as absolute before detaching
                        const device1 = this.objects.find(o => o.id === link.device1);
                        if (device1 && link.start) {
                            // Position is already set, just clear the attachment
                        }
                        delete link.device1;
                    }
                    if (link.device2) {
                        delete link.device2;
                    }
                    
                    // Clear connectedTo attachment
                    if (link.connectedTo) {
                        delete link.connectedTo;
                    }
                    
                    // Mark link as non-sticky (won't auto-attach to devices)
                    link.stickyDisabled = true;
                    
                    this.showToast('Link detached from devices', 'info');
                    this.hideLinkSelectionToolbar();
                    this.draw();
                    this.scheduleAutoSave();
                    
                    // Re-show toolbar to reflect new state
                    setTimeout(() => {
                        if (this.selectedObject === link) {
                            this.showLinkSelectionToolbar(link);
                        }
                    }, 100);
                } else {
                    // Toggle sticky mode for this link
                    this.saveState();
                    const isStickyDisabled = link.stickyDisabled === true;
                    
                    if (isStickyDisabled) {
                        // Enable sticky mode (will attach when near devices)
                        delete link.stickyDisabled;
                        this.showToast('Sticky enabled - drag endpoint near a device to attach', 'success');
                    } else {
                        // Disable sticky mode (won't auto-attach to devices)
                        link.stickyDisabled = true;
                        this.showToast('Sticky disabled - link will not auto-attach to devices', 'info');
                    }
                    
                    this.hideLinkSelectionToolbar();
                    this.scheduleAutoSave();
                    
                    // Re-show toolbar to reflect new state
                    setTimeout(() => {
                        if (this.selectedObject === link) {
                            this.showLinkSelectionToolbar(link);
                        }
                    }, 100);
                }
            }, { color: attachColor }));
        }
        
        toolbar.appendChild(createSeparator());
        
        // Duplicate button
        toolbar.appendChild(createButton('copy', 'Duplicate', () => {
            this.hideLinkSelectionToolbar();
            this.duplicateObject(link, false);
        }));
        
        // Copy Style button
        toolbar.appendChild(createButton('brush', 'Copy Style', () => {
            this.hideLinkSelectionToolbar();
            this.copyObjectStyle(link);
            this.showToast('Style copied! Click another link to paste.', 'success');
        }));
        
        toolbar.appendChild(createSeparator());
        
        // Delete button
        toolbar.appendChild(createButton('trash', 'Delete', () => {
            this.hideLinkSelectionToolbar();
            this.deleteSelected();
        }, { isDestructive: true }));
        
        // Prevent clicks from propagating to canvas (prevents deselection/re-selection)
        toolbar.addEventListener('mousedown', (e) => {
            e.stopPropagation();
            e.preventDefault();
        });
        toolbar.addEventListener('click', (e) => {
            e.stopPropagation();
            e.preventDefault();
        });
        
        document.body.appendChild(toolbar);
        this._linkSelectionToolbar = toolbar;
        this._linkSelectionToolbarTarget = link;
        
        // Keep toolbar within viewport
        requestAnimationFrame(() => {
            const toolbarRect = toolbar.getBoundingClientRect();
            if (toolbarRect.right > window.innerWidth - 10) {
                toolbar.style.left = `${window.innerWidth - toolbarRect.width / 2 - 10}px`;
            }
            if (toolbarRect.bottom > window.innerHeight - 10) {
                toolbar.style.top = `${toolbarY - 50}px`;
            }
        });
    }
    
    hideLinkSelectionToolbar() {
        if (this._linkSelectionToolbar) {
            this._linkSelectionToolbar.remove();
            this._linkSelectionToolbar = null;
            this._linkSelectionToolbarTarget = null;
        }
        this._hideToolbarTooltip();
        // Hide related popups
        const widthSlider = document.getElementById('link-width-slider-popup');
        if (widthSlider) widthSlider.remove();
        const stylePopup = document.getElementById('link-style-options-popup');
        if (stylePopup) stylePopup.remove();
        const curvePopup = document.getElementById('link-curve-options-popup');
        if (curvePopup) curvePopup.remove();
    }
    
    // Shared tooltip helpers for toolbars
    _showToolbarTooltip(btn, title) {
        let tooltip = document.getElementById('tb-active-tooltip');
        if (!tooltip) {
            tooltip = document.createElement('div');
            tooltip.id = 'tb-active-tooltip';
            document.body.appendChild(tooltip);
        }
        tooltip.textContent = title;
        tooltip.style.cssText = `
            position: fixed;
            background: rgba(15, 15, 20, 0.96);
            color: #fff;
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 11px;
            font-weight: 500;
            font-family: system-ui, -apple-system, sans-serif;
            white-space: nowrap;
            pointer-events: none;
            z-index: 100000;
            box-shadow: 0 3px 12px rgba(0,0,0,0.4);
            opacity: 1;
            visibility: visible;
        `;
        const btnRect = btn.getBoundingClientRect();
        tooltip.style.left = `${btnRect.left + btnRect.width / 2}px`;
        tooltip.style.top = `${btnRect.top - 8}px`;
        tooltip.style.transform = 'translate(-50%, -100%)';
    }
    
    _hideToolbarTooltip() {
        const tooltip = document.getElementById('tb-active-tooltip');
        if (tooltip) {
            tooltip.style.opacity = '0';
            tooltip.style.visibility = 'hidden';
        }
    }
    
    // Hide ALL selection toolbars (text, device, link)
    hideAllSelectionToolbars() {
        this.hideTextSelectionToolbar();
        this.hideDeviceSelectionToolbar();
        this.hideLinkSelectionToolbar();
        this.hideShapeSelectionToolbar();
        this.hideMultiSelectContextMenu();
    }
    
    // ==================== MULTI-SELECT CONTEXT MENU ====================
    // Special liquid glass menu for controlling multiple selected objects by category
    
    showMultiSelectContextMenu(screenX, screenY) {
