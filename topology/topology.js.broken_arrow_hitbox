                { x: x + cx, y: y - cy, id: 'ne', size: cornerHandleSize, isCorner: true },
                { x: x - cx, y: y + cy, id: 'sw', size: cornerHandleSize, isCorner: true },
                { x: x + cx, y: y + cy, id: 'se', size: cornerHandleSize, isCorner: true },
