        const centerScreenX = (device.x * this.zoom + this.panOffset.x) / scaleX + rect.left;
        const centerScreenY = (device.y * this.zoom + this.panOffset.y) / scaleY + rect.top;
        
        // Position toolbar below device with sufficient gap to avoid overlap
        const deviceRadius = (device.radius || 30) * this.zoom / scaleY;
