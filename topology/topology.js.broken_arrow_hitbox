    // Paste style to a target object
    // ENHANCED: Works universally between ALL object types - applies whatever properties are applicable
    pasteStyleToObject(targetObj) {
        if (!this.copiedStyle || !targetObj) return false;
        
        const sourceType = this.copiedStyle.type;
        const targetType = targetObj.type;
        const isLinkType = (t) => t === 'link' || t === 'unbound';
        
        // Check if types are compatible for full style copy
        const sameCategory = (sourceType === targetType) || 
                            (isLinkType(sourceType) && isLinkType(targetType));
        
        // Apply style
        this.saveState();
        
        // ENHANCED: If target is a UL that's part of a BUL, apply style to ALL links in the chain
        let targetsToStyle = [targetObj];
        if (targetObj.type === 'unbound' && (targetObj.mergedWith || targetObj.mergedInto)) {
            targetsToStyle = this.getAllMergedLinks(targetObj);
        }
        
        // Apply style to all targets using helper
        targetsToStyle.forEach(obj => {
            this._applyStyleToObject(obj);
        });
        
        // Log appropriate message
        if (this.debugger) {
            const isBul = targetsToStyle.length > 1;
            if (sameCategory) {
                if (isBul) {
                    this.debugger.logSuccess(`🖌️ Full style pasted to BUL (${targetsToStyle.length} links)`);
                } else {
                    this.debugger.logSuccess(`🖌️ Full style pasted to ${targetObj.label || targetObj.type}`);
                }
            } else {
                if (isBul) {
                    this.debugger.logSuccess(`🎨 Color pasted to BUL (${targetsToStyle.length} links) (different type: ${sourceType} → ${targetType})`);
                } else {
                    this.debugger.logSuccess(`🎨 Color pasted to ${targetObj.label || targetObj.type} (different type: ${sourceType} → ${targetType})`);
                }
            }
        }
        
        this.draw();
        return true;
    }
    
    // Exit paste style mode
    exitPasteStyleMode() {
        this.pasteStyleMode = false;
        this.csmsMode = false; // Also clear CS-MS mode
        
        // Clear CS-MS animation frame if running
        if (this._csmsAnimationFrame) {
            cancelAnimationFrame(this._csmsAnimationFrame);
            this._csmsAnimationFrame = null;
        }
        
        this.canvas.style.cursor = 'default';
        this.setMode('base');
        
        if (this.debugger) {
            this.debugger.logInfo(`🖌️ Exited paste style mode`);
        }
        
        this.draw();
