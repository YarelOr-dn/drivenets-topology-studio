    // ==================== SHAPE SELECTION TOOLBAR ====================
    // Floating toolbar for shapes - liquid glass style
    
    showShapeSelectionToolbar(shape) {
        if (!shape || shape.type !== 'shape') return;
        
        // Hide other toolbars
        this.hideShapeSelectionToolbar();
        this.hideDeviceSelectionToolbar();
        this.hideLinkSelectionToolbar();
        this.hideTextSelectionToolbar();
        
        // Calculate screen position of the shape
        const rect = this.canvas.getBoundingClientRect();
        const scaleX = this.canvas.width / rect.width;
        const scaleY = this.canvas.height / rect.height;
        
        // Shape center position in screen coordinates
        const centerScreenX = (shape.x * this.zoom + this.panOffset.x) / scaleX + rect.left;
        const centerScreenY = (shape.y * this.zoom + this.panOffset.y) / scaleY + rect.top;
        
        // Calculate bottom of shape in screen coordinates
        const bottomY = centerScreenY + ((shape.height / 2) * this.zoom / scaleY);
        
        // Position toolbar below the shape
        const toolbarGap = 25;
        const toolbarX = centerScreenX;
        let toolbarY = bottomY + toolbarGap;
        
        // ENHANCED: Detect if shape fills most of the screen (zoomed in on large shape)
        // If toolbar would be off-screen, position it at a fixed location in the lower portion of the viewport
        const viewportHeight = window.innerHeight;
        const viewportWidth = window.innerWidth;
        const estimatedToolbarHeight = 280; // Approximate height of shape toolbar (reduced estimate)
        const estimatedToolbarWidth = 200; // Approximate width
        
        // Calculate shape bounds in screen coordinates
        const shapeTopY = centerScreenY - ((shape.height / 2) * this.zoom / scaleY);
        const shapeLeftX = centerScreenX - ((shape.width / 2) * this.zoom / scaleX);
        const shapeRightX = centerScreenX + ((shape.width / 2) * this.zoom / scaleX);
        
        // Check if the calculated toolbar position would be off-screen or too close to bottom
        const wouldBeOffScreen = toolbarY + estimatedToolbarHeight > viewportHeight - 20;
        
        // Check if shape fills most of the screen (either dimension)
        const shapeFillsVertically = shapeTopY < 80 && bottomY > viewportHeight - 80;
        const shapeFillsHorizontally = shapeLeftX < 80 && shapeRightX > viewportWidth - 80;
        const shapeFillsScreen = shapeFillsVertically || shapeFillsHorizontally;
        
        // If toolbar would be off-screen or shape fills the screen, use fixed positioning
        let useFixedPosition = wouldBeOffScreen || shapeFillsScreen;
        
        if (useFixedPosition) {
            // Position toolbar at a fixed visible location - bottom-center of viewport
            toolbarY = viewportHeight - estimatedToolbarHeight - 40;
            
            // Ensure it's not too high (minimum 60px from top)
            toolbarY = Math.max(60, toolbarY);
            
            // Also center horizontally if the original X would be off-screen
            if (toolbarX < estimatedToolbarWidth / 2 + 10 || toolbarX > viewportWidth - estimatedToolbarWidth / 2 - 10) {
                // Use center of visible canvas area (accounting for left toolbar)
                const leftToolbar = document.getElementById('left-toolbar');
                const leftOffset = leftToolbar && !leftToolbar.classList.contains('collapsed') ? 220 : 0;
                // Center in remaining space
                // Note: We'll set this via the left style, not toolbarX variable
                // This will be handled in the requestAnimationFrame below
            }
        }
        
        // Create the toolbar container - Liquid Glass Style (ultra-transparent, links visible through)
        const toolbar = document.createElement('div');
        toolbar.id = 'shape-selection-toolbar';
        const isDarkMode = this.darkMode;
