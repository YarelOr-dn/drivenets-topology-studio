                const text = this.createText(this.selectedObject.x + this.selectedObject.radius + 10, this.selectedObject.y);
                text.text = '';
                this.objects.push(text);
                this.selectedObject = text;
                this.selectedObjects = [text];
                this.updateTextProperties();
                this.draw();
            }
        }
