        this.ctx.font = `${fontWeight} ${fontSize}px ${fontFamily}`;
        const textContent = textObj.text || 'Text';
        const lines = textContent.split('\n');
        const lineCount = Math.max(1, lines.length);
        
        // Measure the widest line
        let maxLineWidth = 0;
        lines.forEach(line => {
            const metrics = this.ctx.measureText(line || ' ');
            maxLineWidth = Math.max(maxLineWidth, metrics.width);
        });
        this.ctx.restore();
        
        const lineHeight = fontSize * 1.3;
        const textContentHeight = lineCount * lineHeight;
        const bgPadding = textObj.showBackground !== false ? (textObj.bgPadding || 8) : 4;
        const boxHeight = textContentHeight + bgPadding * 2;
        const boxWidth = maxLineWidth + bgPadding * 2;
        
        // Get rotation in radians
        const rotation = (textObj.rotation || 0) * Math.PI / 180;
        
        // Calculate the 4 corners of the text box (relative to center)
        const halfW = boxWidth / 2;
        const halfH = boxHeight / 2;
        const corners = [
            { x: -halfW, y: -halfH },
            { x: halfW, y: -halfH },
            { x: halfW, y: halfH },
            { x: -halfW, y: halfH }
        ];
        
        // Rotate corners and find bounding box
        const cos = Math.cos(rotation);
        const sin = Math.sin(rotation);
        let maxY = -Infinity;
        
        corners.forEach(corner => {
            const rotY = corner.x * sin + corner.y * cos;
            maxY = Math.max(maxY, rotY);
        });
        
        // Text position is center, convert to screen coordinates
        const centerScreenX = (textObj.x * this.zoom + this.panOffset.x) / scaleX + rect.left;
        const centerScreenY = (textObj.y * this.zoom + this.panOffset.y) / scaleY + rect.top;
        
        // Position below rotated bounding box with consistent gap
        // FIXED: Apply zoom to the maxY offset properly
        const bottomY = centerScreenY + (maxY * this.zoom / scaleY);
        const toolbarGap = 20; // Fixed pixel gap below text
        
        this._textSelectionToolbar.style.left = `${centerScreenX}px`;
        this._textSelectionToolbar.style.top = `${bottomY + toolbarGap}px`;
        this._textSelectionToolbar.style.transform = `translateX(-50%)`;
    }
    
