                devices.forEach(d => d.y = avgY);
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Aligned ${devices.length} devices horizontally`, 'success');
            }));
            content.appendChild(createActionBtn('align-v', 'Align Vertically', () => {
                if (devices.length < 2) return;
                const avgX = devices.reduce((sum, d) => sum + d.x, 0) / devices.length;
                devices.forEach(d => d.x = avgX);
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Aligned ${devices.length} devices vertically`, 'success');
            }));
            
