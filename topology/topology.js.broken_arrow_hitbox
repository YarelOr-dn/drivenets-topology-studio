        };
        
        // Separator helper - MODE-AWARE colors
        const createSeparator = () => {
            const sep = document.createElement('div');
            const sepColor = isDark ? 'rgba(255, 255, 255, 0.2)' : 'rgba(0, 0, 0, 0.12)';
            sep.style.cssText = `
                width: 1px; 
