                this.ctx.beginPath();
                this.ctx.arc(x + handleRadius * 0.25, y + handleRadius * 0.25, handleRadius * 0.2, 0, Math.PI * 2);
                this.ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';
                this.ctx.fill();
