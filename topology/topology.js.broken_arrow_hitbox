        }
    }
    
    /**
     * Cancel an ongoing LLDP operation on a device
     * @param {Object} device - The device object
     */
    async _cancelLldpOnDevice(device) {
        // Use the target device if device param doesn't have job ID
        const targetDevice = (device && device._lldpJobId) ? device : this._lldpTargetDevice;
        
        if (!targetDevice || !targetDevice._lldpJobId) {
            console.warn('[LLDP] No job to cancel');
            // Still clear any visual indicator
            if (device) this._clearDeviceLldpStatus(device);
            if (targetDevice && targetDevice !== device) this._clearDeviceLldpStatus(targetDevice);
            return;
        }
        
        const jobId = targetDevice._lldpJobId;
        console.log(`[LLDP] Cancelling job ${jobId}`);
        
        try {
            const response = await fetch(`http://localhost:8765/api/enable-lldp/cancel?job_id=${jobId}`);
            const result = await response.json();
            
            if (result.status === 'cancelled' || result.error === 'Job not found') {
                // Clear the visual indicator completely (don't show error)
                this._clearDeviceLldpStatus(targetDevice);
                // Clear last result so button returns to normal
                delete targetDevice._lastLldpResult;
                delete targetDevice._lldpJobId;
                this.showToast('LLDP operation cancelled', 'info');
            }
        } catch (error) {
            console.error('[LLDP] Cancel failed:', error);
            // Still clear visual indicator on error
            this._clearDeviceLldpStatus(targetDevice);
            delete targetDevice._lastLldpResult;
            delete targetDevice._lldpJobId;
        }
    }
    
    /**
     * Enable LLDP and admin-state on all interfaces of a device.
     * Uses job-based API with polling for real-time feedback.
     * Shows progress indicator ON the device itself.
     * @param {string} serial - Device serial, hostname, or IP
     * @param {Object} deviceObj - Optional device object from canvas (for better IP resolution)
     */
    async _enableLldpOnDevice(serial, deviceObj = null) {
        // Store reference for progress updates
        this._lldpTargetDevice = deviceObj;
        
        try {
            // Show initial status on device
            if (deviceObj) {
                this._updateDeviceLldpStatus(deviceObj, 'Connecting...', 'running', 0);
                // Clear any previous job ID
                delete deviceObj._lldpJobId;
            }
            
            // Resolve serial to IP address if needed
            let host = serial;
            const isIPAddress = /^\d+\.\d+\.\d+\.\d+$/.test(serial);
            
            // First, check if we have a device object with SSH config containing an IP
            if (!isIPAddress && deviceObj) {
                // Try to extract IP from the device's SSH config
                const devSshHost = deviceObj.sshConfig?.host || deviceObj.deviceAddress;
                if (devSshHost && /^\d+\.\d+\.\d+\.\d+$/.test(devSshHost)) {
                    console.log(`[LLDP] Using device's SSH config IP: ${devSshHost}`);
                    host = devSshHost;
                } else if (deviceObj.sshConfig?.hostBackup && /^\d+\.\d+\.\d+\.\d+$/.test(deviceObj.sshConfig.hostBackup)) {
                    console.log(`[LLDP] Using device's backup SSH IP: ${deviceObj.sshConfig.hostBackup}`);
                    host = deviceObj.sshConfig.hostBackup;
                }
            }
            
            if (!isIPAddress && host === serial) {
                // Try to resolve from managed devices
                if (typeof ScalerAPI !== 'undefined' && ScalerAPI.getDevices) {
                    try {
                        const result = await ScalerAPI.getDevices();
                        const managedDevices = result.devices || [];
                        const cleanSerial = (serial || '').toLowerCase().trim();
                        
                        for (const managed of managedDevices) {
                            const managedHostname = (managed.hostname || '').toLowerCase();
                            const managedId = (managed.id || '').toLowerCase();
                            const managedSerial = (managed.serial || '').toLowerCase();
                            
                            if (managedHostname === cleanSerial || managedId === cleanSerial ||
                                managedSerial === cleanSerial || cleanSerial.includes(managedHostname)) {
                                if (managed.ip) {
                                    console.log(`[LLDP] Resolved "${serial}" → "${managed.ip}" via managed devices`);
                                    host = managed.ip;
                                    break;
                                }
                            }
                        }
                    } catch (err) {
                        console.warn('[LLDP] Failed to resolve via managed devices:', err);
                    }
                }
                
                // Also check canvas devices for SSH config
                if (host === serial && this.devices) {
                    for (const dev of this.devices) {
                        const label = (dev.label || '').toLowerCase();
                        const devSerial = (dev.deviceSerial || '').toLowerCase();
                        const cleanSerial = serial.toLowerCase();
                        
                        if (label === cleanSerial || devSerial === cleanSerial || label.includes(cleanSerial)) {
                            // Check if device has SSH config with an IP
                            const sshHost = dev.sshConfig?.host || dev.deviceAddress;
                            if (sshHost && /^\d+\.\d+\.\d+\.\d+$/.test(sshHost)) {
                                console.log(`[LLDP] Resolved "${serial}" → "${sshHost}" via canvas device`);
                                host = sshHost;
                                break;
                            }
                        }
                    }
                }
            }
            
            console.log(`[LLDP] Using host: ${host} (original: ${serial})`);
            
            // Check if we still don't have an IP address
            const hostIsIP = /^\d+\.\d+\.\d+\.\d+$/.test(host);
            if (!hostIsIP) {
                // Host is still a serial/hostname - warn user but try anyway
                console.warn(`[LLDP] Warning: "${host}" is not an IP address. SSH may fail if not resolvable.`);
            }
            
            // Try ScalerAPI first
            if (typeof ScalerAPI !== 'undefined' && ScalerAPI.enableDeviceLldp) {
                return await ScalerAPI.enableDeviceLldp({ serial: host });
            }
            
            // Start the LLDP enable job
            const startResponse = await fetch('http://localhost:8765/api/enable-lldp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ serial: host })
            });
            
            if (!startResponse.ok) {
                const err = await startResponse.json();
                throw new Error(err.error || 'API error');
            }
            
            const startResult = await startResponse.json();
            const jobId = startResult.job_id;
            
            if (!jobId) {
                throw new Error('No job ID returned');
            }
            
            // Store job ID on device for cancellation support
            if (this._lldpTargetDevice) {
                this._lldpTargetDevice._lldpJobId = jobId;
            }
            
            // Get output div for real-time feedback (optional - for DNAAS panel)
            const outputDiv = document.getElementById('dnaas-output');
            let lastLineCount = 0;
            let lastStatusMessage = '';
            
            // Poll for status with real-time feedback
            const maxAttempts = 180; // 3 minutes max (more time for large interface counts)
            for (let attempt = 0; attempt < maxAttempts; attempt++) {
                await new Promise(resolve => setTimeout(resolve, 500)); // Poll every 500ms
                
                const statusResponse = await fetch(`http://localhost:8765/api/enable-lldp/status?job_id=${jobId}`);
                if (!statusResponse.ok) continue;
                
                const status = await statusResponse.json();
                
                // Parse latest output line for device indicator update
                const lines = status.output_lines || [];
                if (lines.length > 0 && this._lldpTargetDevice) {
                    const latestLine = lines[lines.length - 1];
                    // Calculate progress based on interface count
                    let progress = 0;
                    const interfaceMatch = latestLine.match(/(\d+)\/(\d+)\s+interfaces/);
                    if (interfaceMatch) {
                        progress = Math.round((parseInt(interfaceMatch[1]) / parseInt(interfaceMatch[2])) * 100);
                    } else if (latestLine.includes('Connecting')) {
                        progress = 5;
                    } else if (latestLine.includes('CLI ready')) {
                        progress = 10;
                    } else if (latestLine.includes('Getting interface')) {
                        progress = 15;
                    } else if (latestLine.includes('LLDP globally')) {
                        progress = 25;
                    } else if (latestLine.includes('Committing')) {
                        progress = 90;
                    }
                    
                    // Simplify message for device label
                    let shortMessage = latestLine.replace(/[📋📝🔧🔌📡📊⏳✓✗✅]/g, '').trim();
                    // Make it very short for device display
                    if (shortMessage.includes('interface')) {
                        const match = shortMessage.match(/(\d+\/\d+)/);
                        shortMessage = match ? `${match[1]} interfaces` : 'Configuring...';
                    } else if (shortMessage.includes('Committing')) {
                        shortMessage = 'Committing...';
                    } else if (shortMessage.includes('LLDP globally')) {
                        shortMessage = 'Enabling LLDP...';
                    } else if (shortMessage.length > 20) {
                        shortMessage = shortMessage.substring(0, 18) + '...';
                    }
                    
                    if (shortMessage !== lastStatusMessage) {
                        this._updateDeviceLldpStatus(this._lldpTargetDevice, shortMessage, 'running', progress);
                        lastStatusMessage = shortMessage;
                    }
                }
                
                // Show new output lines in DNAAS panel if visible
                if (outputDiv && lines.length > lastLineCount) {
                    const newLines = lines.slice(lastLineCount);
                    for (const line of newLines) {
                        // Color-code the output
                        let color = '#ecf0f1'; // Default gray
                        if (line.includes('✓') || line.includes('✅')) color = '#27ae60'; // Green
                        else if (line.includes('✗') || line.includes('Error')) color = '#e74c3c'; // Red
                        else if (line.includes('⏳') || line.includes('🔧') || line.includes('📝')) color = '#f39c12'; // Orange
                        else if (line.includes('🔌') || line.includes('📋')) color = '#3498db'; // Blue
                        
                        outputDiv.innerHTML += `<span style="color: ${color};">${line}</span>\n`;
                    }
                    lastLineCount = lines.length;
                    outputDiv.scrollTop = outputDiv.scrollHeight; // Auto-scroll
                }
                
                if (status.status === 'completed') {
                    const count = status.interfaces_enabled || 0;
                    if (this._lldpTargetDevice) {
                        this._updateDeviceLldpStatus(this._lldpTargetDevice, `${count} interfaces`, 'success', 100);
                    }
                    return {
                        success: true,
                        interfaces_enabled: status.interfaces_enabled,
                        interfaces: status.interfaces
                    };
                } else if (status.status === 'failed') {
                    if (this._lldpTargetDevice) {
                        this._updateDeviceLldpStatus(this._lldpTargetDevice, 'Failed', 'error', 0);
                    }
                    throw new Error(status.error || 'LLDP enable failed');
                }
            }
            
            if (this._lldpTargetDevice) {
                this._updateDeviceLldpStatus(this._lldpTargetDevice, 'Timed out', 'error', 0);
            }
            throw new Error('LLDP enable timed out');
            
        } catch (error) {
            console.error('[LLDP Enable] Error:', error);
            // Show error on device if not already shown
            if (this._lldpTargetDevice && !error.message.includes('timed out') && !error.message.includes('failed')) {
                this._updateDeviceLldpStatus(this._lldpTargetDevice, 'Error', 'error', 0);
            }
            return { success: false, error: error.message };
        }
    }
    
