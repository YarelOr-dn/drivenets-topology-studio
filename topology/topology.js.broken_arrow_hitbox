                        if (obj.x === undefined || obj.y === undefined || isNaN(obj.x) || isNaN(obj.y)) {
                            console.warn(`Device "${obj.label || obj.id}" missing coordinates, placing at grid position ${index}`);
                            obj.x = 200 + (index % 5) * 150; // Spread devices in a grid
                            obj.y = 200 + Math.floor(index / 5) * 150;
                        }
