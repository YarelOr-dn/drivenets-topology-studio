    // Get the current endpoints of a link
    getLinkEndpoints(link) {
        let startX, startY, endX, endY;
        
        if (link.type === 'unbound') {
            // For unbound links, use the stored start/end or device positions
            const dev1 = link.device1 ? this.objects.find(o => o.id === link.device1) : null;
            const dev2 = link.device2 ? this.objects.find(o => o.id === link.device2) : null;
            
            startX = dev1 ? dev1.x : link.start.x;
            startY = dev1 ? dev1.y : link.start.y;
            endX = dev2 ? dev2.x : link.end.x;
            endY = dev2 ? dev2.y : link.end.y;
        } else if (link.type === 'link') {
            const dev1 = this.objects.find(o => o.id === link.device1);
            const dev2 = this.objects.find(o => o.id === link.device2);
            if (!dev1 || !dev2) return null;
            startX = dev1.x;
            startY = dev1.y;
            endX = dev2.x;
            endY = dev2.y;
        } else {
