            // ===== LAYER 7: Crisp white border =====
            this.ctx.beginPath();
            this.ctx.arc(x, y, handleRadius, 0, Math.PI * 2);
            this.ctx.strokeStyle = `rgba(255, 255, 255, ${0.95 * opacity})`;
            this.ctx.lineWidth = (isOnCP || isDragging ? 2.5 : 1.5) / this.zoom;
            this.ctx.stroke();
            
