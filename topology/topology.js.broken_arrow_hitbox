            this.hideDeviceSelectionToolbar();
            this.duplicateObject(device, false);
        }));
        
        // Copy Style button
        toolbar.appendChild(createButton('brush', 'Copy Style', () => {
            this.hideDeviceSelectionToolbar();
            this.copyObjectStyle(device);
            this.showToast('Style copied! Click another device to paste.', 'success');
        }));
        
        // Lock/Unlock button
        const isLocked = device.locked || false;
        toolbar.appendChild(createButton(isLocked ? 'lock' : 'unlock', isLocked ? 'Unlock' : 'Lock', () => {
            device.locked = !device.locked;
            this.saveState();
            this.draw();
            this.showToast(device.locked ? 'Device locked' : 'Device unlocked', 'info');
            setTimeout(() => this.showDeviceSelectionToolbar(device), 50);
        }));
        
        toolbar.appendChild(createSeparator());
        
        // Delete button
        toolbar.appendChild(createButton('trash', 'Delete', () => {
            this.hideDeviceSelectionToolbar();
            this.deleteSelected();
        }, { isDestructive: true }));
        
        // Prevent clicks from propagating to canvas (prevents deselection/re-selection)
        toolbar.addEventListener('mousedown', (e) => {
            e.stopPropagation();
            e.preventDefault();
        });
        toolbar.addEventListener('click', (e) => {
            e.stopPropagation();
            e.preventDefault();
        });
        
        document.body.appendChild(toolbar);
        this._deviceSelectionToolbar = toolbar;
        this._deviceSelectionToolbarTarget = device;
        
        // Keep toolbar within viewport
        requestAnimationFrame(() => {
            const toolbarRect = toolbar.getBoundingClientRect();
            if (toolbarRect.right > window.innerWidth - 10) {
                toolbar.style.left = `${window.innerWidth - toolbarRect.width / 2 - 10}px`;
            }
            if (toolbarRect.bottom > window.innerHeight - 10) {
                toolbar.style.top = `${toolbarY - deviceRadius - toolbarGap - toolbarRect.height - 10}px`;
            }
        });
    }
    
