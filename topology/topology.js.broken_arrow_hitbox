    renderMinimap() {
        if (!this.minimap || !this.minimap.canvas) return;
        
        const canvas = this.minimap.canvas;
        
        // Updated canvas dimensions for new liquid glass design
        const canvasWidth = 188;
        const canvasHeight = 100;
        
        // Ensure canvas has correct internal resolution
        if (canvas.width !== canvasWidth || canvas.height !== canvasHeight) {
            canvas.width = canvasWidth;
            canvas.height = canvasHeight;
        }
        
        // Get fresh context every time
        const mmCtx = canvas.getContext('2d');
        if (!mmCtx) {
            console.warn('Minimap: Could not get 2D context');
            return;
        }
        
        // Reset transform
        mmCtx.setTransform(1, 0, 0, 1, 0, 0);
        
        // Clear entire canvas
        mmCtx.clearRect(0, 0, canvasWidth, canvasHeight);
        
        // Liquid glass background with depth
        const bgGrad = mmCtx.createLinearGradient(0, 0, canvasWidth, canvasHeight);
        bgGrad.addColorStop(0, 'rgba(15, 22, 35, 0.6)');
        bgGrad.addColorStop(0.5, 'rgba(10, 16, 28, 0.7)');
        bgGrad.addColorStop(1, 'rgba(8, 12, 22, 0.8)');
        mmCtx.fillStyle = bgGrad;
        mmCtx.fillRect(0, 0, canvasWidth, canvasHeight);
        
        // Subtle inner border glow
        mmCtx.strokeStyle = 'rgba(100, 200, 255, 0.1)';
        mmCtx.lineWidth = 1;
        mmCtx.strokeRect(0.5, 0.5, canvasWidth - 1, canvasHeight - 1);
        
        // Get shared bounds calculation
        const bounds = this.getMinimapBounds();
        if (!bounds || bounds.scale <= 0) return;
        
        const { minX, scale, offsetX, offsetY, viewLeft, viewTop, viewRight, viewBottom } = bounds;
        
        // Transform helper - world coords to minimap coords
        const toMinimap = (x, y) => ({
            x: offsetX + (x - minX) * scale,
            y: offsetY + (y - bounds.minY) * scale
        });
        
        // Draw subtle hexagonal grid pattern (more modern than dots)
        mmCtx.strokeStyle = 'rgba(100, 180, 255, 0.04)';
        mmCtx.lineWidth = 0.5;
        const gridSize = 12;
        for (let x = 0; x < canvasWidth + gridSize; x += gridSize) {
            for (let y = 0; y < canvasHeight + gridSize; y += gridSize * 0.866) {
                const offsetX_grid = (Math.floor(y / (gridSize * 0.866)) % 2) * (gridSize / 2);
                mmCtx.beginPath();
                mmCtx.arc(x + offsetX_grid, y, 1, 0, Math.PI * 2);
                mmCtx.stroke();
            }
        }
        
        // Draw links with neon glow effect
        mmCtx.lineCap = 'round';
        mmCtx.lineJoin = 'round';
        for (const obj of this.objects) {
            if (obj.type === 'link' || obj.type === 'unbound') {
                const endpoints = this.getLinkEndpoints(obj);
                if (endpoints) {
                    const p1 = toMinimap(endpoints.startX, endpoints.startY);
                    const p2 = toMinimap(endpoints.endX, endpoints.endY);
                    
                    // Get link color or use cyan default
                    const linkColor = obj.color || '#64d8ff';
                    
                    // Outer neon glow
                    mmCtx.shadowColor = linkColor;
                    mmCtx.shadowBlur = 6;
                    mmCtx.strokeStyle = linkColor;
                    mmCtx.globalAlpha = 0.3;
                    mmCtx.lineWidth = 4;
                    mmCtx.beginPath();
                    mmCtx.moveTo(p1.x, p1.y);
                    mmCtx.lineTo(p2.x, p2.y);
                    mmCtx.stroke();
                    
                    // Core line
                    mmCtx.shadowBlur = 2;
                    mmCtx.globalAlpha = 0.9;
                    mmCtx.lineWidth = 1.5;
                    mmCtx.beginPath();
                    mmCtx.moveTo(p1.x, p1.y);
                    mmCtx.lineTo(p2.x, p2.y);
                    mmCtx.stroke();
                    
                    mmCtx.shadowBlur = 0;
                    mmCtx.globalAlpha = 1;
                }
            }
        }
        
        // Draw devices with glowing orb effect
        for (const obj of this.objects) {
            if (obj.type === 'device') {
                const p = toMinimap(obj.x, obj.y);
                const radius = 4;
                const deviceColor = obj.color || '#3498db';
                
                // Outer glow
                mmCtx.shadowColor = deviceColor;
                mmCtx.shadowBlur = 8;
                
                // Glowing orb gradient
                const devGrad = mmCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, radius * 1.5);
                devGrad.addColorStop(0, 'rgba(255, 255, 255, 0.9)');
                devGrad.addColorStop(0.3, this.lightenColor(deviceColor, 0.4));
                devGrad.addColorStop(0.7, deviceColor);
                devGrad.addColorStop(1, 'rgba(0, 0, 0, 0)');
                
                mmCtx.beginPath();
                mmCtx.arc(p.x, p.y, radius, 0, Math.PI * 2);
                mmCtx.fillStyle = devGrad;
                mmCtx.fill();
                
                // Reset shadow
                mmCtx.shadowBlur = 0;
                
                // Bright center dot
                mmCtx.beginPath();
                mmCtx.arc(p.x, p.y, 1.5, 0, Math.PI * 2);
                mmCtx.fillStyle = 'rgba(255, 255, 255, 0.9)';
                mmCtx.fill();
            }
        }
        
        // Draw text objects as small glowing markers
        for (const obj of this.objects) {
            if (obj.type === 'text') {
                const p = toMinimap(obj.x, obj.y);
                mmCtx.shadowColor = '#ffa500';
                mmCtx.shadowBlur = 4;
                mmCtx.fillStyle = '#ffa500';
                mmCtx.beginPath();
                mmCtx.arc(p.x, p.y, 2, 0, Math.PI * 2);
                mmCtx.fill();
                mmCtx.shadowBlur = 0;
            }
        }
        
        // Calculate viewport rectangle
        const vpTopLeft = toMinimap(viewLeft, viewTop);
        const vpBottomRight = toMinimap(viewRight, viewBottom);
        
        let vpX = vpTopLeft.x;
        let vpY = vpTopLeft.y;
        let vpWidth = vpBottomRight.x - vpTopLeft.x;
        let vpHeight = vpBottomRight.y - vpTopLeft.y;
        
        // Ensure minimum viewport size for visibility
        const minVpSize = 12;
        if (vpWidth < minVpSize) {
            const centerX = (vpTopLeft.x + vpBottomRight.x) / 2;
            vpX = centerX - minVpSize / 2;
            vpWidth = minVpSize;
        }
        if (vpHeight < minVpSize) {
            const centerY = (vpTopLeft.y + vpBottomRight.y) / 2;
            vpY = centerY - minVpSize / 2;
            vpHeight = minVpSize;
        }
        
        const displayX = vpX;
        const displayY = vpY;
        
        // Liquid glass viewport with animated-looking gradient
        const vpAccent = '#00d4ff'; // Cyan accent
        const vpAccentRgb = '0, 212, 255';
        
        // Viewport glow effect
        mmCtx.shadowColor = vpAccent;
        mmCtx.shadowBlur = 12;
        
        // Draw viewport border with rounded corners
        const vpRadius = 4;
        mmCtx.beginPath();
        mmCtx.roundRect(displayX, displayY, vpWidth, vpHeight, vpRadius);
        mmCtx.strokeStyle = vpAccent;
        mmCtx.lineWidth = 2;
        mmCtx.stroke();
        mmCtx.shadowBlur = 0;
        
        // Viewport fill with glass effect
        const vpGrad = mmCtx.createLinearGradient(displayX, displayY, displayX, displayY + vpHeight);
        vpGrad.addColorStop(0, `rgba(${vpAccentRgb}, 0.15)`);
        vpGrad.addColorStop(0.5, `rgba(${vpAccentRgb}, 0.05)`);
        vpGrad.addColorStop(1, `rgba(${vpAccentRgb}, 0.12)`);
        mmCtx.fillStyle = vpGrad;
        mmCtx.beginPath();
        mmCtx.roundRect(displayX, displayY, vpWidth, vpHeight, vpRadius);
        mmCtx.fill();
        
        // Inner highlight
        mmCtx.strokeStyle = `rgba(${vpAccentRgb}, 0.4)`;
        mmCtx.lineWidth = 1;
        mmCtx.beginPath();
        mmCtx.roundRect(displayX + 1, displayY + 1, vpWidth - 2, vpHeight - 2, vpRadius - 1);
        mmCtx.stroke();
        
        // Corner accents (small glowing dots)
        const cornerSize = 3;
        mmCtx.fillStyle = vpAccent;
        mmCtx.shadowColor = vpAccent;
        mmCtx.shadowBlur = 4;
        
        // Top-left
        mmCtx.beginPath();
        mmCtx.arc(displayX, displayY, cornerSize, 0, Math.PI * 2);
        mmCtx.fill();
        
        // Top-right
        mmCtx.beginPath();
        mmCtx.arc(displayX + vpWidth, displayY, cornerSize, 0, Math.PI * 2);
        mmCtx.fill();
        
        // Bottom-left
        mmCtx.beginPath();
        mmCtx.arc(displayX, displayY + vpHeight, cornerSize, 0, Math.PI * 2);
        mmCtx.fill();
        
        // Bottom-right
        mmCtx.beginPath();
        mmCtx.arc(displayX + vpWidth, displayY + vpHeight, cornerSize, 0, Math.PI * 2);
        mmCtx.fill();
        
        mmCtx.shadowBlur = 0;
        
        // ===== LIQUID GLASS SELECTION RECTANGLE IN MINIMAP =====
        if (this.marqueeActive && this.selectionRectangle && !this.csmsMode) {
            const rect = this.selectionRectangle;
            const mmRect = {
                x: offsetX + (rect.x - minX) * scale,
                y: offsetY + (rect.y - bounds.minY) * scale,
                width: rect.width * scale,
                height: rect.height * scale
            };
            
            // Only draw if rectangle is within minimap bounds
            if (mmRect.x + mmRect.width >= 0 && mmRect.x <= canvasWidth &&
                mmRect.y + mmRect.height >= 0 && mmRect.y <= canvasHeight) {
                
                const radius = 3;
                const pulse = 0.75 + 0.25 * Math.sin(Date.now() / 500);
                
                // Helper for rounded rectangle
                const roundedRect = (x, y, w, h, r) => {
                    r = Math.min(r, w / 2, h / 2);
                    mmCtx.beginPath();
                    mmCtx.moveTo(x + r, y);
                    mmCtx.lineTo(x + w - r, y);
                    mmCtx.quadraticCurveTo(x + w, y, x + w, y + r);
                    mmCtx.lineTo(x + w, y + h - r);
                    mmCtx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
                    mmCtx.lineTo(x + r, y + h);
                    mmCtx.quadraticCurveTo(x, y + h, x, y + h - r);
                    mmCtx.lineTo(x, y + r);
                    mmCtx.quadraticCurveTo(x, y, x + r, y);
                    mmCtx.closePath();
                };
                
                // Outer glow
                mmCtx.shadowColor = '#3498db';
                mmCtx.shadowBlur = 8;
                mmCtx.fillStyle = `rgba(52, 152, 219, ${0.15 * pulse})`;
                roundedRect(mmRect.x, mmRect.y, mmRect.width, mmRect.height, radius);
                mmCtx.fill();
                
                // Main glass fill
                const glassGrad = mmCtx.createLinearGradient(
                    mmRect.x, mmRect.y,
                    mmRect.x + mmRect.width, mmRect.y + mmRect.height
                );
                glassGrad.addColorStop(0, `rgba(52, 152, 219, ${0.3 * pulse})`);
                glassGrad.addColorStop(0.5, `rgba(74, 172, 239, ${0.2 * pulse})`);
                glassGrad.addColorStop(1, `rgba(52, 152, 219, ${0.25 * pulse})`);
                
                roundedRect(mmRect.x, mmRect.y, mmRect.width, mmRect.height, radius);
                mmCtx.fillStyle = glassGrad;
                mmCtx.fill();
                
                // Border
                const borderGrad = mmCtx.createLinearGradient(
                    mmRect.x, mmRect.y,
                    mmRect.x, mmRect.y + mmRect.height
                );
                borderGrad.addColorStop(0, `rgba(255, 255, 255, ${0.7 * pulse})`);
                borderGrad.addColorStop(0.5, `rgba(74, 172, 239, ${0.9 * pulse})`);
                borderGrad.addColorStop(1, `rgba(52, 152, 219, ${0.6 * pulse})`);
                
                roundedRect(mmRect.x, mmRect.y, mmRect.width, mmRect.height, radius);
                mmCtx.strokeStyle = borderGrad;
                mmCtx.lineWidth = 1.5;
                mmCtx.stroke();
                
                mmCtx.shadowBlur = 0;
            }
        }
        
        // Update zoom indicator
        const zoomIndicator = document.getElementById('minimap-zoom-indicator');
        if (zoomIndicator) {
            const zoomPercent = Math.round(this.zoom * 100);
            zoomIndicator.textContent = `${zoomPercent}%`;
            
            // Light mode always uses dark background with white text for visibility
            const isLightMode = document.body.classList.contains('light-mode');
            
            // Change color based on zoom level
            if (zoomPercent < 50) {
                // Orange/warm for zoomed out
                zoomIndicator.style.color = isLightMode ? '#ffffff' : 'rgba(255, 150, 100, 0.9)';
                zoomIndicator.style.borderColor = isLightMode ? 'rgba(255, 180, 120, 0.4)' : 'rgba(255, 150, 100, 0.3)';
                zoomIndicator.style.background = isLightMode ? 'rgba(180, 100, 50, 0.9)' : 'rgba(255, 150, 100, 0.1)';
            } else if (zoomPercent > 150) {
                // Green for zoomed in
                zoomIndicator.style.color = isLightMode ? '#ffffff' : 'rgba(100, 255, 150, 0.9)';
                zoomIndicator.style.borderColor = isLightMode ? 'rgba(120, 255, 180, 0.4)' : 'rgba(100, 255, 150, 0.3)';
                zoomIndicator.style.background = isLightMode ? 'rgba(50, 140, 80, 0.9)' : 'rgba(100, 255, 150, 0.1)';
            } else {
                // Blue for normal zoom
                zoomIndicator.style.color = isLightMode ? '#ffffff' : 'rgba(100, 200, 255, 0.8)';
                zoomIndicator.style.borderColor = isLightMode ? 'rgba(255, 255, 255, 0.25)' : 'rgba(100, 200, 255, 0.2)';
                zoomIndicator.style.background = isLightMode ? 'rgba(30, 64, 120, 0.9)' : 'rgba(100, 200, 255, 0.1)';
            }
            
            // Add shadow for light mode visibility
            if (isLightMode) {
                zoomIndicator.style.boxShadow = '0 2px 6px rgba(0, 0, 0, 0.25)';
            } else {
                zoomIndicator.style.boxShadow = '';
            }
        }
    }
    
    getTopologyBounds() {
        // Get bounding box of all objects
        let minX = Infinity, maxX = -Infinity;
        let minY = Infinity, maxY = -Infinity;
        let hasObjects = false;
        
        for (const obj of this.objects) {
            if (obj.type === 'device') {
                const r = obj.radius || 30;
                minX = Math.min(minX, obj.x - r);
                maxX = Math.max(maxX, obj.x + r);
                minY = Math.min(minY, obj.y - r);
                maxY = Math.max(maxY, obj.y + r);
                hasObjects = true;
            } else if (obj.type === 'text') {
                minX = Math.min(minX, obj.x - 50);
                maxX = Math.max(maxX, obj.x + 50);
                minY = Math.min(minY, obj.y - 20);
                maxY = Math.max(maxY, obj.y + 20);
                hasObjects = true;
            } else if (obj.type === 'link' || obj.type === 'unbound') {
                const endpoints = this.getLinkEndpoints(obj);
                if (endpoints) {
                    minX = Math.min(minX, endpoints.startX, endpoints.endX);
                    maxX = Math.max(maxX, endpoints.startX, endpoints.endX);
                    minY = Math.min(minY, endpoints.startY, endpoints.endY);
                    maxY = Math.max(maxY, endpoints.startY, endpoints.endY);
                    hasObjects = true;
                }
            }
        }
        
        if (!hasObjects) return null;
        
        return { minX, maxX, minY, maxY };
    }
    
    setupScrollbars() {
        const vScrollbar = document.getElementById('vertical-scrollbar');
        const hScrollbar = document.getElementById('horizontal-scrollbar');
        const vThumb = document.getElementById('vertical-thumb');
        const hThumb = document.getElementById('horizontal-thumb');
        
        // Early return if elements don't exist yet
        if (!vScrollbar || !hScrollbar || !vThumb || !hThumb) {
            console.warn('Scrollbar elements not found, skipping setup');
            return;
        }
        
        // Vertical scrollbar (with touchpad support)
        const vThumbDown = (e) => {
            e.stopPropagation();
            this.draggingScrollbar = 'vertical';
            this.scrollbarDragStart = {
                y: e.clientY,
                panOffset: this.panOffset.y
            };
        };
        vThumb.addEventListener('mousedown', vThumbDown);
        if (window.PointerEvent) {
            vThumb.addEventListener('pointerdown', vThumbDown);
        }
        
        // Horizontal scrollbar (with touchpad support)
        const hThumbDown = (e) => {
            e.stopPropagation();
            this.draggingScrollbar = 'horizontal';
            this.scrollbarDragStart = {
                x: e.clientX,
                panOffset: this.panOffset.x
            };
        };
        hThumb.addEventListener('mousedown', hThumbDown);
        if (window.PointerEvent) {
            hThumb.addEventListener('pointerdown', hThumbDown);
        }
        
        // Global mouse/pointer events for scrollbar dragging
        const handleScrollbarMove = (e) => {
            if (this.draggingScrollbar === 'vertical') {
                const deltaY = e.clientY - this.scrollbarDragStart.y;
                const scrollbarHeight = vScrollbar.clientHeight;
                const thumbHeight = vThumb.clientHeight;
                const maxScroll = scrollbarHeight - thumbHeight;
                const scrollRatio = deltaY / maxScroll;
                // Use same dynamic range as updateScrollbars
                const baseRange = 2000;
                const zoomFactor = Math.max(1, this.zoom);
                const panRange = baseRange * zoomFactor;
                this.panOffset.y = this.scrollbarDragStart.panOffset + (scrollRatio * panRange * 2);
                this.savePanOffset();
                this.updateScrollbars();
                this.draw();
            } else if (this.draggingScrollbar === 'horizontal') {
                const deltaX = e.clientX - this.scrollbarDragStart.x;
                const scrollbarWidth = hScrollbar.clientWidth;
                const thumbWidth = hThumb.clientWidth;
                const maxScroll = scrollbarWidth - thumbWidth;
                const scrollRatio = deltaX / maxScroll;
                // Use same dynamic range as updateScrollbars
                const baseRange = 2000;
                const zoomFactor = Math.max(1, this.zoom);
                const panRange = baseRange * zoomFactor;
                this.panOffset.x = this.scrollbarDragStart.panOffset + (scrollRatio * panRange * 2);
                this.savePanOffset();
                this.updateScrollbars();
                this.draw();
            }
        };
        
        document.addEventListener('mousemove', handleScrollbarMove);
        if (window.PointerEvent) {
            document.addEventListener('pointermove', handleScrollbarMove);
        }
        
        // Mouse alignment: Click scrollbar track to jump thumb to mouse position
        vScrollbar.addEventListener('click', (e) => {
            if (e.target === vScrollbar) { // Clicked track, not thumb
                const rect = vScrollbar.getBoundingClientRect();
                const clickY = e.clientY - rect.top;
                const scrollbarHeight = vScrollbar.clientHeight;
                const thumbHeight = vThumb.clientHeight;
                
                // Center thumb at click position
                const newThumbTop = clickY - thumbHeight / 2;
                const maxScroll = scrollbarHeight - thumbHeight;
                const scrollRatio = (newThumbTop / maxScroll) * 2 - 1; // -1 to 1
                
                // Use same dynamic range as updateScrollbars
                const baseRange = 2000;
                const zoomFactor = Math.max(1, this.zoom);
                const panRange = baseRange * zoomFactor;
                this.panOffset.y = scrollRatio * panRange;
                this.savePanOffset();
                this.updateScrollbars();
                this.draw();
                this.updateHud();
            }
        });
        
        hScrollbar.addEventListener('click', (e) => {
            if (e.target === hScrollbar) { // Clicked track, not thumb
                const rect = hScrollbar.getBoundingClientRect();
                const clickX = e.clientX - rect.left;
                const scrollbarWidth = hScrollbar.clientWidth;
                const thumbWidth = hThumb.clientWidth;
                
                // Center thumb at click position
                const newThumbLeft = clickX - thumbWidth / 2;
                const maxScroll = scrollbarWidth - thumbWidth;
                const scrollRatio = (newThumbLeft / maxScroll) * 2 - 1; // -1 to 1
                
                // Use same dynamic range as updateScrollbars
                const baseRange = 2000;
                const zoomFactor = Math.max(1, this.zoom);
                const panRange = baseRange * zoomFactor;
                this.panOffset.x = scrollRatio * panRange;
                this.savePanOffset();
                this.updateScrollbars();
                this.draw();
                this.updateHud();
            }
        });
        
        const handleScrollbarUp = () => {
            this.draggingScrollbar = null;
            this.scrollbarDragStart = null;
        };
        
        document.addEventListener('mouseup', handleScrollbarUp);
        if (window.PointerEvent) {
            document.addEventListener('pointerup', handleScrollbarUp);
        }
    }
    
    updateScrollbars() {
        const vThumb = document.getElementById('vertical-thumb');
        const hThumb = document.getElementById('horizontal-thumb');
        const vScrollbar = document.getElementById('vertical-scrollbar');
        const hScrollbar = document.getElementById('horizontal-scrollbar');
        
        if (!vThumb || !hThumb || !vScrollbar || !hScrollbar) return;
        
        // ENHANCED: Dynamic range based on zoom for better representation
        // At higher zoom, you can pan further, scrollbar should reflect this
        const baseRange = 2000;
        const zoomFactor = Math.max(1, this.zoom); // Scale range with zoom
        const panRange = baseRange * zoomFactor;
        
        // Vertical scrollbar - smooth position calculation
        const vMax = vScrollbar.clientHeight - vThumb.clientHeight;
        const vRatio = Math.max(-1, Math.min(1, this.panOffset.y / panRange));
        const vPos = (vRatio + 1) / 2 * vMax;
        const vPosClamped = Math.max(0, Math.min(vMax, vPos));
        
        // SMOOTH: Use transform for GPU acceleration instead of top/left
        vThumb.style.transform = `translateY(${vPosClamped}px)`;
        vThumb.style.top = '0';
        
        // Horizontal scrollbar - smooth position calculation
        const hMax = hScrollbar.clientWidth - hThumb.clientWidth;
        const hRatio = Math.max(-1, Math.min(1, this.panOffset.x / panRange));
        const hPos = (hRatio + 1) / 2 * hMax;
        const hPosClamped = Math.max(0, Math.min(hMax, hPos));
        
        // SMOOTH: Use transform for GPU acceleration instead of left
        hThumb.style.transform = `translateX(${hPosClamped}px)`;
        hThumb.style.left = '0';
        
        // Update minimap to reflect current viewport
        this.renderMinimap();
    }
    
