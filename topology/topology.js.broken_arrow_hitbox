        // Font button - shows font selection dropdown (keep toolbar open)
        toolbar.appendChild(createButton('text', 'Font', () => {
            this.showTextFontSelector(textObj);
        }, { autoClose: false }));
        
        // Rotation button - HIDE when attached to link (rotation is auto-calculated from link angle)
        if (!textObj.linkId) {
        toolbar.appendChild(createButton('rotate', 'Rotate', () => {
