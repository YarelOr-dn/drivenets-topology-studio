    // Load a DNAAS topology by name
    loadDnaasSavedTopology(name) {
        console.log('loadDnaasSavedTopology called with:', name);
        const storageKey = `topology_dnaas_${name}`;
        
        try {
            const dataStr = localStorage.getItem(storageKey);
            if (!dataStr) {
                this.showNotification(`DNAAS topology "${name}" not found`, 'error');
                return;
            }
            
            const data = JSON.parse(dataStr);
            
            // Clear current state
            this.objects = [];
            this.undoStack = [];
            this.redoStack = [];
            this.selectedObject = null;
            this.selectedObjects = [];
            
            if (data.objects && Array.isArray(data.objects)) {
                this.objects = JSON.parse(JSON.stringify(data.objects));
            }
            
            if (data.metadata) {
                const m = data.metadata;
                this.deviceIdCounter = m.deviceIdCounter || 1;
                this.linkIdCounter = m.linkIdCounter || 1;
                this.textIdCounter = m.textIdCounter || 1;
                this.shapeIdCounter = m.shapeIdCounter || 1;
                if (m.deviceCounters) this.deviceCounters = { ...m.deviceCounters };
                if (m.panOffset) this.panOffset = { ...m.panOffset };
                if (typeof m.zoom === 'number') this.zoom = m.zoom;
            }
            
            localStorage.setItem('topology_current_name', name);
            this.draw();
            this.showNotification(`Loaded DNAAS "${name}"`, 'success');
            
        } catch (error) {
            console.error('Error loading DNAAS topology:', error);
            this.showNotification(`Failed to load: ${error.message}`, 'error');
        }
    }
    
    // Delete a DNAAS topology
    deleteDnaasTopology(name) {
        const storageKey = `topology_dnaas_${name}`;
        localStorage.removeItem(storageKey);
        
        let dnaasList = [];
        try {
            dnaasList = JSON.parse(localStorage.getItem('topology_dnaas_list') || '[]');
        } catch (e) { dnaasList = []; }
        
        dnaasList = dnaasList.filter(n => n !== name);
        localStorage.setItem('topology_dnaas_list', JSON.stringify(dnaasList));
        
        const timestamps = JSON.parse(localStorage.getItem('topology_timestamps') || '{}');
        delete timestamps[`dnaas_${name}`];
        localStorage.setItem('topology_timestamps', JSON.stringify(timestamps));
        
        this.showNotification(`Deleted DNAAS "${name}"`, 'success');
    }
    
    // Load a saved topology by name
    loadSavedTopology(name) {
        console.log('loadSavedTopology called with:', name);
        
        if (!name) {
            console.error('No topology name provided');
            this.showNotification('No topology name provided', 'error');
            return;
        }
        
        const storageKey = `topology_saved_${name}`;
        console.log('Looking for storage key:', storageKey);
        
        try {
            const dataStr = localStorage.getItem(storageKey);
            console.log('Data found:', dataStr ? 'yes (' + dataStr.length + ' chars)' : 'no');
            
            if (!dataStr) {
                this.showNotification(`Topology "${name}" not found in storage`, 'error');
                return;
            }
            
            // Auto-save current before switching
            const currentName = localStorage.getItem('topology_current_name');
            if (currentName && currentName !== name && this.objects.length > 0) {
                console.log('Auto-saving current topology:', currentName);
                this.saveWithName(currentName);
            }
            
            const data = JSON.parse(dataStr);
            console.log('Parsed data:', {
                version: data.version,
                name: data.name,
                objectCount: data.objects ? data.objects.length : 0,
                hasMetadata: !!data.metadata
            });
            
            // Clear current state
            this.objects = [];
            this.undoStack = [];
            this.redoStack = [];
            this.selectedObject = null;
            this.selectedObjects = [];
            
            // Load objects - deep copy to avoid reference issues
            if (data.objects && Array.isArray(data.objects)) {
                this.objects = JSON.parse(JSON.stringify(data.objects));
                console.log('Loaded', this.objects.length, 'objects');
            }
            
            // Load metadata
            if (data.metadata) {
                const m = data.metadata;
                this.deviceIdCounter = m.deviceIdCounter || 1;
                this.linkIdCounter = m.linkIdCounter || 1;
                this.textIdCounter = m.textIdCounter || 1;
                this.shapeIdCounter = m.shapeIdCounter || 1;
                if (m.deviceCounters) this.deviceCounters = { ...m.deviceCounters };
                if (m.panOffset) this.panOffset = { ...m.panOffset };
                if (typeof m.zoom === 'number') this.zoom = m.zoom;
            }
            
            localStorage.setItem('topology_current_name', name);
            
            // Force a full re-render
            this.draw();
            
            this.showNotification(`Loaded "${name}" (${this.objects.length} objects)`, 'success');
            console.log('Topology loaded successfully');
            
        } catch (error) {
            console.error('Error loading topology:', error);
            console.error('Error stack:', error.stack);
            this.showNotification(`Failed to load: ${error.message}`, 'error');
        }
    }
    
