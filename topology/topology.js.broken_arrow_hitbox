        this.livePreviewBgColor = (e) => {
            if (this.editingText) {
                this.editingText.backgroundColor = e.target.value;
                this.addRecentColor(e.target.value);
                this.draw();
            }
        };
        
        textContent.addEventListener('input', this.livePreviewText);
