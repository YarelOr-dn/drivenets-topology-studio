            content.appendChild(createActionBtn('edit', 'Curve: Manual', () => {
                links.forEach(l => {
                    l.curveMode = 'manual';
                    l.curveOverride = true;
                });
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Curve mode set to Manual for ${links.length} links`, 'success');
            }));
            content.appendChild(createActionBtn('minus', 'Curve: Off', () => {
                links.forEach(l => {
                    l.curveMode = 'off';
                    l.curveOverride = true;
                    delete l.manualCurvePoint;
                    delete l.keepCurve;
                });
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Curve mode set to Off for ${links.length} links`, 'success');
            }));
