        const isFaceUser = textObj.alwaysFaceUser === true;
        const faceUserIcon = isFaceUser ? 'eye' : 'rotate';
        const faceUserTitle = isFaceUser ? 'Face User ON → Click for Link Rotation' : 'Link Rotation → Click for Face User';
        toolbar.appendChild(createButton(faceUserIcon, faceUserTitle, () => {
            // Simple two-state toggle: true ↔ false (no undefined state)
            if (textObj.alwaysFaceUser === true) {
                textObj.alwaysFaceUser = false;
                this.showToast('Text follows link rotation', 'info');
            } else {
                textObj.alwaysFaceUser = true;
                this.showToast('Text always faces user (0°)', 'info');
            }
            this.saveState();
            this.draw();
            setTimeout(() => this.showTextSelectionToolbar(textObj), 50);
        }));
        
        toolbar.appendChild(createSeparator());
        
        // Delete button
        toolbar.appendChild(createButton('trash', 'Delete', () => {
            this.hideTextSelectionToolbar();
            const index = this.objects.indexOf(textObj);
            if (index > -1) {
                this.saveState();
                this.objects.splice(index, 1);
                this.selectedObject = null;
                this.selectedObjects = [];
                this.draw();
            }
        }, { isDestructive: true }));
        
        // Prevent clicks from propagating to canvas
        toolbar.addEventListener('mousedown', (e) => {
            e.stopPropagation();
            e.preventDefault();
        });
        toolbar.addEventListener('click', (e) => {
            e.stopPropagation();
            e.preventDefault();
        });
        
        document.body.appendChild(toolbar);
        
        // Store references
        this._textSelectionToolbar = toolbar;
        this._textSelectionToolbarTarget = textObj;
        
        // Adjust position if off-screen
        setTimeout(() => {
            const toolbarRect = toolbar.getBoundingClientRect();
            if (toolbarRect.right > window.innerWidth - 10) {
                toolbar.style.left = `${window.innerWidth - toolbarRect.width / 2 - 10}px`;
            }
            if (toolbarRect.left < 10) {
                toolbar.style.left = `${toolbarRect.width / 2 + 10}px`;
            }
            if (toolbarRect.bottom > window.innerHeight - 10) {
                // Position ABOVE the text box instead
                const topY = centerScreenY + (minY * this.zoom) - 15;
                toolbar.style.top = `${topY - toolbarRect.height}px`;
            }
        }, 0);
    }
    
    hideTextSelectionToolbar() {
        if (this._textSelectionToolbar) {
            this._textSelectionToolbar.remove();
            this._textSelectionToolbar = null;
            this._textSelectionToolbarTarget = null;
        }
        // Also remove the active tooltip if present
        const tooltip = document.getElementById('tb-active-tooltip');
        if (tooltip) tooltip.remove();
