    loadTopology(event) {
        const file = event.target.files[0];
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = (e) => {
            try {
                const data = JSON.parse(e.target.result);
                
                // Store the topology name from file or derive from filename
                const topologyName = data.name || file.name.replace(/\.json$/i, '').replace(/_\d{4}-\d{2}-\d{2}$/, '');
                localStorage.setItem('topology_current_name', topologyName);
                
                this.objects = data.objects || [];
                
                // Add missing properties for compatibility with old saves
                this.objects.forEach((obj, index) => {
                    if (obj.type === 'device') {
                        // Ensure device has a label
                        if (!obj.label) {
                            obj.label = obj.deviceType === 'router' ? 'NCP' : 'S';
                        }
