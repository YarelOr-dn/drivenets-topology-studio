    // ===== Minimap for Navigation =====
    setupMinimap() {
        const minimapContainer = document.getElementById('minimap-container');
        const minimapCanvas = document.getElementById('minimap-canvas');
        const toggleBtn = document.getElementById('btn-toggle-minimap');
        
        if (!minimapContainer || !minimapCanvas) {
            console.warn('Minimap elements not found, skipping setup');
            return;
        }
        
        this.minimap = {
            container: minimapContainer,
            canvas: minimapCanvas,
            ctx: minimapCanvas.getContext('2d'),
            isDragging: false,
            visible: true,
            // Smooth dragging state
            targetPan: null,
            animationId: null,
            lastMoveTime: 0
        };
        
        // Load saved visibility preference
        const savedMinimapVisible = localStorage.getItem('minimapVisible');
        if (savedMinimapVisible === 'false') {
            this.minimap.visible = false;
            minimapContainer.style.display = 'none';
            if (toggleBtn) toggleBtn.classList.remove('minimap-on');
        }
        
        // Toggle button handler
        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                this.toggleMinimap();
            });
        }
        
        // Mousedown on minimap - start dragging
        minimapContainer.addEventListener('mousedown', (e) => {
            if (e.target === minimapCanvas || e.target === minimapContainer) {
                e.preventDefault();
                this.minimap.isDragging = true;
                this.minimap.lastMoveTime = performance.now();
                // Cancel any existing animation
                if (this.minimap.animationId) {
                    cancelAnimationFrame(this.minimap.animationId);
                    this.minimap.animationId = null;
                }
                // Navigate immediately (instant for first click)
                this.navigateFromMinimapDrag(e);
                // Start smooth tracking loop
                this.startMinimapDragLoop();
            }
        });
        
        // Track mouse movement while dragging (on document for smooth dragging even when cursor leaves)
        const handleMouseMove = (e) => {
            if (this.minimap && this.minimap.isDragging) {
                e.preventDefault();
                this.updateMinimapDragTarget(e);
            }
        };
        
        const handleMouseUp = (e) => {
            if (this.minimap && this.minimap.isDragging) {
                this.minimap.isDragging = false;
                this.stopMinimapDragLoop();
                this.savePanOffset();
            }
        };
        
        // Use document-level events for smooth dragging that continues outside minimap
        document.addEventListener('mousemove', handleMouseMove, { passive: false });
        document.addEventListener('mouseup', handleMouseUp);
        
        // Also handle local events for better responsiveness
        minimapContainer.addEventListener('mousemove', (e) => {
            if (this.minimap.isDragging) {
                e.preventDefault();
                this.updateMinimapDragTarget(e);
            }
        }, { passive: false });
        
        // Initial render
        setTimeout(() => this.renderMinimap(), 100);
    }
    
    // Start the smooth drag animation loop
    startMinimapDragLoop() {
        if (this.minimap.animationId) return;
        
        const loop = () => {
            if (!this.minimap.isDragging) return;
            
            if (this.minimap.targetPan) {
                // Smooth interpolation towards target (lerp factor for smooth follow)
                const lerpFactor = 0.35; // Higher = faster response (0.1-0.5 range works well)
                const dx = this.minimap.targetPan.x - this.panOffset.x;
                const dy = this.minimap.targetPan.y - this.panOffset.y;
                
                // Only update if there's meaningful movement
                if (Math.abs(dx) > 0.1 || Math.abs(dy) > 0.1) {
                    this.panOffset.x += dx * lerpFactor;
                    this.panOffset.y += dy * lerpFactor;
                    this.draw();
                    this.renderMinimap();
                    this.updateHud();
                    this.updateScrollbars();
                }
            }
            
            this.minimap.animationId = requestAnimationFrame(loop);
        };
        
        this.minimap.animationId = requestAnimationFrame(loop);
    }
    
    // Stop the drag animation loop
    stopMinimapDragLoop() {
        if (this.minimap.animationId) {
            cancelAnimationFrame(this.minimap.animationId);
            this.minimap.animationId = null;
        }
        this.minimap.targetPan = null;
    }
    
    // Update target pan position during drag (called on mousemove)
    updateMinimapDragTarget(e) {
        if (!this.minimap || !this.minimap.isDragging) return;
        
        const rect = this.minimap.canvas.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const clickY = e.clientY - rect.top;
        
        const bounds = this.getMinimapBounds();
        if (!bounds || bounds.scale <= 0) return;
        
        // Convert mouse position to world coordinates
        const worldX = bounds.minX + (clickX - bounds.offsetX) / bounds.scale;
        const worldY = bounds.minY + (clickY - bounds.offsetY) / bounds.scale;
        
        // Calculate target pan to center on this point
        this.minimap.targetPan = {
            x: this.canvas.width / 2 - worldX * this.zoom,
            y: this.canvas.height / 2 - worldY * this.zoom
        };
    }
    
    // Immediate navigation for initial click (no animation delay)
    navigateFromMinimapDrag(e) {
        if (!this.minimap) return;
        
        const rect = this.minimap.canvas.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const clickY = e.clientY - rect.top;
        
        const bounds = this.getMinimapBounds();
        if (!bounds || bounds.scale <= 0) return;
        
        // Convert click to world coordinates
        const worldX = bounds.minX + (clickX - bounds.offsetX) / bounds.scale;
        const worldY = bounds.minY + (clickY - bounds.offsetY) / bounds.scale;
        
        // Set target for smooth follow
        this.minimap.targetPan = {
            x: this.canvas.width / 2 - worldX * this.zoom,
            y: this.canvas.height / 2 - worldY * this.zoom
        };
        
        // Immediately move most of the way for instant feedback
        const instantFactor = 0.7;
        this.panOffset.x += (this.minimap.targetPan.x - this.panOffset.x) * instantFactor;
        this.panOffset.y += (this.minimap.targetPan.y - this.panOffset.y) * instantFactor;
        
        this.draw();
        this.renderMinimap();
        this.updateHud();
        this.updateScrollbars();
    }
    
    toggleMinimap() {
        if (!this.minimap) return;
        
        this.minimap.visible = !this.minimap.visible;
        const toggleBtn = document.getElementById('btn-toggle-minimap');
        
        if (this.minimap.visible) {
            this.minimap.container.style.display = 'block';
            if (toggleBtn) toggleBtn.classList.add('minimap-on');
            this.renderMinimap();
        } else {
            this.minimap.container.style.display = 'none';
            if (toggleBtn) toggleBtn.classList.remove('minimap-on');
        }
        
        // Save preference
        localStorage.setItem('minimapVisible', this.minimap.visible);
    }
    
    // Get the combined bounds for minimap (topology + viewport)
    getMinimapBounds() {
        const canvasWidth = 172;
        const canvasHeight = 93;
        
        // Calculate current viewport in world coordinates
        const viewLeft = (0 - this.panOffset.x) / this.zoom;
        const viewTop = (0 - this.panOffset.y) / this.zoom;
        const viewRight = (this.canvas.width - this.panOffset.x) / this.zoom;
        const viewBottom = (this.canvas.height - this.panOffset.y) / this.zoom;
        
        // Get topology bounds
        const topologyBounds = this.getTopologyBounds();
        
        let minX, maxX, minY, maxY;
        
        if (topologyBounds) {
            // Combine topology bounds with viewport bounds
            minX = Math.min(topologyBounds.minX, viewLeft);
            maxX = Math.max(topologyBounds.maxX, viewRight);
            minY = Math.min(topologyBounds.minY, viewTop);
            maxY = Math.max(topologyBounds.maxY, viewBottom);
        } else {
            // No objects - just show viewport area
            minX = viewLeft;
            maxX = viewRight;
            minY = viewTop;
            maxY = viewBottom;
        }
        
        // Add small padding
        const padding = 50;
        minX -= padding;
        maxX += padding;
        minY -= padding;
        maxY += padding;
        
        const boundsWidth = maxX - minX;
        const boundsHeight = maxY - minY;
        
        // Calculate scale to fit
        const scaleX = canvasWidth / boundsWidth;
        const scaleY = canvasHeight / boundsHeight;
        const scale = Math.min(scaleX, scaleY);
        
        // Offset to center
        const offsetX = (canvasWidth - boundsWidth * scale) / 2;
        const offsetY = (canvasHeight - boundsHeight * scale) / 2;
        
        return {
            minX, maxX, minY, maxY,
            boundsWidth, boundsHeight,
            scale, offsetX, offsetY,
            canvasWidth, canvasHeight,
            viewLeft, viewTop, viewRight, viewBottom
        };
    }
    
