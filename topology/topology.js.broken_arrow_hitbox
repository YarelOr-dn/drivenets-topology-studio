    setupFileMenu() {
        const fileBtn = document.getElementById('btn-file-menu');
        const fileMenu = document.getElementById('file-dropdown-menu');
        const fileInput = document.getElementById('file-input');
        
        if (!fileBtn || !fileMenu) {
            console.warn('File menu elements not found');
            return;
        }
        
        // Use style.display for consistent behavior
        const closeMenu = () => {
            fileMenu.style.display = 'none';
            // Also close topologies submenu if open
            const topoSubmenu = document.getElementById('topologies-submenu');
            if (topoSubmenu) topoSubmenu.remove();
        };
        
        const openMenu = () => {
            const btnRect = fileBtn.getBoundingClientRect();
            fileMenu.style.left = (btnRect.left + btnRect.width/2 - 110) + 'px';
            fileMenu.style.display = 'block';
        };
        
        const isMenuOpen = () => fileMenu.style.display === 'block';
        
        // Toggle menu on button click - This is the primary handler (fallback for inline onclick)
        // Remove any existing listener first to avoid duplicates
        fileBtn._fileMenuHandler = fileBtn._fileMenuHandler || ((e) => {
            e.preventDefault();
            e.stopPropagation();
            if (isMenuOpen()) {
                closeMenu();
            } else {
                openMenu();
            }
        });
        fileBtn.removeEventListener('click', fileBtn._fileMenuHandler);
        fileBtn.addEventListener('click', fileBtn._fileMenuHandler);
        
        // Prevent menu from closing when clicking inside it
        fileMenu.addEventListener('click', (e) => {
            e.stopPropagation();
        });
        
        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
            if (isMenuOpen() && !fileBtn.contains(e.target) && !fileMenu.contains(e.target)) {
                // Check if clicking topologies submenu
                const topoSubmenu = document.getElementById('topologies-submenu');
                if (topoSubmenu && topoSubmenu.contains(e.target)) return;
                closeMenu();
            }
        });
        
        // Close menu on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && isMenuOpen()) {
                closeMenu();
            }
        });
        
        // Menu item handlers are now inline onclick in HTML (liquid-menu-item buttons)
        // The onclick handlers directly call window.topologyEditor methods
        
        // Ctrl+S keyboard shortcut
        document.addEventListener('keydown', (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                this.quickSaveTopology();
            }
        });
        
        console.log('File menu initialized');
    }
    
