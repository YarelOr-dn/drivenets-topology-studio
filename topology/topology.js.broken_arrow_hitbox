    // Load predefined DNAAS topologies
    loadDnaasTopology(topologyType) {
        let topologyData = null;
        
        switch(topologyType) {
            case 'logical-bd210':
                topologyData = this.getDnaasLogicalBD210Topology();
                break;
            case 'bd210':
                topologyData = this.getDnaasBD210Topology();
                break;
            case 'discover':
                this.showInfoDialog('Live Network Discovery', 
                    'This feature will connect to network devices and\n' +
                    'discover the topology automatically.\n\n' +
                    'Coming soon!\n\n' +
                    'For now, use "Trace Path by Serial Number" to\n' +
                    'run the discovery script manually.');
                return;
            default:
                console.warn('Unknown DNAAS topology type:', topologyType);
                return;
        }
        
        if (topologyData) {
            // Confirm before replacing current canvas
            if (this.objects.length > 0) {
                if (!confirm('This will replace the current canvas. Continue?')) {
                    return;
                }
            }
            
            this.saveState();
            this.objects = topologyData.objects || [];
            this.deviceIdCounter = topologyData.metadata?.deviceIdCounter || 0;
            this.linkIdCounter = topologyData.metadata?.linkIdCounter || 0;
            this.textIdCounter = topologyData.metadata?.textIdCounter || 0;
            
            this.selectedObject = null;
            this.selectedObjects = [];
            
            // Reset zoom and pan to center the loaded topology
            this.zoom = 1;
            
            // Calculate center of all devices
            const devices = this.objects.filter(o => o.type === 'device');
            if (devices.length > 0) {
                const centerX = devices.reduce((sum, d) => sum + d.x, 0) / devices.length;
                const centerY = devices.reduce((sum, d) => sum + d.y, 0) / devices.length;
                // Pan so center of devices is at center of canvas
                this.panOffset = {
                    x: (this.canvas.width / 2) - centerX,
                    y: (this.canvas.height / 2) - centerY
                };
            } else {
                this.panOffset = { x: 0, y: 0 };
            }
            
            // Save pan/zoom to localStorage
            localStorage.setItem('topology_zoom', this.zoom.toString());
            localStorage.setItem('topology_panOffset', JSON.stringify(this.panOffset));
            
            this.updatePropertiesPanel();
            this.updateZoomIndicator();
            this.draw();
            
            console.log(`📡 DNAAS topology loaded: ${topologyType}`, {
                objects: this.objects.length,
                devices: devices.length,
                panOffset: this.panOffset
            });
            
            if (this.debugger) {
                this.debugger.logSuccess(`📡 DNAAS topology loaded: ${topologyType} (${this.objects.length} objects)`);
            }
        }
    }
    
