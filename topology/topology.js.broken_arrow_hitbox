    handleMouseDown(e) {
        // CRITICAL FIX: Prevent duplicate event processing from pointer+mouse events
        // Both pointerdown and mousedown fire for the same physical click, causing
        // double-tap detection to trigger on a single click!
        // Use event.timeStamp (not Date.now()) because it represents when the event was 
        // generated by the browser, not when our handler runs. This avoids issues with
        // slow JS execution (e.g., forced reflows) causing the threshold to be exceeded.
        // CRITICAL FIX (Dec 2025): Prevent duplicate event processing from pointer+mouse events
        // Both pointerdown and mousedown fire for the same physical click. Using event.timeStamp
        // (not Date.now()) because it represents when the event was generated by the browser,
        // avoiding issues with slow JS execution causing the threshold to be exceeded.
        const eventTime = e.timeStamp;
        if (this._lastMouseDownEventTime && (eventTime - this._lastMouseDownEventTime) < 30) {
            return; // Skip duplicate event within 30ms of same physical click
        }
        this._lastMouseDownEventTime = eventTime;
        
        // ENHANCED: Log with input device type differentiation
        // FIXED: Prevent duplicate logging when both pointer and mouse events fire
        if (this.debugger && !this._skipMouseLog) {
            // Reduced logging: Don't log every click (too verbose)
            // Uncomment if debugging click detection:
            // const inputSource = this._lastInputType || 'mouse';
            // const icon = inputSource === 'trackpad' ? '🖐️' : '🖱️';
            // this.debugger.logAction(`${icon} Click: button=${e.button}`);
        }
        
        // Clear the skip flag for next event
        this._skipMouseLog = false;
        
        // Hide context menu on any click
        this.hideContextMenu();
        
        // CRITICAL: Don't process canvas clicks while TB (text editor) modal is open
        // This prevents the modal from closing when user clicks on the grid/canvas
        const textEditorModal = document.getElementById('text-editor-modal');
        if (textEditorModal && textEditorModal.classList.contains('show')) {
            return; // Don't process canvas clicks while TB modal is open
        }
        
        // Also check link-details-modal (Link Table)
        const linkDetailsModal = document.getElementById('link-details-modal');
        if (linkDetailsModal && linkDetailsModal.classList.contains('show')) {
            return; // Don't process canvas clicks while Link Table modal is open
        }
        
        // Hide inline text editor if clicking outside it
        // (Note: inline editor has its own click-outside handler, but this is a backup)
        
        const pos = this.getMousePos(e);
        
        // PASTE STYLE MODE: Handle clicks to paste style
        if (this.pasteStyleMode && e.button === 0) {
            const targetObj = this.findObjectAt(pos.x, pos.y);
            if (targetObj) {
                const success = this.pasteStyleToObject(targetObj);
                
                // If Shift is held, stay in paste mode for continuous pasting
                // Otherwise, exit to base mode after single paste
                if (!this.shiftPressed) {
                    this.exitPasteStyleMode();
                }
                return; // Don't process as normal click
            } else {
                // Clicked on empty space - START CS-MS marquee selection mode!
                // This allows user to select multiple objects to paste style to
                this.startCSMSMode(pos);
                return; // Let mousemove handler take over for marquee drag
            }
        }
        
        // MANUAL CURVE: Check for curve handle click
        // FIX: TB (text box) ALWAYS wins when clicked on visible TB area
        // CP only activates when clicking OUTSIDE the TB bounds
        // CRITICAL FIX: Recalculate curve handle at click position (don't rely on stale mousemove cache)
        const curveHandleAtClick = this.findCurveHandleAt(pos.x, pos.y);
        if (e.button === 0 && curveHandleAtClick && curveHandleAtClick.isOnCP) {
            // Update hover state to match click detection
            this.hoveredLinkMidpoint = curveHandleAtClick;
            
            // Check if there's a text box at this position
            const textAtPos = this.findTextAt(pos.x, pos.y);
            
            // TB vs CP priority - TB ALWAYS wins if clicked on its visible area
            let tbHasPriority = false;
            
            if (textAtPos) {
                // Calculate full visual bounds (text + background padding)
                this.ctx.save();
                const fontFamily = textAtPos.fontFamily || 'Arial';
                const fontWeight = textAtPos.fontWeight || 'normal';
                this.ctx.font = `${fontWeight} ${textAtPos.fontSize}px ${fontFamily}`;
                const metrics = this.ctx.measureText(textAtPos.text || 'Text');
                const textW = metrics.width;
                const textH = parseInt(textAtPos.fontSize) || 14;
                this.ctx.restore();
                
                // Transform click point to text's local space
                const dx = pos.x - textAtPos.x;
                const dy = pos.y - textAtPos.y;
                const angle = -(textAtPos.rotation || 0) * Math.PI / 180;
                const localX = dx * Math.cos(angle) - dy * Math.sin(angle);
                const localY = dx * Math.sin(angle) + dy * Math.cos(angle);
                
                // FIX: Use FULL visible bounds - text + background padding
                // If TB has a background, use its padding; otherwise use reasonable margin
                const hasBackground = textAtPos.showBackground !== false;
                const bgPadding = hasBackground ? (textAtPos.backgroundPadding || 8) : 6;
                // Add extra click tolerance (6px) for better UX
                const clickPadding = bgPadding + 6;
                
                const isOnTextArea = Math.abs(localX) <= (textW/2 + clickPadding) && 
                                     Math.abs(localY) <= (textH/2 + clickPadding);
                
                // TB WINS if click is within its visible area
                if (isOnTextArea) {
                    tbHasPriority = true;
                    if (this.debugger) {
                        this.debugger.logInfo(`Click on TB visible area - TB has priority over CP`);
                    }
                }
            }
            
            if (!tbHasPriority) {
                // CP clicked - record for potential drag, but DON'T intercept click
                // The link will be selected normally below (like clicking on link body)
                // Only start curve drag if mouse actually moves
                this._potentialCPDrag = {
                    link: this.hoveredLinkMidpoint.link,
                    startX: pos.x,
                    startY: pos.y,
                    initialPoint: this.hoveredLinkMidpoint.link.manualControlPoint 
                        ? { ...this.hoveredLinkMidpoint.link.manualControlPoint }
                        : { ...this.hoveredLinkMidpoint.midpoint },
                    midpoint: { ...this.hoveredLinkMidpoint.midpoint }
                };
                
                if (this.debugger) {
                    this.debugger.logInfo(`CP mousedown: ${this.hoveredLinkMidpoint.link.id} - will drag if moved`);
                }
                // DON'T return - let normal link click handling happen below
            }
            // If tbHasPriority, fall through to normal click handling (text selection)
        }
        
        // CRITICAL: Check for double-tap BEFORE any other logic (handles slight movement)
        // This prevents background click detection when double-tapping with slight movement
        // Note: If first tap was a long press, tap tracking is already cleared in mouseup
        if (this._lastTapDevice && this._lastTapPos) {
            const now = Date.now();
            const timeSinceLastTap = now - this.lastTapTime;
            const clickedObject = this.findObjectAt(pos.x, pos.y);
            
            // CRITICAL FIX: Prevent accidental LINK mode entry after dragging
            // Only block double-tap detection for 200ms after drag ends
            const timeSinceDragEnd = now - (this._lastDragEndTime || 0);
            if (timeSinceDragEnd < 200) {
                // Drag just ended - clear tap tracking and skip double-tap detection entirely
                this.lastTapTime = 0;
                this._lastTapDevice = null;
                this._lastTapPos = null;
                this._lastTapStartTime = 0;
                // Don't continue with double-tap detection - exit this block
            }
            
            // Only proceed with double-tap check if tap tracking wasn't just cleared
            // Check if this is a double-tap on the same device (or near it)
            const isSameDevice = this._lastTapDevice && clickedObject && clickedObject === this._lastTapDevice;
            const isNearLastTap = this._lastTapPos && 
                Math.sqrt(Math.pow(pos.x - this._lastTapPos.x, 2) + Math.pow(pos.y - this._lastTapPos.y, 2)) <= this.doubleTapTolerance;
            
            // If it's a quick second tap on the same device OR near the first tap position, enter link mode
            // Note: Long presses are already filtered out in mouseup, so we only get here for quick taps
            if (this._lastTapDevice && timeSinceLastTap < this.doubleTapDelay && (isSameDevice || isNearLastTap)) {
                // Cancel any device placement
                if (this.placingDevice) {
                    this.placingDevice = null;
                }
                
                // Enter link mode with the device from first tap
                this.setMode('link');
                this.linking = true;
                this.linkStart = this._lastTapDevice;
                
                // CRITICAL: Clear ALL conflicting state flags to ensure link preview is drawn
                this.dragging = false;
                this._pendingDrag = null;
                this.panning = false;
                this.marqueeActive = false;
                this.selectionRectStart = null;
                this.selectionRectangle = null;
                this.rotatingDevice = null;
                this.resizingDevice = null;
                this.stretchingLink = null;
                this.stretchingEndpoint = null;
                this.selectedObject = null;
                this.selectedObjects = [];
                
                if (this.debugger) {
                    const gridPos = this.worldToGrid({ x: this._lastTapDevice.x, y: this._lastTapDevice.y });
                    this.debugger.logSuccess(`👆👆 Double-tap detected: LINK mode from ${this._lastTapDevice.label || 'Device'}`);
                    this.debugger.logInfo(`Device: ${this._lastTapDevice.label} at Grid(${Math.round(gridPos.x)}, ${Math.round(gridPos.y)})`);
                    this.debugger.logInfo(`Time between taps: ${timeSinceLastTap}ms`);
                    if (!isSameDevice && isNearLastTap) {
                        const dist = Math.sqrt(Math.pow(pos.x - this._lastTapPos.x, 2) + Math.pow(pos.y - this._lastTapPos.y, 2));
                        this.debugger.logInfo(`Movement detected: ${dist.toFixed(1)}px (within ${this.doubleTapTolerance}px tolerance)`);
                    }
                }
                
                this.lastTapTime = 0; // Reset
                this._lastTapDevice = null;
                this._lastTapPos = null;
                this._lastTapStartTime = 0; // Reset
                this.draw();
                return;
            }
        }
        
        // Track background clicks for fast double-click UL placement
        const clickedObj = this.findObjectAt(pos.x, pos.y);
        if (!clickedObj) {
            // Clicked on background - track timing
            const now = Date.now();
            const timeSinceLastClick = now - this.lastBackgroundClickTime;
            this.lastBackgroundClickTime = now;
            
            // Reduced logging: Don't log every background click
            // Uncomment if debugging double-click UL creation:
            // if (this.debugger && timeSinceLastClick < this.fastDoubleClickDelay && timeSinceLastClick > 0) {
            //     this.debugger.logInfo(`Background click #2: ${timeSinceLastClick}ms`);
            // }
        }
        
        // Alt/Option + Click on device → Quick link start (from ANY mode)
        if ((this.altPressed || e.altKey) && e.button === 0) {
            const clickedDevice = this.findObjectAt(pos.x, pos.y);
            if (clickedDevice && clickedDevice.type === 'device') {
                // Cancel any device placement
                if (this.placingDevice) {
                    this.placingDevice = null;
                }
                // Enter link mode with this device as start
                this.setMode('link');
                this.linking = true;
                this.linkStart = clickedDevice;
                
                // CRITICAL: Clear ALL conflicting state flags to ensure link preview is drawn
                this.dragging = false;
                this._pendingDrag = null;
                this.panning = false;
                this.marqueeActive = false;
                this.selectionRectStart = null;
                this.selectionRectangle = null;
                this.rotatingDevice = null;
                this.resizingDevice = null;
                this.stretchingLink = null;
                this.stretchingEndpoint = null;
                this.selectedObject = null;
                this.selectedObjects = [];
                this.draw();
                return;
            }
        }
        
        // Pan with middle mouse button or space + left click
        if (e.button === 1 || this.spacePressed) {
            this.panning = true;
            this.panStart = {
                x: e.clientX - this.panOffset.x,
                y: e.clientY - this.panOffset.y
            };
            this.canvas.style.cursor = 'move';
            // Close all menus/toolbars when panning starts
            this.hideAllPopups();
            e.preventDefault();
            return;
        }
        
        // Check for link endpoint stretching (unbound links) - check before other object detection
        if (!this.stretchingLink && this.currentTool === 'select') {
            const clickedLink = this.findUnboundLinkEndpoint(pos.x, pos.y);
            if (clickedLink && clickedLink.link.type === 'unbound') {
                // ENHANCED: Don't immediately start stretching - wait for drag threshold
                // This prevents accidental dragging on light taps
                this._pendingStretch = {
                    link: clickedLink.link,
                    endpoint: clickedLink.endpoint,
                    isConnectionPoint: clickedLink.isConnectionPoint || false,
                    startX: pos.x,
                    startY: pos.y,
                    threshold: 5 // Minimum pixels to move before starting stretch
                };
                this.selectedObject = clickedLink.link;
                this.selectedObjects = [clickedLink.link];
                
                if (this.debugger) {
                    const allMergedLinks = this.getAllMergedLinks(clickedLink.link);
                    const ulNumber = allMergedLinks.findIndex(l => l.id === clickedLink.link.id) + 1;
                    const pointType = clickedLink.isConnectionPoint ? '[MP]' : '[TP]';
                    this.debugger.logInfo(`UL Clicked: ${clickedLink.link.id} (U${ulNumber}) at ${clickedLink.endpoint} [${pointType}]`);
                    this.debugger.logInfo(`   Waiting for ${this._pendingStretch.threshold}px drag threshold before stretching...`);
                }
                
                this.draw();
                return;
            }
        }
        
        // Handle device placement mode
        if (this.placingDevice) {
            // Only respond to left-click (button 0); defer placement until mouseup so we can detect drag for MS
            if (e.button === 0) {
                // ENHANCED: Check if clicked on an existing device
                const clickedDevice = this.findObjectAt(pos.x, pos.y);
                if (clickedDevice && clickedDevice.type === 'device') {
                    // Clicked on existing device - select it and exit placement mode
                    this.placingDevice = null;
                    this.placementPending = null;
                    this.selectedObject = clickedDevice;
                    this.selectedObjects = [clickedDevice];
                    this.setMode('select');
                    this.updatePropertiesPanel();
                    this.draw();
                    
                    if (this.debugger) {
                        this.debugger.logInfo(`📍 Clicked on existing device while placing → Selected ${clickedDevice.label || 'Device'}`);
                    }
                    return;
                }
                
                this.placementPending = {
                    type: this.placingDevice,
                    startPos: { x: pos.x, y: pos.y },
                    clickTime: Date.now()
                };
                // Prepare potential marquee selection if user drags
                this.selectionRectStart = { x: pos.x, y: pos.y };
                
                if (this.debugger) {
                    this.debugger.logInfo(`📍 Device placement pending (${this.placingDevice})`);
                }
            }
            // Right-click will be handled by contextmenu event (exits to base mode)
            return;
        }
        
        // Handle shape placement mode
        if (this.placingShape) {
            if (e.button === 0) {
                // Check if clicked on an existing object
                const clickedObject = this.findObjectAt(pos.x, pos.y);
                if (clickedObject) {
                    // Clicked on existing object - select it and exit placement mode
                    this.exitShapePlacementMode();
                    this.selectedObject = clickedObject;
                    this.selectedObjects = [clickedObject];
                    this.setMode('select');
                    this.updatePropertiesPanel();
                    this.draw();
                    return;
                }
                
                // Create the shape at click position
                const shape = this.createShape(pos.x, pos.y, this.placingShape);
                
                // Select the new shape
                this.selectedObject = shape;
                this.selectedObjects = [shape];
                shape._mouseReleasedAfterSelection = true; // Allow immediate resize
                
                // Exit placement mode (single placement, not continuous)
                this.exitShapePlacementMode();
                
                // Show shape toolbar after a brief delay
                setTimeout(() => {
                    if (this.selectedObject === shape) {
                        this.showShapeSelectionToolbar(shape);
                    }
                }, 100);
            } else if (e.button === 2) {
                // Right-click exits placement mode
                this.exitShapePlacementMode();
            }
            return;
        }
        
        // Check for handles ONLY on SELECTED text object
        // CRITICAL: Only allow resize/rotation AFTER text is selected AND mouse is released
        // This prevents accidental resize/rotate when trying to drag unselected text
        let handleFound = false;
        
        // CRITICAL: Skip handle detection if text is being edited (inline editor is open)
        if (this.selectedObject && this.selectedObject.type === 'text' && e.button === 0 &&
            this.selectedObject._mouseReleasedAfterSelection === true &&
            !this.selectedObject._editing) {  // Skip when inline editor is open
            const textObj = this.selectedObject;
            // Temporarily set font to measure text - MUST match drawing font exactly
            this.ctx.save();
            const fontFamily = textObj.fontFamily || 'Arial';
            const fontWeight = textObj.fontWeight || 'normal';
            const fontSize = parseInt(textObj.fontSize) || 14;
            this.ctx.font = `${fontWeight} ${fontSize}px ${fontFamily}`;
            
            // MULTI-LINE SUPPORT: Calculate dimensions based on all lines
            const textContent = textObj.text || 'Text';
            const lines = textContent.split('\n');
            const lineHeight = fontSize * 1.2;
            
            // Calculate max width across all lines
            let textWidth = 0;
            for (const line of lines) {
                const lineWidth = this.ctx.measureText(line || ' ').width;
                textWidth = Math.max(textWidth, lineWidth);
            }
            const textHeight = lines.length * lineHeight;
            this.ctx.restore();
            
            const angle = (textObj.rotation || 0) * Math.PI / 180;
            
            // Define all corner handles (must match drawing offset of 8)
            const handleOffset = 8;
            const corners = [
                { x: -textWidth/2 - handleOffset, y: -textHeight/2 - handleOffset, type: 'resize' },  // Top-left
                { x: textWidth/2 + handleOffset, y: -textHeight/2 - handleOffset, type: 'rotation' },  // Top-right
                { x: textWidth/2 + handleOffset, y: textHeight/2 + handleOffset, type: 'resize' },     // Bottom-right
                { x: -textWidth/2 - handleOffset, y: textHeight/2 + handleOffset, type: 'resize' }     // Bottom-left
            ];
                
                // Check each corner handle with HUGE hitbox
                for (const corner of corners) {
                    // Transform corner to world coordinates (accounting for text rotation)
                    const rotatedX = corner.x * Math.cos(angle) - corner.y * Math.sin(angle);
                    const rotatedY = corner.x * Math.sin(angle) + corner.y * Math.cos(angle);
                    const handleWorldX = textObj.x + rotatedX;
                    const handleWorldY = textObj.y + rotatedY;
                    
                    const dx = pos.x - handleWorldX;
                    const dy = pos.y - handleWorldY;
                    const dist = Math.sqrt(dx * dx + dy * dy);
            
                    // Balanced hitbox: 22px radius - easy to click, matches cursor detection
                    const hitboxSize = 22 / this.zoom;
                    if (dist < hitboxSize) {
                        this.selectedObject = textObj;
                        this.selectedObjects = [textObj];
                        
                    if (corner.type === 'rotation') {
                // Start text rotation
                        this.saveState(); // Make text rotation undoable
                this.rotatingText = true;
                        const mouseAngle = Math.atan2(pos.y - textObj.y, pos.x - textObj.x);
                this.textRotationStartAngle = mouseAngle;
                        this.textRotationStartRot = textObj.rotation;
                        // Hide toolbar during rotation for cleaner UX
                        this.hideTextSelectionToolbar();
                    } else {
                        // Start text resize - drag away from center = bigger, toward center = smaller
                        this.saveState(); // Make text resize undoable
                        this.resizingText = true;
                        this.textResizeStartSize = textObj.fontSize;
                        this.textResizeStartDist = Math.sqrt(
                            Math.pow(pos.x - textObj.x, 2) + 
                            Math.pow(pos.y - textObj.y, 2)
                        );
                        // Hide toolbar during resize for cleaner UX
                        this.hideTextSelectionToolbar();
                    }
                        handleFound = true;
                e.preventDefault();
                return;
                    }
            }
        }
        
        // Find clicked object if we didn't click text handles
        let clickedObject = null;
        if (!this.rotatingText && !this.resizingText) {
            clickedObject = this.findObjectAt(pos.x, pos.y);
        }
        
        // Check for Terminal button click (opens SSH to device)
        if (clickedObject && clickedObject.type === 'device' && 
            this.selectedObject === clickedObject && 
            e.button === 0 &&
            this.findTerminalButton(clickedObject, pos.x, pos.y)) {
            // Open terminal to this device
            this.openTerminalToDevice(clickedObject);
            e.preventDefault();
            return;
        }
        
        // Check for device rotation handle (only on selected devices)
        // CRITICAL: Only allow rotation AFTER device is selected AND mouse is released
        // This prevents race conditions with collision detection and drag offset calculation
        
        // CRITICAL FIX (Dec 2025): Removed currentMode === 'select' check - it was too strict
        // Mode often resets to 'base' but device should still be resizable/rotatable if selected
        if (clickedObject && clickedObject.type === 'device' && 
            this.selectedObject === clickedObject && 
            e.button === 0 &&
            clickedObject._mouseReleasedAfterSelection === true) { // Must release mouse after selection first
            const isOnRotationHandle = this.findRotationHandle(clickedObject, pos.x, pos.y);
            const isOnResizeHandle = this.findResizeHandle(clickedObject, pos.x, pos.y);
            
            if (isOnRotationHandle) {
                // Start device rotation
                this.saveState();
                this.rotatingDevice = clickedObject;
                this.rotationStartAngle = Math.atan2(pos.y - clickedObject.y, pos.x - clickedObject.x);
                this.rotationStartValue = clickedObject.rotation || 0;
                this.dragging = false; // Ensure dragging is false for rotation
                
                // Stop momentum if active
                if (this.momentum) {
                    if (this.momentum.activeSlides.has(clickedObject.id)) {
                        this.momentum.activeSlides.delete(clickedObject.id);
                    }
                    this.momentum.reset();
                }
                
                if (this.debugger) {
                    this.debugger.logSuccess(`Device rotation started: ${clickedObject.label || 'Device'}`);
                    this.debugger.logInfo(`   Rotation enabled after mouse release - prevents race conditions`);
                }
                
                this.draw();
                e.preventDefault();
                return;
            }
            
            // Check for device resize handle
            if (isOnResizeHandle) {
                const resizeHandle = isOnResizeHandle;
                // Start device resizing
                this.saveState();
                this.resizingDevice = clickedObject;
                this.resizeHandle = resizeHandle;
                this.resizeStartRadius = clickedObject.radius;
                this.resizeStartPos = { x: pos.x, y: pos.y };
                this.dragging = false;
                
                // Stop momentum if active
                if (this.momentum) {
                    if (this.momentum.activeSlides.has(clickedObject.id)) {
                        this.momentum.activeSlides.delete(clickedObject.id);
                    }
                    this.momentum.reset();
                }
                
                if (this.debugger) {
                    this.debugger.logSuccess(`Device resize started: ${clickedObject.label || 'Device'} (${resizeHandle})`);
                }
                
                this.draw();
                e.preventDefault();
                return;
            }
        }
        
        // Check for shape resize handles
        // CRITICAL FIX (Jan 2026): Added _mouseReleasedAfterSelection check to match device/text behavior
        if (clickedObject && clickedObject.type === 'shape' && 
            this.selectedObject === clickedObject && e.button === 0 &&
            clickedObject._mouseReleasedAfterSelection === true) {
            const shapeResizeHandle = this.findShapeResizeHandle(clickedObject, pos.x, pos.y);
            if (shapeResizeHandle) {
                this.saveState();
                
                // Check if it's rotation handle
                if (shapeResizeHandle === 'rotation') {
                    this.rotatingShape = clickedObject;
                    this._shapeRotationStart = {
                        x: pos.x,
                        y: pos.y,
                        startAngle: Math.atan2(pos.y - clickedObject.y, pos.x - clickedObject.x),
                        originalRotation: clickedObject.rotation || 0
                    };
                    this.dragging = false;
                    this.hideShapeSelectionToolbar();
                    
                    if (this.debugger) {
                        this.debugger.logSuccess(`Shape rotation started on "${clickedObject.label || clickedObject.shapeType}"`);
                    }
                    
                    this.draw();
                    e.preventDefault();
                    return;
                }
                
                this.resizingShape = clickedObject;
                this.shapeResizeHandle = shapeResizeHandle;
                this._shapeResizeStart = {
                    x: pos.x,
                    y: pos.y,
                    width: clickedObject.width,
                    height: clickedObject.height,
                    centerX: clickedObject.x,  // Store original center for edge resizing
                    centerY: clickedObject.y
                };
                this.dragging = false;
                
                // Hide shape toolbar during resize for clean UX
                this.hideShapeSelectionToolbar();
                
                if (this.debugger) {
                    this.debugger.logSuccess(`Shape resize started: ${shapeResizeHandle} on "${clickedObject.label || clickedObject.shapeType}"`);
                }
                
                this.draw();
                e.preventDefault();
                return;
            }
        }
        
        // Long press detection for multi-select
        // CRITICAL FIX: Skip long press timer if a double-click happened recently (prevents MS after UL)
        const timeSinceDoubleClick = Date.now() - this.lastDoubleClickTime;
        if (timeSinceDoubleClick > 500) { // Only set timer if > 500ms since last double-click
        this.longPressTimer = setTimeout(() => {
                // CS-MS MODE: If in paste style mode, enter special CS-MS marquee mode
                if (this.pasteStyleMode && this.copiedStyle) {
                    this.startCSMSMode(pos);
                } else {
            this.startMultiSelect(pos);
                }
        }, this.longPressDelay);
        }
        
        if (!clickedObject) {
            clickedObject = this.findObjectAt(pos.x, pos.y);
        }
        
        if (this.currentTool === 'select') {
            // Check if there are multiple selected objects OR multiSelectMode is active
            if (this.selectedObjects.length > 1 || this.multiSelectMode) {
                // Multi-select mode from marquee
                if (clickedObject) {
                    if (this.selectedObjects.includes(clickedObject)) {
                        // Clicked on a selected object - drag ALL selected objects
                        // CRITICAL FIX: Stop ALL momentum/slides FIRST before capturing positions!
                        if (this.momentum) {
                            this.momentum.stopAll(); // Stop active slides
                            this.momentum.reset();   // Clear velocity history
                        }
                        
                        this.saveState(); // Save before moving
                        // CRITICAL FIX: Calculate all positions BEFORE setting dragging=true!
