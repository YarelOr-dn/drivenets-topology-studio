    // Detect Model from device name (e.g., DNAAS-LEAF-B10 -> NCM-1600, YOR_PE-1 -> SA-36CD-S)
    // MUST return models that exist in driveNetsPlatforms database!
    detectModelFromDeviceName(deviceName) {
        if (!deviceName) return '';
        
        const nameLower = deviceName.toLowerCase();
        
        // DNAAS fabric devices (LEAF, SPINE, SuperSpine)
        if (nameLower.includes('leaf') || nameLower.includes('spine') || nameLower.includes('superspine')) {
            // Default to NCM-1600 for fabric devices (exists in DNAAS category)
            return 'NCM-1600';
        }
        
        // PE routers / Termination devices - use SA platform models (most common PE platform)
        if (nameLower.includes('pe') || nameLower.includes('yor_') || nameLower.includes('_pe')) {
            // Default to SA-36CD-S for PE devices (NCP3, common PE platform in SA category)
            return 'SA-36CD-S';
        }
        
        // CE / Customer Edge - use SA platform
        if (nameLower.includes('ce')) {
            // Default to SA-40C for CE devices (NCP1, common SA platform)
            return 'SA-40C';
        }
        
        // P routers / Provider core
        if (nameLower.includes('_p-') || nameLower.includes('-p-') || nameLower.match(/\bp\d+\b/)) {
            return 'SA-36CD-S';
        }
        
        return '';
    }
    
