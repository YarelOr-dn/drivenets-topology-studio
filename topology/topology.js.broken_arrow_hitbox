            content.appendChild(createColorRow((color) => {
                devices.forEach(d => d.color = color);
                this.saveState();
                this.draw();
                this.showToast(`Color applied to ${devices.length} devices`, 'success');
            }));
            
            // Lock/Unlock all
            content.appendChild(createActionBtn('lock', 'Lock All', () => {
                devices.forEach(d => d.locked = true);
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Locked ${devices.length} devices`, 'info');
            }));
            content.appendChild(createActionBtn('unlock', 'Unlock All', () => {
                devices.forEach(d => d.locked = false);
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Unlocked ${devices.length} devices`, 'info');
