            content.appendChild(createActionBtn('dotted', 'Style: Dashed', () => {
                links.forEach(l => l.style = 'dashed');
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Style set to dashed for ${links.length} links`, 'success');
            }));
            content.appendChild(createActionBtn('arrow-right', 'Style: Arrow', () => {
                links.forEach(l => l.style = 'arrow');
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Style set to arrow for ${links.length} links`, 'success');
            }));
            
            // Curve mode options
            content.appendChild(createActionBtn('curve', 'Curve: Auto', () => {
                links.forEach(l => {
                    l.curveMode = 'auto';
                    l.curveOverride = true;
                    delete l.manualCurvePoint;
                    delete l.keepCurve;
                });
                this.saveState();
                this.draw();
                this.hideMultiSelectContextMenu();
                this.showToast(`Curve mode set to Auto for ${links.length} links`, 'success');
