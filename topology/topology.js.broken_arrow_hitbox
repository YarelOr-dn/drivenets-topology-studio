    /**
     * Show LLDP progress indicator ON the device itself.
     * Creates an animated ring around the device showing progress.
     * @param {Object} device - The device object from canvas
     * @param {string} message - Status message
     * @param {string} type - 'running', 'success', 'error'
     * @param {number} progress - Progress percentage (0-100)
     */
    _updateDeviceLldpStatus(device, message, type = 'running', progress = 0) {
        if (!device) return;
        
        // Store LLDP status on device for canvas drawing
        device._lldpStatus = {
            type,
            progress,
            message,
            timestamp: Date.now()
        };
        
        // Trigger redraw to show the indicator
        this.draw();
        
        // Start animation loop for running state (spinning indicator)
        if (type === 'running') {
            this._startLldpAnimationLoop();
        } else {
            this._stopLldpAnimationLoop();
        }
        
        // Store last result for button display
        if (type === 'success' || type === 'error') {
            device._lastLldpResult = {
                type,
                timestamp: Date.now(),
                message: message
            };
        }
        
        // Auto-clear success after delay (keep error visible until device is selected)
        if (type === 'success') {
            clearTimeout(device._lldpStatusTimeout);
            device._lldpStatusTimeout = setTimeout(() => {
                delete device._lldpStatus;
                this.draw();
            }, 3000);
        }
        // Error stays visible until device is clicked/selected
    }
    
    /**
     * Start animation loop for LLDP indicator spinning
     */
    _startLldpAnimationLoop() {
        if (this._lldpAnimationId) return; // Already running
        
        const animate = () => {
            // Check if any device has running LLDP status
            const hasRunningLldp = this.devices?.some(d => d._lldpStatus?.type === 'running');
            
            if (hasRunningLldp) {
                this.draw();
                this._lldpAnimationId = requestAnimationFrame(animate);
            } else {
                this._lldpAnimationId = null;
            }
        };
        
        this._lldpAnimationId = requestAnimationFrame(animate);
    }
    
    /**
     * Stop LLDP animation loop
     */
    _stopLldpAnimationLoop() {
        if (this._lldpAnimationId) {
            cancelAnimationFrame(this._lldpAnimationId);
            this._lldpAnimationId = null;
        }
    }
    
    /**
     * Draw LLDP status indicator around a device (called from main draw loop)
     * MINIMAL VERSION: Small badge at bottom-right of device
     * @param {CanvasRenderingContext2D} ctx
     * @param {Object} device
     */
    _drawDeviceLldpIndicator(ctx, device) {
        if (!device._lldpStatus) return;
        
        const status = device._lldpStatus;
        const deviceRadius = device.radius || 30;
        const x = device.x;
        const y = device.y;
        
        ctx.save();
        
        // Color based on status
        let color, bgColor;
        if (status.type === 'success') {
            color = '#27ae60';
            bgColor = 'rgba(39, 174, 96, 0.9)';
        } else if (status.type === 'error') {
            color = '#e74c3c';
            bgColor = 'rgba(231, 76, 60, 0.9)';
        } else {
            color = '#00B4D8';
            bgColor = 'rgba(0, 180, 216, 0.9)';
        }
        
        // MINIMAL: Small badge at bottom-right corner of device
        const badgeRadius = 10;
        const badgeX = x + deviceRadius * 0.7;
        const badgeY = y + deviceRadius * 0.7;
        
        // Badge shadow
        ctx.shadowColor = 'rgba(0, 0, 0, 0.3)';
        ctx.shadowBlur = 4;
        ctx.shadowOffsetY = 2;
        
        // Badge background
        ctx.beginPath();
        ctx.arc(badgeX, badgeY, badgeRadius, 0, Math.PI * 2);
        ctx.fillStyle = bgColor;
        ctx.fill();
        
        // White border
        ctx.shadowColor = 'transparent';
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.8)';
        ctx.lineWidth = 1.5;
        ctx.stroke();
        
        // Icon inside badge
        ctx.fillStyle = 'white';
        ctx.strokeStyle = 'white';
        ctx.lineWidth = 2;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        
        if (status.type === 'success') {
            // Checkmark
            ctx.beginPath();
            ctx.moveTo(badgeX - 4, badgeY);
            ctx.lineTo(badgeX - 1, badgeY + 3);
            ctx.lineTo(badgeX + 5, badgeY - 3);
            ctx.stroke();
        } else if (status.type === 'error') {
            // X mark
            ctx.beginPath();
            ctx.moveTo(badgeX - 3, badgeY - 3);
            ctx.lineTo(badgeX + 3, badgeY + 3);
            ctx.moveTo(badgeX + 3, badgeY - 3);
            ctx.lineTo(badgeX - 3, badgeY + 3);
            ctx.stroke();
        } else {
            // Spinning dots for running state
            const elapsed = Date.now() - status.timestamp;
            const spinAngle = (elapsed / 400) % (Math.PI * 2);
            
            for (let i = 0; i < 3; i++) {
                const angle = spinAngle + (i * Math.PI * 2 / 3);
                const dotX = badgeX + Math.cos(angle) * 4;
                const dotY = badgeY + Math.sin(angle) * 4;
                const opacity = 0.4 + (0.6 * ((i + 1) / 3));
                
                ctx.beginPath();
                ctx.arc(dotX, dotY, 2, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
                ctx.fill();
            }
        }
        
        ctx.restore();
    }
    
    /**
     * Clear LLDP status from a device (but preserve lastLldpResult for button display)
     */
    _clearDeviceLldpStatus(device) {
        if (device) {
            delete device._lldpStatus;
            clearTimeout(device._lldpStatusTimeout);
            this.draw();
        }
    }
    
    /**
     * Clear LLDP error/failed status when device is selected (user acknowledgment)
     */
    _clearLldpErrorOnSelect(device) {
        if (device && device._lldpStatus && device._lldpStatus.type === 'error') {
            delete device._lldpStatus;
