        const wasStretching = this.stretchingLink !== null;
        const stretchedLink = this.stretchingLink; // Store reference before clearing for CP update
        const wasPendingStretch = this._pendingStretch !== null;
        const hadPendingDrag = this._pendingDrag !== null; // Track if we had pending drag
        // Store pending stretch info before clearing (for link from TP feature)
        const pendingStretchInfo = this._pendingStretch ? { ...this._pendingStretch } : null;
        this._pendingStretchInfo = pendingStretchInfo; // Temporarily store for processing below
        this.stretchingLink = null;
        this.stretchingEndpoint = null;
        this.stretchingConnectionPoint = false; // Clear connection point dragging flag
        this._pendingStretch = null; // Clear pending stretch (light tap without drag)
        this._pendingDrag = null; // Clear pending drag (light tap without drag)
        
        // CRITICAL FIX: If we had a pending drag (user clicked on object but released before threshold),
        // clear tap tracking to prevent false double-tap detection
        if (hadPendingDrag) {
            this.lastTapTime = 0;
            this._lastTapDevice = null;
            this._lastTapPos = null;
            this._lastTapStartTime = 0;
        }
        
        // CRITICAL FIX: Also clear pending stretch if we had one (prevents stuck selection)
        if (wasPendingStretch && !wasStretching) {
