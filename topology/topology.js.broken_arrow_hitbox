            const hoverColor = isPillButton 
                ? '#ffffff' // Keep white on hover
                : (isDestructive ? '#ff6b6b' : (isDarkMode ? '#fff' : '#1a1a2e'));
            
            // Base background for pill buttons
            const baseBg = isPillButton ? color : 'transparent';
            
            btn.style.cssText = `
