                        obj.createdAt = Date.now() - (parseInt(obj.id.split('_')[1]) || 0) * 100; // Estimate
                    }
                });
                
                // AUTO-CORRECT CREDENTIALS for loaded devices
                this._correctDeviceCredentials();
                
