    // Get handle positions based on shape type - handles at actual visual boundaries
    getShapeHandlePositions(shape) {
        const x = shape.x;
        const y = shape.y;
        const w = shape.width;
        const h = shape.height;
        // Larger handles like devices (zoom-adjusted sizes will be applied in drawing)
        const handleSize = 14;
        const cornerHandleSize = 16;
        
        // For circles (which can be ovals when stretched), use radii for edge positions
        if (shape.shapeType === 'circle') {
            const rx = w / 2; // X radius
            const ry = h / 2; // Y radius (different from rx when stretched)
            // For corners, use positions at 45° on the ellipse
            const cornerAngle = Math.PI / 4;
            const cx = rx * Math.cos(cornerAngle);
            const cy = ry * Math.sin(cornerAngle);
            return [
                // Corner handles at 45° positions on the oval/circle
                { x: x - cx, y: y - cy, id: 'nw', size: cornerHandleSize, isCorner: true },
                { x: x + cx, y: y - cy, id: 'ne', size: cornerHandleSize, isCorner: true },
                { x: x - cx, y: y + cy, id: 'sw', size: cornerHandleSize, isCorner: true },
                { x: x + cx, y: y + cy, id: 'se', size: cornerHandleSize, isCorner: true },
                // Edge handles at cardinal positions using appropriate radii
                { x: x, y: y - ry, id: 'n', size: handleSize, isCorner: false },
                { x: x, y: y + ry, id: 's', size: handleSize, isCorner: false },
                { x: x - rx, y: y, id: 'w', size: handleSize, isCorner: false },
                { x: x + rx, y: y, id: 'e', size: handleSize, isCorner: false }
