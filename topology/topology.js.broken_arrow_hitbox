        // Add CSS animation - remove old styles first
        const oldStyle = document.getElementById('tb-toolbar-styles');
        if (oldStyle) oldStyle.remove();
        
        const style = document.createElement('style');
        style.id = 'tb-toolbar-styles';
        style.textContent = `
