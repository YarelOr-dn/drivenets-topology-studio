        this.multiSelectInitialPositions = null;
        this._initialQuickLinkCPs = null; // Clear QL CP positions
        this._initialAttachedULCPs = null; // Clear attached UL CP positions
        this.unboundLinkInitialPos = null; // Clear UL body drag position
        this._onLineTextDragStart = null; // Clear on-line text drag state
        this._attachedTextDragStart = null; // Clear attached text drag state
        
        // FINALIZE TB CURVE DRAG: Clean up temporary control point
        if (this._tbCurveDragStart && this.selectedObject && this.selectedObject.type === 'text') {
            const textObj = this.selectedObject;
            const link = this.objects.find(obj => obj.id === textObj.linkId);
            if (link && link.manualControlPoint) {
