            if (tbHadBackground) {
                // TB had background: TB bg → device color, TB text color → device labelColor
                if (this.copiedStyle.backgroundColor !== undefined) {
                    obj.color = this.copiedStyle.backgroundColor;
                } else if (this.copiedStyle.bgColor !== undefined) {
                    obj.color = this.copiedStyle.bgColor;
