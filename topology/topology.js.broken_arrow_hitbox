        const header = panel.querySelector('div[style*="border-bottom"]');
        if (header) {
            header.style.borderBottomColor = isDark ? '#444' : '#ddd';
        }
        
        // Update title
        const title = panel.querySelector('h4');
        if (title) {
            title.style.color = isDark ? '#fff' : '#333';
        }
        
        // Update All/None buttons
        const buttons = panel.querySelectorAll('button');
        buttons.forEach(btn => {
            const text = btn.textContent.toLowerCase();
            if (text === 'all') {
                btn.style.background = isDark ? '#27ae60' : '#2ecc71';
                btn.style.color = '#fff';
            } else if (text === 'none') {
                btn.style.background = isDark ? '#c0392b' : '#e74c3c';
