    // Get list of saved topologies with metadata
    // category: 'user' (default) or 'dnaas'
    getSavedTopologies(category = 'all') {
        let savedList = [];
        let dnaasList = [];
        
        try {
            savedList = JSON.parse(localStorage.getItem('topology_saved_list') || '[]');
        } catch (e) { savedList = []; }
        
        try {
            dnaasList = JSON.parse(localStorage.getItem('topology_dnaas_list') || '[]');
        } catch (e) { dnaasList = []; }
        
        const timestamps = JSON.parse(localStorage.getItem('topology_timestamps') || '{}');
        const currentName = localStorage.getItem('topology_current_name') || '';
        
        const userTopologies = savedList.map(name => ({
            name,
            category: 'user',
            timestamp: timestamps[name] || 0,
            isCurrent: name === currentName
        })).sort((a, b) => b.timestamp - a.timestamp);
        
        const dnaasTopologies = dnaasList.map(name => ({
            name,
            category: 'dnaas',
            timestamp: timestamps[`dnaas_${name}`] || 0,
            isCurrent: name === currentName
        })).sort((a, b) => b.timestamp - a.timestamp);
        
        if (category === 'user') return userTopologies;
        if (category === 'dnaas') return dnaasTopologies;
        return { user: userTopologies, dnaas: dnaasTopologies };
    }
    
    // Save current topology as DNAAS topology
    saveAsDnaasTopology(name = null) {
        if (!name) {
            // Show modal for naming
            this.showSaveAsDnaasModal();
            return;
        }
        
        const cleanName = name.trim().replace(/[<>:"/\\|?*]/g, '_');
        if (!cleanName) {
            this.showNotification('Invalid name', 'error');
            return;
        }
        
        // Save with dnaas prefix
        const data = {
            version: '1.0',
            name: cleanName,
            category: 'dnaas',
            savedAt: new Date().toISOString(),
            objects: JSON.parse(JSON.stringify(this.objects)),
            metadata: {
                deviceIdCounter: this.deviceIdCounter,
                linkIdCounter: this.linkIdCounter,
                textIdCounter: this.textIdCounter,
                shapeIdCounter: this.shapeIdCounter,
                deviceCounters: this.deviceCounters,
                panOffset: this.panOffset,
                zoom: this.zoom
            }
        };
        
        const storageKey = `topology_dnaas_${cleanName}`;
        try {
            localStorage.setItem(storageKey, JSON.stringify(data));
            
            // Update DNAAS list
            let dnaasList = [];
            try {
                dnaasList = JSON.parse(localStorage.getItem('topology_dnaas_list') || '[]');
            } catch (e) { dnaasList = []; }
            
            if (!dnaasList.includes(cleanName)) {
                dnaasList.push(cleanName);
                localStorage.setItem('topology_dnaas_list', JSON.stringify(dnaasList));
            }
            
            // Update timestamp
            const timestamps = JSON.parse(localStorage.getItem('topology_timestamps') || '{}');
            timestamps[`dnaas_${cleanName}`] = Date.now();
            localStorage.setItem('topology_timestamps', JSON.stringify(timestamps));
            
            this.showNotification(`Saved DNAAS topology "${cleanName}"`, 'success');
            
        } catch (error) {
            console.error('Error saving DNAAS topology:', error);
            this.showNotification('Failed to save - storage may be full', 'error');
        }
    }
    
