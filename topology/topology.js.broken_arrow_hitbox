    /**
     * Draw device as a circle (default style)
     */
    drawDeviceCircle(device, isSelected) {
        this.ctx.beginPath();
        this.ctx.arc(device.x, device.y, device.radius, 0, Math.PI * 2);
        this.ctx.fillStyle = device.color;
        this.ctx.fill();
        
        // Draw border (white in dark mode, dark gray in light mode)
        this.ctx.strokeStyle = isSelected ? '#3498db' : (this.darkMode ? '#ffffff' : '#333');
        this.ctx.lineWidth = isSelected ? 3 : 2;
        this.ctx.stroke();
    }
    
    /**
     * Draw device as Cylinder - 3D cylinder with gradient and arrows on top
     * Professional network device style
     */
    drawDeviceClassicRouter(device, isSelected) {
        const r = device.radius;
        const x = device.x;
        const y = device.y;
        
        // Cylinder dimensions
        const width = r * 1.6;
        const topHeight = r * 0.4; // Ellipse height for top face
        const bodyHeight = r * 0.6; // Cylinder body height
        
        this.ctx.save();
        this.ctx.translate(x, y);
        this.ctx.rotate((device.rotation || 0) * Math.PI / 180);
        
        const borderColor = isSelected ? '#3498db' : (this.darkMode ? '#ffffff' : '#333');
        const darkerColor = this.darkenColor(device.color, 0.35);
        const highlightColor = this.lightenColor ? this.lightenColor(device.color, 0.1) : device.color;
        
        // Draw cylinder body (side) with horizontal gradient for 3D effect
        this.ctx.beginPath();
        this.ctx.moveTo(-width/2, -topHeight/2);
        this.ctx.lineTo(-width/2, -topHeight/2 + bodyHeight);
        this.ctx.ellipse(0, -topHeight/2 + bodyHeight, width/2, topHeight/2, 0, Math.PI, 0, true);
        this.ctx.lineTo(width/2, -topHeight/2);
        this.ctx.closePath();
        
        // Create horizontal gradient for cylinder body (light in center, dark at edges)
        const bodyGradient = this.ctx.createLinearGradient(-width/2, 0, width/2, 0);
        bodyGradient.addColorStop(0, darkerColor);
        bodyGradient.addColorStop(0.3, this.darkenColor(device.color, 0.15));
        bodyGradient.addColorStop(0.5, this.darkenColor(device.color, 0.1));
        bodyGradient.addColorStop(0.7, this.darkenColor(device.color, 0.15));
        bodyGradient.addColorStop(1, darkerColor);
        this.ctx.fillStyle = bodyGradient;
        this.ctx.fill();
        this.ctx.strokeStyle = borderColor;
        this.ctx.lineWidth = isSelected ? 3 : 2;
        this.ctx.stroke();
        
        // Draw label on the cylinder body (side surface)
        const label = device.label || (device.deviceType === 'router' ? 'NCP' : 'S');
        const labelY = bodyHeight * 0.4; // Center of body
        // Use custom labelSize if set, otherwise calculate based on radius
        const fontSize = device.labelSize || Math.max(10, Math.min(r * 0.35, 22));
        // Use device's font family (handwritten, etc.) or default
        const fontFamily = device.fontFamily || this.defaultDeviceFontFamily || 'Inter, sans-serif';
        const fontWeight = device.fontWeight || 'bold';
        const fontStyle = device.fontStyle || 'normal';
        this.ctx.font = `${fontStyle} ${fontWeight} ${fontSize}px ${fontFamily}`;
        this.ctx.textAlign = 'center';
        this.ctx.textBaseline = 'middle';
        
        // Label on device body - use labelColor if set, default white on colored surface
        const labelTextColor = device.labelColor || '#ffffff';
        this.ctx.strokeStyle = 'rgba(0,0,0,0.6)';
        this.ctx.lineWidth = 2.5;
        this.ctx.strokeText(label, 0, labelY);
        this.ctx.fillStyle = labelTextColor;
        this.ctx.fillText(label, 0, labelY);
        
        // Draw top ellipse face with subtle gradient
        this.ctx.beginPath();
        this.ctx.ellipse(0, -topHeight/2, width/2, topHeight/2, 0, 0, Math.PI * 2);
        
        // Radial gradient for top face (subtle lighting)
        const topGradient = this.ctx.createRadialGradient(-width*0.15, -topHeight*0.6, 0, 0, -topHeight/2, width/2);
        topGradient.addColorStop(0, highlightColor);
        topGradient.addColorStop(0.7, device.color);
        topGradient.addColorStop(1, this.darkenColor(device.color, 0.1));
        this.ctx.fillStyle = topGradient;
        this.ctx.fill();
        this.ctx.strokeStyle = borderColor;
        this.ctx.stroke();
        
        // Draw 4-way arrows on top face (scaled to fit ellipse)
        // Always white arrows for visibility on colored device
        this.drawFourWayArrowsEllipse(0, -topHeight/2, width/2 * 0.7, topHeight/2 * 0.7, '#ffffff');
        
        this.ctx.restore();
    }
    
    /**
     * Draw device as Simple Router - 2D minimal circle with crossed arrows
     * Clean, schematic style
     */
    drawDeviceSimpleRouter(device, isSelected) {
        const r = device.radius;
        const x = device.x;
        const y = device.y;
        
        this.ctx.save();
        this.ctx.translate(x, y);
        this.ctx.rotate((device.rotation || 0) * Math.PI / 180);
        
        const borderColor = isSelected ? '#3498db' : (this.darkMode ? '#ffffff' : '#333');
        
        // Draw outer circle (outline only or very light fill)
        this.ctx.beginPath();
        this.ctx.arc(0, 0, r, 0, Math.PI * 2);
        this.ctx.fillStyle = this.darkMode ? 'rgba(255,255,255,0.1)' : 'rgba(255,255,255,0.9)';
        this.ctx.fill();
        this.ctx.strokeStyle = borderColor;
        this.ctx.lineWidth = isSelected ? 3 : 2.5;
        this.ctx.stroke();
        
        // Draw inner circle
        this.ctx.beginPath();
        this.ctx.arc(0, 0, r * 0.15, 0, Math.PI * 2);
        this.ctx.fillStyle = borderColor;
        this.ctx.fill();
        
        // Draw 4 cardinal arrows pointing outward
        const arrowColor = borderColor;
        const arrowLen = r * 0.65;
        const arrowStart = r * 0.25;
        
        this.ctx.strokeStyle = arrowColor;
        this.ctx.fillStyle = arrowColor;
        this.ctx.lineWidth = 2.5;
        
        // Cardinal directions: up, right, down, left
        const directions = [
            { dx: 0, dy: -1 },  // Up
            { dx: 1, dy: 0 },   // Right
            { dx: 0, dy: 1 },   // Down
            { dx: -1, dy: 0 }   // Left
        ];
        
        directions.forEach(dir => {
            const startX = dir.dx * arrowStart;
            const startY = dir.dy * arrowStart;
            const endX = dir.dx * arrowLen;
            const endY = dir.dy * arrowLen;
            
            // Draw arrow line
            this.ctx.beginPath();
            this.ctx.moveTo(startX, startY);
            this.ctx.lineTo(endX, endY);
            this.ctx.stroke();
            
            // Draw arrowhead
            const headLen = r * 0.18;
            const angle = Math.atan2(dir.dy, dir.dx);
            
            this.ctx.beginPath();
            this.ctx.moveTo(endX, endY);
            this.ctx.lineTo(
                endX - headLen * Math.cos(angle - Math.PI/6),
                endY - headLen * Math.sin(angle - Math.PI/6)
            );
            this.ctx.lineTo(
                endX - headLen * Math.cos(angle + Math.PI/6),
                endY - headLen * Math.sin(angle + Math.PI/6)
            );
            this.ctx.closePath();
            this.ctx.fill();
        });
        
        this.ctx.restore();
    }
    
