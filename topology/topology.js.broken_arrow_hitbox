    findUnboundLinkEndpoint(x, y) {
        // ENHANCED: Pixel-accurate triangular hitbox for arrow tips (TPs and MPs)
        // TPs have higher priority than MPs, and larger hitboxes for easier grabbing
        
        // First pass: Check FREE ENDPOINTS (TPs) - highest priority
        for (let i = this.objects.length - 1; i >= 0; i--) {
            const obj = this.objects[i];
            if (obj.type === 'unbound') {
                // Use unified isEndpointConnected to check if endpoints are TPs
                const startIsTP = !this.isEndpointConnected(obj, 'start') && 
                                 !(obj.device1 !== null && obj.device1 !== undefined);
                const endIsTP = !this.isEndpointConnected(obj, 'end') && 
                               !(obj.device2 !== null && obj.device2 !== undefined);
                
                // ENHANCED: Triangular hitbox for arrow tips to match visual shape
                const linkStyle = obj.style || 'solid';
                const isArrowStyle = linkStyle.includes('arrow');
                const linkWidth = obj.width || 2;
                const arrowLength = isArrowStyle ? (10 + linkWidth * 3) : 0;
                const arrowAngleSpread = Math.PI / 5; // 36° (matches visual)
                
                // Arrow tips: triangular hitbox for pixel-perfect accuracy
                // Regular TPs: standard 16px circular hitbox
                const tpHitRadius = isArrowStyle ? Math.max(20, arrowLength * 1.8) / this.zoom : 16 / this.zoom;
                
                // FIX: Always use current link.start/end positions for free TPs
                // Arrow tip positions may be from previous draw cycle, causing mismatch
                // For free TPs (not attached to device), use link.start/end directly
                let startPosX, startPosY, endPosX, endPosY;
                
                if (startIsTP) {
                    // Free TP - use current position
                    startPosX = obj.start.x;
                    startPosY = obj.start.y;
                } else {
                    // Device-attached - use stored arrow tip if available (accounts for device edge)
                    startPosX = obj._arrowTipStart ? obj._arrowTipStart.x : obj.start.x;
                    startPosY = obj._arrowTipStart ? obj._arrowTipStart.y : obj.start.y;
                }
                
                if (endIsTP) {
                    // Free TP - use current position
                    endPosX = obj.end.x;
                    endPosY = obj.end.y;
                } else {
                    // Device-attached - use stored arrow tip if available
                    endPosX = obj._arrowTipEnd ? obj._arrowTipEnd.x : obj.end.x;
                    endPosY = obj._arrowTipEnd ? obj._arrowTipEnd.y : obj.end.y;
                }
                
                if (startIsTP) {
                    // Check with triangular hitbox for arrow tips
                    let hitStart = false;
                    
                    if (isArrowStyle && linkStyle.includes('double') && obj._arrowStartAngle !== undefined) {
                        // Pixel-accurate triangle hitbox for START arrow tip
                        const startAngle = obj._arrowStartAngle;
                        const tipX = startPosX;
                        const tipY = startPosY;
                        const leftX = tipX + arrowLength * Math.cos(startAngle - arrowAngleSpread);
                        const leftY = tipY + arrowLength * Math.sin(startAngle - arrowAngleSpread);
                        const rightX = tipX + arrowLength * Math.cos(startAngle + arrowAngleSpread);
                        const rightY = tipY + arrowLength * Math.sin(startAngle + arrowAngleSpread);
                        
                        hitStart = this.isPointInTriangle(x, y, tipX, tipY, leftX, leftY, rightX, rightY);
                    }
                    
                    // Fallback: circular hitbox
                    if (!hitStart) {
                        const distStart = Math.hypot(x - startPosX, y - startPosY);
                        hitStart = distStart < tpHitRadius;
                    }
                    
                    if (hitStart) {
                        return { link: obj, endpoint: 'start', isConnectionPoint: false };
                    }
                }
                
                if (endIsTP) {
                    // Check with triangular hitbox for arrow tips
                    let hitEnd = false;
                    
                    if (isArrowStyle && obj._arrowEndAngle !== undefined) {
                        // Pixel-accurate triangle hitbox for END arrow tip
                        const endAngle = obj._arrowEndAngle;
                        const tipX = endPosX;
                        const tipY = endPosY;
                        const leftX = tipX - arrowLength * Math.cos(endAngle - arrowAngleSpread);
                        const leftY = tipY - arrowLength * Math.sin(endAngle - arrowAngleSpread);
                        const rightX = tipX - arrowLength * Math.cos(endAngle + arrowAngleSpread);
                        const rightY = tipY - arrowLength * Math.sin(endAngle + arrowAngleSpread);
                        
                        hitEnd = this.isPointInTriangle(x, y, tipX, tipY, leftX, leftY, rightX, rightY);
                    }
                    
                    // Fallback: circular hitbox
                    if (!hitEnd) {
                        const distEnd = Math.hypot(x - endPosX, y - endPosY);
                        hitEnd = distEnd < tpHitRadius;
                    }
                    
                    if (hitEnd) {
                        return { link: obj, endpoint: 'end', isConnectionPoint: false };
                    }
                }
            }
        }
        
        // Second pass: Check connection points (MPs) - lower priority
        // Only check if no TP was found above
        for (let i = this.objects.length - 1; i >= 0; i--) {
            const obj = this.objects[i];
            if (obj.type === 'unbound') {
                // ENHANCED: Larger hitbox for MPs too, but still lower priority
                const mpHitRadius = 14 / this.zoom; // 14px screen space
                
                // Get all links in the merge chain
                const allMergedLinks = this.getAllMergedLinks(obj);
                
                // Check all connection points in the chain
                for (const chainLink of allMergedLinks) {
                    // Check if this link is the parent in a merge (has mergedWith)
                    if (chainLink.mergedWith && chainLink.mergedWith.connectionPoint) {
                        const connPoint = chainLink.mergedWith.connectionPoint;
                        const distConn = Math.hypot(x - connPoint.x, y - connPoint.y);
                        if (distConn < mpHitRadius) {
                            // Return the connected endpoint as a Moving Point
                            const connectedEndpoint = chainLink.mergedWith.parentFreeEnd === 'start' ? 'end' : 'start';
                            return { link: chainLink, endpoint: connectedEndpoint, isConnectionPoint: true };
                        }
                    }
                    
                    // Check if this link is the child in a merge (has mergedInto)
                    if (chainLink.mergedInto && chainLink.mergedInto.connectionPoint) {
                        const connPoint = chainLink.mergedInto.connectionPoint;
                        const distConn = Math.hypot(x - connPoint.x, y - connPoint.y);
                        if (distConn < mpHitRadius) {
                            // Return the connected endpoint as a Moving Point
                            const parentLink = this.objects.find(o => o.id === chainLink.mergedInto.parentId);
                            if (parentLink && parentLink.mergedWith) {
                                const connectedEndpoint = parentLink.mergedWith.childConnectionEndpoint ||
                                    (parentLink.mergedWith.childFreeEnd === 'start' ? 'end' : 'start');
                                return { link: chainLink, endpoint: connectedEndpoint, isConnectionPoint: true };
                            }
                        }
                    }
                }
            }
        }
        
        return null;
    }
    
