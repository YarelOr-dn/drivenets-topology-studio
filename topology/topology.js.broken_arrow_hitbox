            this.draw();
            // Re-show toolbar at new position
            setTimeout(() => this.showTextSelectionToolbar(textObj), 50);
        }));
        }
        
        // Background toggle
        const bgBtn = createButton(textObj.showBackground !== false ? 'bg-on' : 'bg-off', 'Background', () => {
            textObj.showBackground = textObj.showBackground === false;
            if (textObj.linkId) this.updateAdjacentTextPosition(textObj);
