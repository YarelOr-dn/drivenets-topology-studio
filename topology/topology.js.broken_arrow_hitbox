                { x: x, y: y - h/2, id: 'n', size: cornerHandleSize, isCorner: true },
                { x: x, y: y + h/2, id: 's', size: cornerHandleSize, isCorner: true },
                { x: x - w/2, y: y, id: 'w', size: cornerHandleSize, isCorner: true },
                { x: x + w/2, y: y, id: 'e', size: cornerHandleSize, isCorner: true },
