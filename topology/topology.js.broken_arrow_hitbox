    // ==================== INLINE TEXT EDITOR ====================
    // Mini toolbar that appears at the text location on double-click
    // Contains: text input, color picker, font size slider
    
    showInlineTextEditor(textObj, event) {
        if (!textObj || textObj.type !== 'text') return;
        
        // BUGFIX: Hide text selection toolbar when opening inline editor
        this.hideTextSelectionToolbar();
        
        // Remove existing inline editor if any (BEFORE setting editingText)
        this.hideInlineTextEditor();
        
        // Set editingText AFTER hide to prevent it from being cleared
        this.editingText = textObj;
        
        try {
            // Calculate screen position of the text (exact position on grid)
            const rect = this.canvas.getBoundingClientRect();
            const scaleX = this.canvas.width / rect.width;
            const scaleY = this.canvas.height / rect.height;
            const screenX = (textObj.x * this.zoom + this.panOffset.x) / scaleX + rect.left;
            const screenY = (textObj.y * this.zoom + this.panOffset.y) / scaleY + rect.top;
            
            // Calculate the scaled font size for screen display
            const scaledFontSize = (parseInt(textObj.fontSize) || 14) * this.zoom / scaleX;
            
            // Create the inline text textarea for multi-line support
            // Using textarea instead of input to support Shift+Enter for new lines
            const textInput = document.createElement('textarea');
            textInput.id = 'inline-text-editor';
            textInput.value = textObj.text || '';
            textInput.placeholder = 'Type here...';
            // Use the text object's font properties (family, weight, AND style)
            const fontFamily = textObj.fontFamily || 'Arial';
            const fontWeight = textObj.fontWeight || 'normal';
            const fontStyle = textObj.fontStyle || 'normal'; // italic, oblique, or normal
            
            // Calculate height based on number of lines
            const existingLines = (textObj.text || '').split('\n').length;
            const minRows = Math.max(1, existingLines);
            const lineHeightPx = scaledFontSize * 1.3;
            const textareaHeight = Math.max(lineHeightPx * minRows + 16, 30); // +16 for padding
            
            textInput.style.cssText = `
                position: fixed;
                left: ${screenX}px;
                top: ${screenY}px;
                transform: translate(-50%, -50%) rotate(${textObj.rotation || 0}deg);
                z-index: 10000;
                background: transparent;
                border: 2px dashed #3498db;
                border-radius: 4px;
                padding: 4px 8px;
                color: ${textObj.color || '#ffffff'};
                font-size: ${scaledFontSize}px;
                font-family: ${fontFamily}, sans-serif;
                font-weight: ${fontWeight};
                font-style: ${fontStyle};
                text-align: center;
                outline: none;
                min-width: 80px;
                min-height: ${textareaHeight}px;
                box-sizing: border-box;
                caret-color: #3498db;
                resize: none;
                overflow: hidden;
                line-height: 1.3;
                white-space: pre-wrap;
            `;
            
            // Add text stroke effect via text-shadow if stroke is enabled
            if (textObj.strokeWidth && textObj.strokeWidth > 0) {
                const strokeColor = textObj.strokeColor || '#000000';
                const sw = textObj.strokeWidth * this.zoom / scaleX;
                textInput.style.textShadow = `
                    -${sw}px -${sw}px 0 ${strokeColor},
                    ${sw}px -${sw}px 0 ${strokeColor},
                    -${sw}px ${sw}px 0 ${strokeColor},
                    ${sw}px ${sw}px 0 ${strokeColor}
                `;
            }
            
            document.body.appendChild(textInput);
            
            // Store reference for cleanup BEFORE setting _editing
            this._inlineTextEditor = textInput;
            
            // Verify element was added successfully
            if (!document.body.contains(textInput)) {
                throw new Error('Failed to append inline editor to DOM');
            }
            
            // NOW set _editing flag - only after DOM element exists
            textObj._editing = true;
            
            // Focus and select all text
            textInput.focus();
            textInput.select();
            
            // Auto-resize textarea based on content (width and height)
            const autoResize = () => {
                const content = textInput.value || textInput.placeholder;
                const lines = content.split('\n');
                
                // Measure max line width
                let maxWidth = 0;
                const tempSpan = document.createElement('span');
                tempSpan.style.cssText = `
                    position: absolute;
                    visibility: hidden;
                    white-space: pre;
                    font-size: ${scaledFontSize}px;
                    font-family: ${fontFamily}, sans-serif;
                    font-weight: ${fontWeight};
                    font-style: ${fontStyle};
                    padding: 4px 8px;
                `;
                document.body.appendChild(tempSpan);
                
                for (const line of lines) {
                    tempSpan.textContent = line || ' '; // Use space for empty lines
                    maxWidth = Math.max(maxWidth, tempSpan.offsetWidth);
                }
                document.body.removeChild(tempSpan);
                
                // Set width based on max line width
                const newWidth = Math.max(80, maxWidth + 24);
                textInput.style.width = `${newWidth}px`;
                
                // Set height based on number of lines
                const lineHeightPx = scaledFontSize * 1.3;
                const newHeight = Math.max(lineHeightPx + 16, lines.length * lineHeightPx + 16);
                textInput.style.height = `${newHeight}px`;
            };
            
            autoResize();
            
            // Live preview - update text as user types
            textInput.addEventListener('input', (e) => {
                if (this.editingText) {
                    this.editingText.text = e.target.value;
                    autoResize();
                    this.draw();
                }
            });
            
            // Close on Enter (without Shift) or Escape
            // Shift+Enter inserts a new line for multi-line text
            // Option+Backspace deletes one word backwards
            textInput.addEventListener('keydown', (e) => {
                // Stop propagation to prevent global handlers from interfering
                e.stopPropagation();
                
                // Option+Backspace (Alt+Backspace): Delete one word backwards
                if (e.key === 'Backspace' && e.altKey) {
                    e.preventDefault();
                    const cursorPos = textInput.selectionStart;
                    const text = textInput.value;
                    
                    // Find the start of the previous word
                    let wordStart = cursorPos;
                    // Skip any trailing spaces
                    while (wordStart > 0 && /\s/.test(text[wordStart - 1])) {
                        wordStart--;
                    }
                    // Find the start of the word
                    while (wordStart > 0 && !/\s/.test(text[wordStart - 1])) {
                        wordStart--;
                    }
                    
                    // Delete the word
                    const newText = text.substring(0, wordStart) + text.substring(cursorPos);
                    textInput.value = newText;
                    textInput.selectionStart = textInput.selectionEnd = wordStart;
                    
                    // Trigger input event for live preview
                    textInput.dispatchEvent(new Event('input', { bubbles: true }));
                    return;
                }
                
                if (e.key === 'Enter') {
                    if (e.shiftKey) {
                        // Shift+Enter: Insert new line - let textarea handle it naturally
                        // Don't preventDefault - the textarea needs to insert the newline
                        // After newline insertion, the 'input' event will trigger autoResize
                        return;
                    } else {
                        // Plain Enter: Close editor and save
                        e.preventDefault();
                        this.hideInlineTextEditor();
                    }
                }
                if (e.key === 'Escape') {
                    e.preventDefault();
                    this.hideInlineTextEditor();
                }
            });
            
            // Close on click outside
            this._inlineEditorClickOutside = (e) => {
                if (this._inlineTextEditor && e.target !== this._inlineTextEditor) {
                    this.hideInlineTextEditor();
                }
            };
            
            // Delay adding the click listener to prevent immediate close
            setTimeout(() => {
                document.addEventListener('mousedown', this._inlineEditorClickOutside);
            }, 100);
            
            // Fallback safety: if inline editor disappears without cleanup, restore visibility
            this._inlineEditorFallback = setTimeout(() => {
                if (textObj._editing && !document.body.contains(this._inlineTextEditor)) {
                    console.warn('Inline editor disappeared unexpectedly, restoring text visibility');
                    delete textObj._editing;
                    this.draw();
                }
            }, 200);
            
            this.draw();
            
            if (this.debugger) {
                this.debugger.logInfo(`Inline editor opened for "${textObj.text}"`);
            }
        } catch (e) {
            // Error occurred - restore text visibility
            console.error('Failed to show inline text editor:', e);
            delete textObj._editing;
            this.editingText = null;
            this._inlineTextEditor = null;
            this.draw();
        }
    }
    
    // Update inline editor position when canvas pans/zooms
    updateInlineTextEditorPosition() {
        if (!this._inlineTextEditor || !this.editingText) return;
        
        const textObj = this.editingText;
        const rect = this.canvas.getBoundingClientRect();
        const scaleX = this.canvas.width / rect.width;
        const scaleY = this.canvas.height / rect.height;
        const screenX = (textObj.x * this.zoom + this.panOffset.x) / scaleX + rect.left;
        const screenY = (textObj.y * this.zoom + this.panOffset.y) / scaleY + rect.top;
        const scaledFontSize = (parseInt(textObj.fontSize) || 14) * this.zoom / scaleX;
        
        this._inlineTextEditor.style.left = `${screenX}px`;
        this._inlineTextEditor.style.top = `${screenY}px`;
        this._inlineTextEditor.style.fontSize = `${scaledFontSize}px`;
        this._inlineTextEditor.style.transform = `translate(-50%, -50%) rotate(${textObj.rotation || 0}deg)`;
    }
    
    hideInlineTextEditor() {
        // Clear fallback safety timer
        if (this._inlineEditorFallback) {
            clearTimeout(this._inlineEditorFallback);
            this._inlineEditorFallback = null;
        }
        
        if (this._inlineTextEditor) {
            this._inlineTextEditor.remove();
            this._inlineTextEditor = null;
        }
        
        if (this._inlineEditorClickOutside) {
            document.removeEventListener('mousedown', this._inlineEditorClickOutside);
            this._inlineEditorClickOutside = null;
        }
        
        // Keep text selected and clear editing flag
        const textObj = this.editingText;
        this.editingText = null;
        
        // ALWAYS clear _editing flag to restore text visibility
        if (textObj) {
            // Clear editing flag so text renders on canvas again
            delete textObj._editing;
            this.selectedObject = textObj;
            this.selectedObjects = [textObj];
            // Show selection toolbar after closing inline editor
            this.showTextSelectionToolbar(textObj);
        }
        
        this.draw();
    }
    
    // ==================== TEXT SELECTION TOOLBAR ====================
    // Floating toolbar that appears below selected text with options
    // Contains: Rotation, Background, Detach, Delete, More options
    
    // Helper to create SVG icon HTML (for dynamic icon generation)
    _createIconSvg(iconId, size = 16, color = null) {
        const colorStyle = color ? `color: ${color};` : '';
        // pointer-events: none ensures clicks pass through to parent button
        return `<svg width="${size}" height="${size}" style="${colorStyle} pointer-events: none;"><use href="#ico-${iconId}"/></svg>`;
    }
    
    showTextSelectionToolbar(textObj) {
        if (!textObj || textObj.type !== 'text') return;
        
        // Don't show if inline editor is active
        if (this._inlineTextEditor) return;
        
        // Don't show if text is currently being dragged or sliding
        if (this.dragging) return;
        
        // Hide ALL toolbars first (device, link, text, shape) - only one can be open at a time
        this.hideDeviceSelectionToolbar();
        this.hideLinkSelectionToolbar();
        this.hideTextSelectionToolbar();
        this.hideShapeSelectionToolbar();
        
        // Calculate screen position of the text
        const rect = this.canvas.getBoundingClientRect();
        const scaleX = this.canvas.width / rect.width;
        const scaleY = this.canvas.height / rect.height;
        
        // FIXED: Measure actual text width using canvas context
        this.ctx.save();
        const fontFamily = textObj.fontFamily || 'Arial';
        const fontWeight = textObj.fontWeight || 'normal';
        const fontSize = parseInt(textObj.fontSize) || 14;
        this.ctx.font = `${fontWeight} ${fontSize}px ${fontFamily}`;
        const textContent = textObj.text || 'Text';
        const lines = textContent.split('\n');
        const lineCount = Math.max(1, lines.length);
        
        // Measure the widest line
        let maxLineWidth = 0;
        lines.forEach(line => {
            const metrics = this.ctx.measureText(line || ' ');
            maxLineWidth = Math.max(maxLineWidth, metrics.width);
        });
        this.ctx.restore();
        
        const lineHeight = fontSize * 1.3;
        const textContentHeight = lineCount * lineHeight;
        const bgPadding = textObj.showBackground !== false ? (textObj.bgPadding || 8) : 4;
        const boxHeight = textContentHeight + bgPadding * 2;
        const boxWidth = maxLineWidth + bgPadding * 2;
        
        // Get rotation in radians
        const rotation = (textObj.rotation || 0) * Math.PI / 180;
        
        // Calculate the 4 corners of the text box (relative to center)
        const halfW = boxWidth / 2;
        const halfH = boxHeight / 2;
        const corners = [
            { x: -halfW, y: -halfH }, // top-left
            { x: halfW, y: -halfH },  // top-right
            { x: halfW, y: halfH },   // bottom-right
            { x: -halfW, y: halfH }   // bottom-left
        ];
        
        // Rotate corners and find the bounding box
        const cos = Math.cos(rotation);
        const sin = Math.sin(rotation);
        let minY = Infinity, maxY = -Infinity, minX = Infinity, maxX = -Infinity;
        
        corners.forEach(corner => {
            const rotX = corner.x * cos - corner.y * sin;
            const rotY = corner.x * sin + corner.y * cos;
            minX = Math.min(minX, rotX);
            maxX = Math.max(maxX, rotX);
            minY = Math.min(minY, rotY);
            maxY = Math.max(maxY, rotY);
        });
        
        // Text position is the center, convert to screen coordinates
        const centerScreenX = (textObj.x * this.zoom + this.panOffset.x) / scaleX + rect.left;
        const centerScreenY = (textObj.y * this.zoom + this.panOffset.y) / scaleY + rect.top;
        
        // Calculate bottom of the rotated bounding box in screen coordinates
        // FIXED: Apply zoom to the maxY offset properly
        const bottomY = centerScreenY + (maxY * this.zoom / scaleY);
        const centerX = centerScreenX;
        
        // Position toolbar BELOW the rotated bounding box with consistent gap
        const toolbarGap = 20; // Fixed pixel gap below text
        const toolbarX = centerX;
        const toolbarY = bottomY + toolbarGap;
        
        // Create the toolbar container - Liquid Glass Style (ultra-transparent, links visible through)
        const toolbar = document.createElement('div');
        toolbar.id = 'text-selection-toolbar';
        const isDark = this.darkMode;
        // ENHANCED: More prominent liquid glass with increased blur - links clearly visible through
        const glassBg = isDark 
            ? 'linear-gradient(135deg, rgba(20, 25, 40, 0.3) 0%, rgba(15, 20, 35, 0.4) 100%)' 
            : 'linear-gradient(135deg, rgba(255, 255, 255, 0.35) 0%, rgba(240, 245, 255, 0.3) 100%)';
        const glassBorder = isDark ? 'rgba(100, 150, 255, 0.2)' : 'rgba(100, 150, 200, 0.12)';
        const glassShadow = isDark 
            ? '0 8px 40px rgba(0, 0, 0, 0.35), 0 2px 8px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.1), inset 0 -1px 0 rgba(0, 0, 0, 0.08)'
            : '0 8px 40px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.6), inset 0 -1px 0 rgba(0, 0, 0, 0.03)';
        toolbar.style.cssText = `
            position: fixed;
            left: ${toolbarX}px;
