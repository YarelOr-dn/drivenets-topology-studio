        if (wasPendingStretch && !wasStretching) {
            const pendingInfo = this._pendingStretchInfo;
            if (pendingInfo && !pendingInfo.isConnectionPoint) {
                // Check if this endpoint is really a free TP (not attached to a device AND not connected to another link)
                const link = pendingInfo.link;
                const endpoint = pendingInfo.endpoint;
                
                // CRITICAL FIX: Check BOTH device attachment AND merge connection
                // An endpoint is only a "free TP" if it has no device AND is not connected to another link
                const isStartFree = !link.device1 && !this.isEndpointConnected(link, 'start');
                const isEndFree = !link.device2 && !this.isEndpointConnected(link, 'end');
                
                const isFreeTP = (endpoint === 'start' && isStartFree) || (endpoint === 'end' && isEndFree);
                
                // CRITICAL: Only allow link from TP if chain mode is ON
                if (isFreeTP && this.linkContinuousMode) {
                    // Enter "link from TP" mode
                    this._linkFromTP = {
                        link: link,
                        endpoint: endpoint,
                        startPos: endpoint === 'start' ? { ...link.start } : { ...link.end }
                    };
                    this.setMode('link');
                    this.linking = true;
                    this.linkStart = null; // Not starting from a device
                    
                    // Keep the BUL chain selected for visual feedback
                    const allMergedLinks = this.getAllMergedLinks(link);
                    this.selectedObjects = allMergedLinks;
                    this.selectedObject = link;
                    
                    if (this.debugger) {
                        this.debugger.logSuccess(`🔗 Link from TP: Started from ${link.id} (${endpoint})`);
                        this.debugger.logInfo(`   Click on a device, grid, or another TP to connect`);
                    }
                    
                    // Show notification to user
                    this.showNotification('Click to extend chain from TP (ESC to cancel)', 'info');
                    
                    this.draw();
                    return; // Don't process further
                } else if (isFreeTP && !this.linkContinuousMode) {
                    // Chain mode OFF - don't enter link from TP mode, just keep selected
                    if (this.debugger) {
                        this.debugger.logInfo(`🔗 Chain mode OFF → TP click (enable chain mode to extend)`);
                    }
                    // Show hint to user
                    this.showNotification('Enable "Chain" mode to extend from TP', 'warning');
                }
            }
        }
        
        // CRITICAL: Clear _pendingStretchInfo after processing
        this._pendingStretchInfo = null;
        
