            let lldpLabel = 'Enable LLDP';
            let lldpColor = '#00B4D8'; // Default blue
            
            if (device._lastLldpResult) {
                const lastResult = device._lastLldpResult;
                const ageMinutes = (Date.now() - lastResult.timestamp) / 60000;
                
                if (ageMinutes < 30) { // Show status if less than 30 minutes old
                    if (lastResult.type === 'success') {
                        lldpLabel = 'LLDP ✓';
                        lldpColor = '#27ae60'; // Green
                    } else if (lastResult.type === 'error') {
                        lldpLabel = 'LLDP ✗ Retry';
                        lldpColor = '#e74c3c'; // Red
                    }
                }
            }
            
            let lldpBtnRef = null;
            lldpBtnRef = createButton('broadcast', lldpLabel, () => {
