        this._tbCurveDragStart = null; // Clear TB curve drag state (middle-attached text curving)
        
        // TEXT-TO-LINK SNAP: If text was being dragged and has a snap preview, attach it
        if (wasDragging && this.selectedObject && this.selectedObject.type === 'text' && this._textSnapPreview) {
            const snap = this._textSnapPreview;
            this.attachTextToLink(this.selectedObject, snap.link, snap.t);
            
            // After attaching, transition to base mode for seamless experience
            if (this.currentMode === 'text') {
                this.setMode('base');
                this.selectedObject = this.selectedObject; // Keep text selected
                this.selectedObjects = [this.selectedObject];
            }
        }
        this._textSnapPreview = null; // Always clear snap preview
        
        // ENHANCED: Keep text selection toolbar visible after dragging a text box
        if (wasDragging && this.selectedObject && this.selectedObject.type === 'text') {
            // Update toolbar position to follow dragged text
            this.updateTextSelectionToolbarPosition();
            // If toolbar was closed during drag, re-show it
            if (!this._textSelectionToolbar) {
                this.showTextSelectionToolbar(this.selectedObject);
            }
        }
        
        // ENHANCED: Re-show device toolbar after dragging a device
        if (wasDragging && this.selectedObject && this.selectedObject.type === 'device') {
            // Re-show toolbar at new position (below device)
            this.showDeviceSelectionToolbar(this.selectedObject);
        }
        
        // ENHANCED: Re-show link toolbar after dragging a link
        if (wasDragging && this.selectedObject && (this.selectedObject.type === 'link' || this.selectedObject.type === 'unbound')) {
            // Re-show toolbar at link center (no click position available after drag)
            this.showLinkSelectionToolbar(this.selectedObject);
        }
        
        this.textDragInitialPos = null; // Clear text drag position
        this.deviceDragInitialPos = null; // Clear device drag position
        this.shapeDragInitialPos = null; // Clear shape drag position
        this.dragStartPos = null; // Clear starting position for tap vs drag detection
        this.lastMousePos = null; // Clear last mouse position
        this._unboundLinkMoveLogged = false; // Reset UL move log flag
        this._unboundBodyDragLogged = false; // Reset UL body drag log flag
        this._lastLinkBodyDragDelta = null; // Reset link body drag delta tracking
        this._linkBodyDragInitialTextPositions = null; // Clear initial TB positions for link body drag
        this.lastDragPos = null; // Clear drag position tracking
        this._jumpDetectedThisDrag = false; // Reset jump detection flag for next drag
        this.lastDragTime = null;
        if (this.currentTool !== 'link') {
            this.linking = false;
            this.linkStart = null;
        }

        // If we temporarily exited placement to drag the newly placed device,
        // restore device placement mode after releasing the mouse
        if (this.tempPlacementResumeType) {
            this.setDevicePlacementMode(this.tempPlacementResumeType);
            this.tempPlacementResumeType = null;
        }
    }
    
    getNextDeviceLabel(deviceType) {
        // If numbering is disabled, always return base name
        if (!this.deviceNumbering) {
            return deviceType === 'router' ? 'NCP' : 'S';
        }
        
        // Numbering enabled - increment counter
        this.deviceCounters[deviceType] = (this.deviceCounters[deviceType] || 0) + 1;
        const count = this.deviceCounters[deviceType];
        
        if (count === 1) {
            return deviceType === 'router' ? 'NCP' : 'S';
        } else {
            return deviceType === 'router' ? `NCP-${count}` : `S${count}`;
        }
    }
    
    isDeviceNameUnique(name) {
        const existing = this.objects.find(obj => 
            obj.type === 'device' && obj.label === name
        );
        return !existing;
    }
    
    updateDeviceCounters() {
        // Recalculate device counters based on existing devices
        this.deviceCounters = { router: 0, switch: 0 };
        this.objects.forEach(obj => {
            if (obj.type === 'device') {
                const label = obj.label || '';
                if (obj.deviceType === 'router') {
                    if (label === 'NCP' || label === 'R') {
                        this.deviceCounters.router = Math.max(this.deviceCounters.router, 1);
                    } else {
                        // Match both NCP-2 format and old R2 format
                        const matchNCP = label.match(/^NCP-(\d+)$/);
                        const matchR = label.match(/^R(\d+)$/);
                        if (matchNCP) {
                            const num = parseInt(matchNCP[1]);
                            this.deviceCounters.router = Math.max(this.deviceCounters.router, num);
                        } else if (matchR) {
                            const num = parseInt(matchR[1]);
                            this.deviceCounters.router = Math.max(this.deviceCounters.router, num);
                        }
                    }
                } else if (obj.deviceType === 'switch') {
                    if (label === 'S') {
                        this.deviceCounters.switch = Math.max(this.deviceCounters.switch, 1);
                    } else {
                        const match = label.match(/^S(\d+)$/);
                        if (match) {
                            const num = parseInt(match[1]);
                            this.deviceCounters.switch = Math.max(this.deviceCounters.switch, num);
                        }
                    }
                }
            }
        });
    }
    
    handleContextMenu(e) {
        e.preventDefault();
        
        // If in device placement mode, right-click exits to base mode
        if (this.placingDevice) {
            this.placingDevice = null;
            this.placementPending = null;
            this.setMode('base');
            return;
        }
        
        // If in text placement mode, right-click exits to base mode
        // Also exits continuous TB placement mode
        if (this.currentTool === 'text') {
            this.textPlacementPending = null;
            this.exitContinuousTextPlacement(); // Exit continuous mode and update button
            this.setMode('base');
            return;
        }
        
        // If in link mode or TP chaining mode, right-click exits to base mode (no menu)
        if (this.currentTool === 'link' || this.currentMode === 'link' || this._linkFromTP || this.linking) {
            this.linking = false;
            this.linkStart = null;
            this._linkFromTP = null; // Clear TP linking mode
            this.setMode('base');
            this.draw();
            
            if (this.debugger) {
                this.debugger.logInfo(`🔗 Right-click → Exited to BASE mode (no menu)`);
            }
            return; // CRITICAL: Return here to prevent any menu from opening
        }
        
        const pos = this.getMousePos(e);
        const clickedObject = this.findObjectAt(pos.x, pos.y);
        
        // CRITICAL: Stop any dragging when context menu opens
        this.dragging = false;
        this.dragStart = null;
        this.stretchingLink = null;
        this.stretchingEndpoint = null;
        this.rotatingDevice = null;
        this.resizingDevice = null;
        this.resizeHandle = null;
        this.resizeStartDist = 0; // Reset delta calculation value
        this.rotatingText = false;
        this.resizingText = false;
        
        // ✨ MULTI-SELECT: Right-click with multiple objects selected → Show multi-select menu
        if (this.selectedObjects && this.selectedObjects.length > 1) {
            // Show the special multi-select context menu (liquid glass design)
            this.showMultiSelectContextMenu(e.clientX, e.clientY);
            
            if (this.debugger) {
                const devices = this.selectedObjects.filter(o => o.type === 'device').length;
                const links = this.selectedObjects.filter(o => o.type === 'link' || o.type === 'unbound').length;
                const texts = this.selectedObjects.filter(o => o.type === 'text').length;
                this.debugger.logSuccess(`🖱️ Multi-select right-click: ${this.selectedObjects.length} objects`);
                this.debugger.logInfo(`   Devices: ${devices}, Links: ${links}, Text: ${texts}`);
            }
            return;
        }
        
        // ✨ Right-click on device → Show device selection toolbar (liquid glass style)
        if (clickedObject && clickedObject.type === 'device') {
            // Cancel any device placement
            if (this.placingDevice) {
                this.placingDevice = null;
            }
            
            // Select the device if not already selected
            if (!this.selectedObjects.includes(clickedObject)) {
                this.selectedObject = clickedObject;
                this.selectedObjects = [clickedObject];
            }
            
            // Show the new device selection toolbar instead of context menu
            this.showDeviceSelectionToolbar(clickedObject);
            
            if (this.debugger) {
                const gridPos = this.worldToGrid({ x: clickedObject.x, y: clickedObject.y });
                this.debugger.logSuccess(`🖱️ Right-click on device: Toolbar for ${clickedObject.label || 'Device'}`);
                this.debugger.logInfo(`Device: ${clickedObject.label} at Grid(${Math.round(gridPos.x)}, ${Math.round(gridPos.y)})`);
            }
            
            this.draw();
            return;
        }
        
        // Right-click on TEXT object → Show text selection toolbar (NOT context menu)
        // All text features are now in the floating toolbar
        if (clickedObject && clickedObject.type === 'text') {
            // Select the text if not already selected
            if (!this.selectedObjects.includes(clickedObject)) {
                this.selectedObject = clickedObject;
                this.selectedObjects = [clickedObject];
            }
            
            // Show the text selection toolbar instead of context menu
            this.showTextSelectionToolbar(clickedObject);
            
            if (this.debugger) {
                this.debugger.logSuccess(`🖱️ Right-click on text: Showing toolbar for "${clickedObject.text || 'Text'}"`);
            }
            
            this.draw();
            return;
        }
        
        // For links (connected or unbound), show link selection toolbar (liquid glass style)
        if (clickedObject && (clickedObject.type === 'link' || clickedObject.type === 'unbound')) {
            // Check if clicked object is part of a BUL chain
            const isBulLink = clickedObject.type === 'unbound' && (clickedObject.mergedWith || clickedObject.mergedInto);
            
            // Check if current multi-selection is just a BUL chain (not manual multi-selection)
            let isOnlyBulChain = false;
            if (this.selectedObjects.length > 1 && this.selectedObjects.includes(clickedObject)) {
                // Check if all selected objects are part of the same BUL chain
                const allMergedLinks = this.getAllMergedLinks(clickedObject);
                isOnlyBulChain = this.selectedObjects.every(obj => allMergedLinks.includes(obj));
            }
            
            // If clicking on an already-selected object in TRUE multi-select (not just BUL chain), show bulk menu
            if (this.selectedObjects.length > 1 && this.selectedObjects.includes(clickedObject) && !isOnlyBulChain) {
                // Keep current multi-selection, show bulk operations menu
                this.showBulkContextMenu(e.clientX, e.clientY);
            } else {
                // Single selection OR BUL chain - replace selection with clicked object and its chain
                this.selectedObject = clickedObject;
                this.selectedObjects = [clickedObject];
                
                // ENHANCED: If selecting a merged UL, also add ALL partners in the BUL chain to selection
                if (isBulLink) {
                    const allMergedLinks = this.getAllMergedLinks(clickedObject);
                    allMergedLinks.forEach(link => {
                        if (!this.selectedObjects.includes(link)) {
                            this.selectedObjects.push(link);
                        }
                    });
                }
                
                // Show the new link selection toolbar instead of context menu
                this.showLinkSelectionToolbar(clickedObject);
                
                if (this.debugger) {
                    this.debugger.logSuccess(`🖱️ Right-click on link: Toolbar for ${clickedObject.id}`);
                }
            }
            
            this.draw();
            return;
        } else if (!clickedObject) {
            // Right-clicked on empty space (grid/background)
            // ALWAYS transition to base mode regardless of current mode
            // Clear any selection and hide toolbars
            if (this.selectedObjects.length > 0 || this.selectedObject) {
                this.selectedObjects = [];
                this.selectedObject = null;
            }
            this.hideAllSelectionToolbars();
            this.setMode('base');
            this.draw();
        }
    }
    
    // Helper to safely set element display
