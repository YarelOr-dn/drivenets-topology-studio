class OutputGenerator:
    """Generates output files for topology visualization"""
    
    def __init__(self):
        self.output_dir = OUTPUT_DIR
        self.output_dir.mkdir(parents=True, exist_ok=True)
    
    def generate_all(self, path: 'DNAASPath', devices: List['DeviceInfo'],
                     bd_summary: Optional[Dict] = None,
                     discovered_connections: Optional[List] = None) -> str:
        """Generate all output files and return the JSON filename"""
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        json_filename = f"dnaas_path_{timestamp}.json"
        json_path = self.output_dir / json_filename
        
        # Build topology data
        objects = []
        x_offset = 600
        y_offset = 500
        spacing = 200
        
        for i, hop in enumerate(path.hops):
            device_obj = {
                "id": f"device_{i}",
                "type": "device",
                "deviceType": "router" if hop.device_type == "PE" else "switch",
                "x": x_offset + (i * spacing),
                "y": y_offset,
                "radius": 45,
                "rotation": 0,
                "color": "#3498db" if hop.device_type == "PE" else "#e67e22",
                "label": hop.device_name,
                "locked": False,
                "visualStyle": "classic",
                "deviceSerial": hop.device_serial,
            }
            
            # Add SSH config if we have IP
            if hop.device_ip:
                device_obj["sshConfig"] = {
                    "host": hop.device_ip,
                    "hostBackup": hop.device_ip,
                    "user": "dnroot",
                    "password": "dnroot"
                }
            
            objects.append(device_obj)
        
        # Add links between hops
        for i in range(len(path.hops) - 1):
            link_obj = {
                "id": f"link_{i}",
                "type": "link",
                "device1": f"device_{i}",
                "device2": f"device_{i+1}",
                "width": 2,
                "color": "#7f8c8d",
                "style": "solid"
            }
            objects.append(link_obj)
        
        # Build output structure
        output_data = {
            "version": "1.0",
            "objects": objects,
            "metadata": {
                "name": "DNAAS Path Discovery",
                "created": datetime.now().isoformat(),
                "source": path.source_device,
                "destination": path.destination_device or "",
                "bridge_domains": list(bd_summary.keys()) if bd_summary else [],
                "bundles": {},
                "config_changes": []
            }
        }
        
        # Save JSON
        with open(json_path, 'w') as f:
            json.dump(output_data, f, indent=2)
        
        print(f"  {Colors.GREEN}Output saved: {json_filename}{Colors.ENDC}")
        return json_filename


