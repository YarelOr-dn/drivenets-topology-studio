def discover_device(serial: str, inventory: DeviceInventory, 
                    use_cache: bool = False,
                    ssh_user: str = DEFAULT_USER,
                    ssh_pass: str = DEFAULT_PASS) -> Optional[DeviceInfo]:
    """Discover a device by serial number"""
    
    # Check cache first if requested
    if use_cache:
        cached = inventory.get_device(serial)
        if cached:
            print(f"{Colors.CYAN}Using cached data for {serial}{Colors.ENDC}")
            return cached
    
    print(f"\n{Colors.HEADER}[DISCOVERY] {serial}{Colors.ENDC}")
    print("-" * 50)
    
    # Connect to device
    ssh = SSHConnection(serial, ssh_user, ssh_pass)
    if not ssh.connect():
        print(f"{Colors.RED}Failed to connect to {serial}{Colors.ENDC}")
        return None
    
    try:
        discovery = DeviceDiscovery(ssh)
        
        # Get hostname
        print("  Getting hostname...", flush=True)
        hostname = discovery.get_hostname()
        print(f"    Hostname: {Colors.GREEN}{hostname or 'Unknown'}{Colors.ENDC}")
        
        # Get system info
        print("  Getting system info...", flush=True)
        sys_info = discovery.get_system_info()
        print(f"    System Type: {sys_info.get('system_type', 'Unknown')}, Family: {sys_info.get('system_family', 'Unknown')}")
        print(f"    DNOS Version: {sys_info.get('dnos_version', 'Unknown')}")
        
        # Get management interfaces
        print("  Getting management interfaces...", flush=True)
        mgmt_interfaces = discovery.get_management_interfaces()
        print(f"    Found {len(mgmt_interfaces)} management interfaces")
        
        mgmt_ip, mgmt_ipv6 = discovery.get_primary_mgmt_ip(mgmt_interfaces)
        print(f"    Primary IPv4: {Colors.GREEN}{mgmt_ip or 'None'}{Colors.ENDC}")
        print(f"    Primary IPv6: {mgmt_ipv6 or 'None'}")
        
        # Get LLDP neighbors
        print("  Getting LLDP neighbors...", flush=True)
        neighbors = discovery.get_lldp_neighbors()
        print(f"    Found {len(neighbors)} LLDP neighbors")
        
        # Get interface descriptions
        print("  Getting interface descriptions...", flush=True)
        descriptions = discovery.get_interface_descriptions()
        
        # Detect DNAAS interfaces
        print("  Detecting DNAAS interfaces...", flush=True)
        dnaas_interfaces = discovery.detect_dnaas_interfaces(neighbors, descriptions)
        print(f"    Found {Colors.GREEN}{len(dnaas_interfaces)}{Colors.ENDC} DNAAS interfaces")
        
        # Get detailed interface info for each DNAAS interface
        interface_details = {}
        for iface in dnaas_interfaces[:5]:  # Limit to first 5 for speed
            print(f"    Getting details for {iface}...", flush=True)
            details = discovery.get_interface_details(iface)
            interface_details[iface] = details
        
        # Build device info
        device = DeviceInfo(
            serial=serial,
            hostname=hostname,
            mgmt_ip=mgmt_ip,
            mgmt_ipv6=mgmt_ipv6,
            system_type=sys_info.get('system_type', ''),
            dnos_version=sys_info.get('dnos_version', ''),
            dnaas_interfaces=dnaas_interfaces,
            lldp_neighbors=[asdict(n) for n in neighbors],
            all_mgmt_interfaces=[asdict(m) for m in mgmt_interfaces],
            interface_details=interface_details
        )
        
        # Save to inventory
        inventory.update_device(device)
        print(f"{Colors.GREEN}Inventory saved to {INVENTORY_FILE}{Colors.ENDC}")
        
        return device
        
    finally:
        ssh.close()


def main():
    """Main entry point"""
    parser = argparse.ArgumentParser(
        description="DNAAS Path Auto-Discovery with Bridge Domain Support",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  python3 dnaas_path_discovery.py wk31d7vv00023
  python3 dnaas_path_discovery.py wk31d7vv00023 100.64.0.220
  python3 dnaas_path_discovery.py --use-cache wk31d7vv00023
  python3 dnaas_path_discovery.py --multi-bd 100.64.7.186
  python3 dnaas_path_discovery.py --enable-lldp 100.64.7.186
  python3 dnaas_path_discovery.py --list-inventory
        """
    )
    
    parser.add_argument('serials', nargs='*', help='Device serial number(s) or IP addresses to discover')
    parser.add_argument('--use-cache', action='store_true', 
                        help='Use cached data if available')
    parser.add_argument('--list-inventory', action='store_true',
                        help='List all devices in inventory')
    parser.add_argument('--list-credentials', action='store_true',
                        help='List all stored device credentials')
    parser.add_argument('--multi-bd', action='store_true',
                        help='Discover all Bridge Domains from source device')
    parser.add_argument('--enable-lldp', action='store_true',
                        help='Enable LLDP and admin-state on physical interfaces')
    parser.add_argument('--bd-aware', action='store_true',
                        help='Use BD-aware tracing (auto-configures DUT interfaces)')
    parser.add_argument('--no-auto-config', action='store_true',
                        help='Skip auto-configuration of DUT interfaces (use with --bd-aware)')
    parser.add_argument('--user', default=DEFAULT_USER, help='SSH username')
    parser.add_argument('--password', default=DEFAULT_PASS, help='SSH password')
    
    args = parser.parse_args()
    
    # Initialize inventory
    inventory = DeviceInventory()
    
    # List inventory if requested
    if args.list_inventory:
        devices = inventory.list_devices()
        if devices:
            print(f"\n{Colors.HEADER}Device Inventory ({len(devices)} devices){Colors.ENDC}")
            print("-" * 50)
            for serial in devices:
                device = inventory.get_device(serial)
                if device:
                    print(f"  {Colors.CYAN}{serial}{Colors.ENDC}: {device.hostname or 'Unknown'} ({device.mgmt_ip})")
        else:
            print("No devices in inventory.")
        return
    
    # List credentials if requested
    if args.list_credentials:
        creds = credential_manager.list_devices()
        if creds:
            print(f"\n{Colors.HEADER}Stored Credentials ({len(creds)} devices){Colors.ENDC}")
            print("-" * 50)
            for cred in creds:
                device_type = cred.get('device_type', 'DUT')
                type_color = Colors.BLUE if device_type == 'DUT' else Colors.YELLOW
                print(f"  {type_color}[{device_type}]{Colors.ENDC} {cred['hostname']} ({cred['mgmt_ip']})")
                print(f"         Last used: {cred.get('last_used', 'Never')[:19]}")
        else:
            print("No stored credentials.")
        return
    
    # Check for serial numbers
    if not args.serials:
        parser.print_help()
        print(f"\n{Colors.RED}Error: At least one serial number or IP is required{Colors.ENDC}")
        sys.exit(1)
    
    # Use provided credentials
    ssh_user = args.user
    ssh_pass = args.password
    
    # Handle --enable-lldp option
    if args.enable_lldp:
        device_ip = args.serials[0]
        print(f"\n{Colors.BOLD}{Colors.HEADER}ENABLING LLDP on {device_ip}{Colors.ENDC}")
        print("=" * 70)
        
        ssh = SSHConnection(device_ip, ssh_user, ssh_pass)
        if not ssh.connect():
            print(f"{Colors.RED}Failed to connect to {device_ip}{Colors.ENDC}")
            sys.exit(1)
        
        try:
            print(f"  {Colors.CYAN}Enabling LLDP globally...{Colors.ENDC}")
            ssh.send_command("configure")
            ssh.send_command("protocols lldp")
            ssh.send_command("admin-state enable")
            ssh.send_command("exit")  # Exit lldp context
            
            print(f"  {Colors.CYAN}Getting physical interfaces...{Colors.ENDC}")
            # Get interfaces that are physical (ge400, ge100, eth, hu, ce, qsfp patterns)
            output = ssh.send_command("show interfaces brief | no-more", timeout=30)
            
            # Match physical interfaces only (no sub-interfaces with dots)
            physical_pattern = re.compile(r'^(ge\d+-\d+/\d+/\d+|eth-\d+/\d+/\d+|hu\d+-\d+/\d+/\d+|ce\d+-\d+/\d+/\d+|qsfp\d+-\d+/\d+/\d+)\s', re.MULTILINE)
            
            interfaces = physical_pattern.findall(output)
            interfaces = list(set(interfaces))  # Remove duplicates
            
            if interfaces:
                print(f"  {Colors.GREEN}Found {len(interfaces)} physical interfaces{Colors.ENDC}")
                for iface in interfaces:
                    print(f"    Configuring {iface}...")
                    ssh.send_command(f"interfaces {iface}")
                    ssh.send_command("admin-state enabled")
                    ssh.send_command("exit")  # Exit interface context
                
                print(f"  {Colors.CYAN}Committing changes...{Colors.ENDC}")
                ssh.send_command("commit")
                print(f"  {Colors.GREEN}Configuration committed successfully!{Colors.ENDC}")
                print(f"\n{Colors.GREEN}LLDP enabled on {len(interfaces)} physical interfaces!{Colors.ENDC}")
            else:
                print(f"  {Colors.YELLOW}No physical interfaces found to configure{Colors.ENDC}")
        except Exception as e:
            print(f"{Colors.RED}Error during LLDP configuration: {e}{Colors.ENDC}")
            sys.exit(1)
        finally:
            ssh.close()
        sys.exit(0)
    
    # Handle --multi-bd discovery
    if args.multi_bd:
        source_serial = args.serials[0]
        print(f"\n{Colors.BOLD}{Colors.HEADER}MULTI-BD DNAAS DISCOVERY{Colors.ENDC}")
        print("=" * 70)
        print(f"Source device: {source_serial}")
        print("=" * 70)
        
        # Load DNAAS table
        dnaas_table = DNAASTable()
        print(f"{Colors.GREEN}Loaded {len(dnaas_table.devices)} DNAAS devices from table{Colors.ENDC}")
        
        # Create path tracer
        tracer = PathTracer(inventory, dnaas_table)
        
        # Discover the source device first
        device = discover_device(source_serial, inventory, args.use_cache, ssh_user, ssh_pass)
        
        if device:
            # Check if we have LLDP neighbors - if not, fail early with clear message
            if not device.lldp_neighbors:
                print(f"\n{Colors.RED}✗ Found 0 LLDP neighbors on {device.hostname or source_serial}{Colors.ENDC}")
                print(f"{Colors.RED}No LLDP neighbors detected - cannot discover DNAAS fabric{Colors.ENDC}")
                print(f"\n{Colors.YELLOW}Tip: LLDP must be enabled on the device interfaces{Colors.ENDC}")
                print(f"{Colors.YELLOW}Run: python3 dnaas_path_discovery.py --enable-lldp {source_serial}{Colors.ENDC}")
                sys.exit(1)  # Exit with error to trigger UI dialog
            
            # Check if any neighbors are DNAAS devices
            dnaas_neighbors = [n for n in device.lldp_neighbors if n.get('is_dnaas', False)]
            if not dnaas_neighbors:
                print(f"\n{Colors.RED}✗ Found 0 DNAAS neighbors on {device.hostname or source_serial}{Colors.ENDC}")
                print(f"{Colors.RED}Found {len(device.lldp_neighbors)} LLDP neighbors but none are DNAAS infrastructure{Colors.ENDC}")
                print(f"\n{Colors.YELLOW}Tip: Device may not be connected to DNAAS fabric{Colors.ENDC}")
                sys.exit(1)  # Exit with error
            
            # Use BD-aware path trace for multi-BD discovery
            auto_config = not args.no_auto_config
            path = tracer.trace_bd_path(source_serial, auto_configure=auto_config)
            
            # Get BD summary
            bd_summary = tracer.get_bd_summary()
            
            # Check if we actually discovered anything beyond source device
            # path.hops always has source as first hop, so we need > 1 for real discovery
            real_discovery = len(path.hops) > 1 or path.success
            
            if real_discovery:
                print(f"\n{Colors.GREEN}Multi-BD Discovery Complete!{Colors.ENDC}")
                print(f"Discovered {len(path.hops)} hops")
                for hop in path.hops:
                    print(f"  - {hop.device_name} ({hop.device_type})")
                
                # Generate outputs
                output_gen = OutputGenerator()
                discovered_connections = getattr(tracer, 'discovered_connections', [])
                output_gen.generate_all(path, [device], bd_summary, discovered_connections)
                
                print(f"\n{Colors.GREEN}Multi-BD output saved!{Colors.ENDC}")
            else:
                # Discovery didn't find any DNAAS infrastructure path
                print(f"\n{Colors.YELLOW}{path.error_message or 'Discovery incomplete - no DNAAS neighbors found'}{Colors.ENDC}")
                print(f"{Colors.YELLOW}Tip: Make sure LLDP is enabled on the device interfaces{Colors.ENDC}")
                # Still exit 0 since we got some info, but log the issue
                output_gen = OutputGenerator()
                output_gen.generate_all(path, [device], bd_summary, [])
                print(f"{Colors.YELLOW}Partial results saved{Colors.ENDC}")
        else:
            print(f"\n{Colors.RED}Failed to discover source device{Colors.ENDC}")
            sys.exit(1)
        
        return
    
    # Standard discovery flow
    print(f"\n{Colors.BOLD}{Colors.HEADER}DNAAS PATH AUTO-DISCOVERY{Colors.ENDC}")
    print("=" * 70)
    print(f"Devices to discover: {', '.join(args.serials)}")
    print(f"Use cache: {args.use_cache}")
    print("=" * 70)
    
    # Discover all devices
    discovered_devices = []
    for serial in args.serials:
        device = discover_device(serial, inventory, args.use_cache, ssh_user, ssh_pass)
        if device:
            discovered_devices.append(device)
    
    if not discovered_devices:
        print(f"\n{Colors.RED}Failed to connect - No devices discovered successfully{Colors.ENDC}")
        print(f"{Colors.RED}Please check the device serial/hostname and network connectivity{Colors.ENDC}")
        sys.exit(1)
    
    # Load DNAAS table and trace path
    dnaas_table = DNAASTable()
    tracer = PathTracer(inventory, dnaas_table)
    
    # Choose tracing method based on --bd-aware flag
    bd_summary = None
    if args.bd_aware:
        print(f"\n{Colors.HEADER}Using BD-Aware Path Tracing{Colors.ENDC}")
        auto_config = not args.no_auto_config
        
        if len(args.serials) == 1:
            path = tracer.trace_bd_path(args.serials[0], auto_configure=auto_config)
        else:
            path = tracer.trace_bd_path(args.serials[0], args.serials[1], 
                                         auto_configure=auto_config)
        
        # Get BD summary
        bd_summary = tracer.get_bd_summary()
    else:
        # Standard tracing (LLDP-only)
        if len(args.serials) == 1:
            path = tracer.trace_path(args.serials[0])
        else:
            path = tracer.trace_path(args.serials[0], args.serials[1])
    
    # Generate outputs
    output_gen = OutputGenerator()
    discovered_connections = getattr(tracer, 'discovered_connections', [])
    output_gen.generate_all(path, discovered_devices, bd_summary, discovered_connections)
    
    print(f"\n{Colors.GREEN}Discovery complete!{Colors.ENDC}")


