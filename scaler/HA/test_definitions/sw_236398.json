    {
      "id": "test_14",
      "name": "LOFD Simulation (NCF Admin-Disable)",
      "category": "special",
      "jira_ref": "SW-236398 Test 14",
      "requires_cluster": true,
      "ha_command": "LOFD_NCF_ADMIN_DISABLE",
      "ha_type": "lofd",
      "requires_config_mode": true,
      "kills_ssh": false,
      "lofd_disable_duration_sec": 30,
      "config_commands": ["configure", "system", "ncf {ncf_id}", "admin-state disabled", "commit"],
      "recovery_commands": ["configure", "system", "ncf {ncf_id}", "admin-state enabled", "commit"],
      "recovery_fallback_commands": ["configure", "system", "ncf {ncf_id}", "no admin-state", "commit"],
      "expected_recovery_sec": 90,
      "max_recovery_sec": 300,
      "expected_bgp_drop": false,
      "expected_rules_survive": true,
      "expected_traffic_loss": true,
      "pre_safety_check": ["verify_ncf_up", "verify_single_ncf_warning"],
      "recovery_description": "NCF re-enabled after LOFD simulation. Always reverts admin-state to enabled, even on failure.",
      "pre_steps": [],
      "post_verify": [
        "show system",
        "show flowspec ncp",
        "show flowspec instance vrf ALPHA ipv4",
        "show bgp ipv4 flowspec-vpn summary",
        "show system detail"
      ]
    },
