{
  "jira_key": "SW-236398",
  "title": "FlowSpec VPN | HA",
  "description": "15 HA test cases for FlowSpec-VPN from Jira SW-236398",
  "tests": [
    {
      "id": "test_01",
      "name": "RIB Manager Process Restart",
      "category": "process_restart",
      "jira_ref": "SW-236398 Test 1",
      "ha_command": "request system process restart ncc 0 routing-engine routing:rib_manager",
      "ha_type": "process_restart",
      "kills_ssh": false,
      "expected_recovery_sec": 30,
      "max_recovery_sec": 120,
      "expected_bgp_drop": false,
      "expected_rules_survive": true,
      "expected_traffic_loss": false,
      "pre_steps": [],
      "post_verify": [
        "show bgp ipv4 flowspec-vpn routes",
        "show flowspec ncp",
        "show flowspec instance vrf ALPHA ipv4",
        "show system detail"
      ]
    },
