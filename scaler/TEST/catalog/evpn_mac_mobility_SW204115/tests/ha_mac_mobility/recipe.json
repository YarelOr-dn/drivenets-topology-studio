{
  "id": "TEST_mac_mob_ha_SW205165",
  "name": "MAC Mobility | HA - switchovers and restarts",
  "type": "ha",
  "feature": "evpn-mac-mobility",
  "source": "jira:SW-204115 / SW-205165",
  "jira_key": "SW-205165",
  "parent_category": "SW-204115",
  "created": "2026-03-20",
  "device_requirements": {
    "type": "cluster",
    "features": ["evpn", "ncc-redundancy"],
    "min_ncp_count": 1,
    "requires_standby_ncc": true
  },
  "dnos_process_mapping": {
    "bgp": "routing:bgpd",
    "fibmgrd": "routing:fibmgrd",
    "rib_manager": "routing:rib_manager",
    "neighbour_manager": "neighbour_manager"
  },
  "ha_trigger_commands": {
    "bgp_restart": "request system process restart ncc {active_ncc_id} routing-engine routing:bgpd",
    "fibmgrd_restart": "request system process restart ncc {active_ncc_id} routing-engine routing:fibmgrd",
    "ncc_switchover": "request system ncc switchover"
  },
  "show_commands_validated": {
    "show evpn mac-table instance {evpn_name} | no-more": "SHOW_COMMANDS line 10089 -- MAC entries for specific instance",
    "show bgp l2vpn evpn summary | no-more": "BGP L2VPN EVPN session summary",
    "show system | no-more": "System info, node table, NCC/NCP status",
    "show evpn instance {evpn_name} detail | no-more": "Detailed instance info for HA comparison",
    "show evpn mac-table detail instance {evpn_name} | no-more": "Detailed MAC table with sequence numbers",
    "show evpn forwarding-table mac-address-table instance {evpn_name} | no-more": "Datapath-level MAC entries for NCP sync check",
    "show dnos-internal routing evpn mac-mobility-redis-count | no-more": "MAC mobility redis counter for HA",
    "show dnos-internal routing evpn instance {evpn_name} mac-table-ghost | no-more": "Ghost MAC detection",
    "show dnos-internal routing fib-manager database evpn local-mac service-instance {evpn_name} | no-more": "FIB programming state"
  },
  "invalid_commands": {
    "show evpn mac-table evi {evi}": "DOES NOT EXIST. Use: show evpn mac-table instance {name}",
    "show interfaces brief": "DOES NOT EXIST. Use: show interfaces description"
  },
  "scenarios": [
    {
      "id": "SC01_ncc_switchover_mac_history",
      "name": "NCC switchover during MAC mobility; history counters / sequencing",
      "phases": {
        "before_snapshot": {
          "show_commands": [
            "show evpn mac-table instance {evpn_name} | no-more",
            "show bgp l2vpn evpn summary | no-more",
            "show system | no-more"
          ]
        },
        "trigger": {"ha_command": "request system ncc switchover", "ha_type": "ncc_switchover"},
        "poll_recovery": {"timeout_sec": 180, "poll_interval_sec": 15, "reconnect_delay_sec": 45},
        "after_snapshot": {
          "show_commands": [
            "show evpn mac-table instance {evpn_name} | no-more",
            "show bgp l2vpn evpn summary | no-more",
            "show system | no-more"
          ]
        },
        "verify": {"expect": {"history_consistent": true, "check_mac_flags": true, "forbidden_flags": ["F", "D"], "check_forwarding": true, "check_ghost_macs": true, "check_mobility_counter": true, "check_rt2_recovery": true, "check_ha_traffic": true, "cross_layer_check": true, "xray_on_mismatch": true}}
      }
    },
    {
      "id": "SC02_bgpd_restart_sequencing",
      "name": "routing:bgpd restart; MAC table / RT-2 sequencing after recovery",
      "phases": {
        "before_snapshot": {"show_commands": ["show evpn mac-table instance {evpn_name} | no-more", "show bgp l2vpn evpn summary | no-more"]},
        "trigger": {"ha_command": "request system process restart ncc {active_ncc_id} routing-engine routing:bgpd", "ha_type": "process_restart"},
        "poll_recovery": {"timeout_sec": 120, "poll_interval_sec": 10},
        "after_snapshot": {"show_commands": ["show evpn mac-table instance {evpn_name} | no-more"]},
        "verify": {"expect": {"check_mac_flags": true, "forbidden_flags": ["F", "D"], "check_forwarding": true, "check_ghost_macs": true, "check_mobility_counter": true, "check_rt2_recovery": true, "check_ha_traffic": true}}
      }
    },
    {
      "id": "SC03_fibmgrd_restart",
      "name": "routing:fibmgrd restart; datapath reprogram",
      "phases": {
        "before_snapshot": {"show_commands": ["show evpn mac-table instance {evpn_name} | no-more"]},
        "trigger": {"ha_command": "request system process restart ncc {active_ncc_id} routing-engine routing:fibmgrd", "ha_type": "process_restart"},
        "poll_recovery": {"timeout_sec": 120, "poll_interval_sec": 10},
        "verify": {"expect": {"history_consistent": true, "check_mac_flags": true, "forbidden_flags": ["F", "D"], "check_forwarding": true, "check_ghost_macs": true, "check_mobility_counter": true, "check_ha_traffic": true}}
      }
    },
    {
      "id": "SC04_ncp_warm_restart",
      "name": "NCP warm restart; MAC relearn / TCAM reprogram",
      "phases": {
        "before_snapshot": {"show_commands": ["show evpn mac-table instance {evpn_name} | no-more"]},
        "trigger": {"action": "ncp_warm_restart", "command": "request system process restart ncp {ncp_id} forwarding-engine wb_agent"},
        "poll_recovery": {"timeout_sec": 180, "poll_interval_sec": 15},
        "verify": {"expect": {"history_consistent": true, "check_mac_flags": true, "forbidden_flags": ["F", "D"], "check_forwarding": true, "check_ghost_macs": true, "check_mobility_counter": true, "check_ha_traffic": true}}
      }
    },
    {
      "id": "SC05_restart_during_flap",
      "name": "Process restart during active MAC flapping; suppression state",
      "phases": {
        "before_snapshot": {"show_commands": ["show evpn mac-table instance {evpn_name} | no-more"]},
        "trigger": {"action": "parallel_flap_and_restart", "command": "request system process restart ncc {active_ncc_id} routing-engine routing:bgpd"},
        "poll_recovery": {"timeout_sec": 120, "poll_interval_sec": 10, "reconnect_delay_sec": 10},
        "verify": {"expect": {"no_stuck_blackhole": true, "check_mac_flags": true, "forbidden_flags": ["F", "D"], "check_forwarding": true, "check_ghost_macs": true, "check_mobility_counter": true, "check_ha_traffic": true}}
      }
    }
  ],
  "runtime_parameters": {
    "evpn_name": {"resolve": "runtime"},
    "active_ncc_id": {"resolve": "runtime", "from": "show system"}
  },
  "verdict": {"layers": 14, "stop_on_fail": false},
  "counter_commands": [
    {"label": "mac_count", "command": "show evpn mac summary | no-more", "parser": "first_integer", "description": "Total EVPN MAC count"},
    {"label": "fwd_table_count", "command": "show evpn forwarding-table mac-address-table instance {evpn_name} | no-more", "parser": "line_count", "description": "NCP forwarding table count"},
    {"label": "ghost_mac_count", "command": "show dnos-internal routing evpn instance {evpn_name} mac-table-ghost | no-more", "parser": "line_count", "description": "Ghost MAC count"}
  ],
  "counter_expectations": [
    {"label": "mac_count", "rule": "no_decrease", "description": "MAC count must recover after HA"},
    {"label": "fwd_table_count", "rule": "no_decrease", "description": "Forwarding table must recover"},
    {"label": "ghost_mac_count", "rule": "zero", "description": "No ghost MACs after recovery"}
  ],
  "event_expectations": [
    {"event": "BGP_NEIGHBOR_ESTABLISHED", "expect": "present", "min_count": 1, "description": "BGP should re-establish"},
    {"event": "SYSTEM_PROCESS_RESTART", "expect": "present", "min_count": 1, "description": "Process restart expected"}
  ],
  "health_checks": {
    "processes": ["routing:bgpd", "routing:fibmgrd", "routing:rib_manager", "neighbour_manager"],
    "check_crashes": true,
    "check_alarms": true
  },
  "cleanup_commands": ["no debug evpn mac-mobility", "no debug evpn mac-learning", "no set logging terminal"],
  "config_baseline": {
    "sections": ["network-services evpn", "protocols bgp"],
    "full_config": false,
    "ignore_patterns": ["last-modified", "commit-id"]
  }
}
