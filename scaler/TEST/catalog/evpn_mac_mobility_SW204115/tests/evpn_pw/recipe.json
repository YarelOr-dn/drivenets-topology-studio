{
  "id": "TEST_mac_mob_evpn_pw_SW205162",
  "name": "MAC Mobility | Remote EVPN <-> PW | Sticky/Non-sticky",
  "type": "functional",
  "feature": "evpn-mac-mobility",
  "source": "jira:SW-204115 / SW-205162",
  "jira_key": "SW-205162",
  "parent_category": "SW-204115",
  "created": "2026-03-20",
  "reference_table": "EVPN<->PW: Remote<->PW NOT counted; sticky EVPN->PW IGNORE (blackhole risk); PW->sticky EVPN accept static sticky",
  "device_requirements": {"type": "any", "features": ["evpn", "vpls-pw"], "min_ncp_count": 1},
  "show_commands_validated": {
    "show evpn mac-table instance {evpn_name} mac {test_mac} | no-more": "SHOW_COMMANDS line 10091 -- Single MAC lookup",
    "show evpn forwarding-table mac-address-table instance {evpn_name} | no-more": "NCP forwarding state and flags",
    "show dnos-internal routing evpn instance {evpn_name} mac-table-ghost | no-more": "Ghost MAC detection",
    "show dnos-internal routing fib-manager database evpn local-mac service-instance {evpn_name} | no-more": "FIB programming state"
  },
  "invalid_commands": {
    "show evpn mac-table evi {evi}": "DOES NOT EXIST. Use: show evpn mac-table instance {name}",
    "show interfaces brief": "DOES NOT EXIST. Use: show interfaces description"
  },
  "prerequisites": [
    {"id": "pw", "check": "pseudowire_configured", "fix_via": "VPLS PW under service"},
    {"id": "remote_evpn", "check": "bgp_evpn_peer", "fix_via": "Remote PE with RT-2"}
  ],
  "scenarios": [
    {
      "id": "SC01_evpn_to_pw",
      "name": "Non-sticky: remote EVPN -> PW; no RT change; not counted",
      "phases": {
        "snapshot": {"show_commands": ["show evpn mac-table instance {evpn_name} mac {test_mac} | no-more"]},
        "trigger": {"action": "move_evpn_to_pw"},
        "verify": {"expect": {"suppression_not_incremented": true, "check_mac_flags": true, "forbidden_flags": ["F", "D"], "check_forwarding": true, "check_ghost_macs": true, "check_mobility_counter": true}}
      }
    },
    {
      "id": "SC02_pw_to_evpn",
      "name": "PW -> EVPN; accept; static entry",
      "phases": {
        "trigger": {"action": "move_pw_to_evpn"},
        "verify": {"show_commands": ["show evpn mac-table instance {evpn_name} mac {test_mac} | no-more"], "expect": {"static_hint": true, "check_mac_flags": true, "forbidden_flags": ["F", "D"], "check_forwarding": true, "check_ghost_macs": true}}
      }
    },
    {
      "id": "SC03_sticky_evpn_to_pw",
      "name": "Sticky EVPN RT-2 -> PW; IGNORE move (blackholing risk)",
      "phases": {
        "verify": {"expect": {"move_ignored": true, "sticky_evpn_kept": true, "check_mac_flags": true, "check_forwarding": true, "check_ghost_macs": true}}
      }
    },
    {
      "id": "SC04_pw_to_sticky_evpn",
      "name": "PW -> Sticky EVPN; accept; datapath static sticky",
      "phases": {
        "verify": {"expect": {"accept_sticky_static": true, "check_mac_flags": true, "check_forwarding": true, "check_ghost_macs": true}}
      }
    }
  ],
  "runtime_parameters": {
    "evpn_name": {"resolve": "runtime"},
    "test_mac": {"resolve": "runtime"}
  },
  "verdict": {"layers": 8, "stop_on_fail": false},
  "counter_commands": [
    {"label": "mac_count", "command": "show evpn mac summary | no-more", "parser": "first_integer", "description": "Total EVPN MAC count"},
    {"label": "ghost_mac_count", "command": "show dnos-internal routing evpn instance {evpn_name} mac-table-ghost | no-more", "parser": "line_count", "description": "Ghost MAC count"}
  ],
  "counter_expectations": [
    {"label": "mac_count", "rule": "no_decrease", "description": "MAC count must not drop"},
    {"label": "ghost_mac_count", "rule": "zero", "description": "No ghost MACs after scenario"}
  ],
  "event_expectations": [
    {"event": "BGP_NOTIFICATION", "expect": "absent", "description": "No BGP notifications"},
    {"event": "L2_MAC_MOBILITY_MAC_ADDRESS_SUPPRESSED", "expect": "absent", "description": "No suppression on normal operations"}
  ],
  "health_checks": {
    "processes": ["routing:bgpd", "routing:fibmgrd", "routing:rib_manager", "neighbour_manager"],
    "check_crashes": true,
    "check_alarms": true
  },
  "cleanup_commands": ["no debug evpn mac-mobility", "no set logging terminal"],
  "config_baseline": {
    "sections": ["network-services evpn", "protocols bgp"],
    "full_config": false,
    "ignore_patterns": ["last-modified", "commit-id"]
  }
}
