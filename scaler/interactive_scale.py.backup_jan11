def _show_multi_device_action_menu(multi_ctx: 'MultiDeviceContext', primary_device) -> str:
    """
    Show enhanced multi-device action menu with split view of both devices.
    
    Args:
        multi_ctx: MultiDeviceContext with selected devices
        primary_device: Primary device for reference
    
    Returns:
        Action string: 'configure', 'delete', 'modify_interfaces', 'compare',
                       'sync_status', 'push', 'refresh', 'exit'
    """
    from rich.columns import Columns
    from rich.panel import Panel
    
    console.print(f"\n[bold cyan]{'═' * 80}[/bold cyan]")
    console.print(f"[bold cyan]Multi-Device Actions[/bold cyan]")
    console.print(f"[bold cyan]{'═' * 80}[/bold cyan]")
    
    # Build side-by-side device panels
    panels = []
    for dev in multi_ctx.devices:
        h = dev.hostname
        lo = multi_ctx.loopbacks.get(h, "N/A")
        asn = multi_ctx.bgp_asn.get(h, 0)
        rt_count = len(multi_ctx.route_targets.get(h, set()))
        mh_count = len(multi_ctx.mh_config.get(h, {}))
        iface_count = len(multi_ctx.interfaces.get(h, []))
        summary = multi_ctx.summaries.get(h)
        
        lines = []
        
        # Loopback & ASN
        lines.append(f"[cyan]Loopback:[/cyan] {lo}")
        lines.append(f"[cyan]BGP AS:[/cyan] {asn}")
        
        # Services summary
        if summary and summary.services:
            svc_parts = []
            for svc_type, (up, total, _) in summary.services.items():
                if up == total:
                    svc_parts.append(f"[green]{svc_type}: {up}/{total}[/green]")
                elif up > 0:
                    svc_parts.append(f"[yellow]{svc_type}: {up}/{total}[/yellow]")
                else:
                    svc_parts.append(f"[red]{svc_type}: {up}/{total}[/red]")
            if svc_parts:
                lines.append(f"[cyan]Services:[/cyan] " + ", ".join(svc_parts[:2]))
                if len(svc_parts) > 2:
                    lines.append(f"          " + ", ".join(svc_parts[2:]))
        
        # Counts
        lines.append(f"[cyan]RTs:[/cyan] {rt_count:,}")
        lines.append(f"[cyan]Interfaces:[/cyan] {iface_count:,}")
        
        # MH status
        if mh_count > 0:
            lines.append(f"[green]Multihoming:[/green] {mh_count:,} ESIs")
        else:
            lines.append(f"[dim]Multihoming:[/dim] Not configured")
        
        # Uptime if available
        if summary and summary.uptime:
            lines.append(f"[dim]Uptime: {summary.uptime}[/dim]")
        
        # Determine panel color
        if mh_count > 0 and rt_count > 0:
            border_style = "green"
        elif rt_count > 0:
            border_style = "cyan"
        else:
            border_style = "yellow"
        
        panel = Panel(
            "\n".join(lines),
            title=f"[bold white]{h}[/bold white]",
            subtitle=f"[dim]{dev.ip}[/dim]",
            border_style=border_style,
            expand=True,
            padding=(0, 1)
        )
        panels.append(panel)
    
    # Show devices side-by-side
    console.print(Columns(panels, expand=True, equal=True))
    
    # Show sync status
    shared_pairs = multi_ctx.get_shared_evpn_peers()
    if shared_pairs:
        console.print(f"\n[bold cyan]🔗 Sync Status:[/bold cyan]")
        for h1, h2, shared_rt in shared_pairs:
            mh1 = len(multi_ctx.mh_config.get(h1, {}))
            mh2 = len(multi_ctx.mh_config.get(h2, {}))
            if mh1 > 0 and mh2 > 0 and mh1 == mh2:
                sync_icon = "[green]✓ Synced[/green]"
            elif mh1 > 0 and mh2 > 0:
                sync_icon = f"[yellow]⚠ MH: {mh1} vs {mh2}[/yellow]"
            elif mh1 > 0 or mh2 > 0:
                sync_icon = "[yellow]⚠ MH mismatch[/yellow]"
            else:
                sync_icon = "[dim]○ No MH[/dim]"
            console.print(f"  {h1} ↔ {h2}: [cyan]{shared_rt:,} shared RTs[/cyan] • {sync_icon}")
    
    console.print()
    
    # Determine default based on last action (stored in multi_ctx)
    last_action = getattr(multi_ctx, '_last_menu_action', '8')  # Default to Image Upgrade
    
    # Action menu - Status/View operations first, then config actions
    console.print("[bold]Status & View:[/bold]")
    console.print("  [1] Compare Configurations - Show detailed diff")
    console.print("  [2] Sync Status - Detailed synchronization analysis")
    console.print("  [3] Push Files - Push saved config files to all devices")
    console.print("  [4] [cyan]Stag Pool Check[/cyan] - Live QinQ Stag usage from Linux shell")
    console.print("  [R] Refresh - Reload configs from all devices")
    console.print()
    console.print("[bold]Configuration Actions:[/bold]")
    console.print("  [5] [green]Configure[/green] - Full configuration wizard (select device)")
    console.print("  [6] [red]Delete Hierarchy[/red] - Delete config sections from all devices")
    console.print("  [7] [yellow]Modify Service Interfaces[/yellow] - Add/remove/remap interfaces at scale")
    console.print("  [8] [magenta]Image Upgrade[/magenta] - Upgrade DNOS/GI/BaseOS from Jenkins")
    console.print("  [9] [bold orange3]Scale Up/Down[/bold orange3] - Bulk add/delete services with correlated interfaces")
    console.print("  [M] [bold bright_magenta]🪞 Mirror Config[/bold bright_magenta] - Copy config from another PE")
    console.print("  [B] Back to device selection")
    
    choice = Prompt.ask(
        "Select action",
        choices=["1", "2", "3", "4", "5", "6", "7", "8", "9", "m", "M", "r", "R", "b", "B"],
        default=last_action
    ).lower()
    
    # Remember this choice for next time (except for view-only actions)
    if choice not in ['1', '2', 'r']:
        multi_ctx._last_menu_action = choice
    
    action_map = {
        "1": "compare",
        "2": "sync_status",
        "3": "push",
        "4": "stag_check",
        "5": "configure",
        "6": "delete",
        "7": "modify_interfaces",
        "8": "image_upgrade",
        "9": "scale_updown",
        "m": "mirror_config",
        "r": "refresh",
        "b": "exit",
    }
    
    return action_map.get(choice, "configure")


def _show_multi_device_compare(multi_ctx: 'MultiDeviceContext'):
    """Compare configurations between devices in multi-device mode - detailed view."""
    from rich.columns import Columns
    from rich.panel import Panel
    
    console.print("\n[bold cyan]═══════════════════════════════════════════════════════════════════[/bold cyan]")
    console.print("[bold cyan]              📊 Multi-Device Configuration Comparison              [/bold cyan]")
    console.print("[bold cyan]═══════════════════════════════════════════════════════════════════[/bold cyan]")
    
    if len(multi_ctx.devices) < 2:
        console.print("[yellow]Need at least 2 devices to compare.[/yellow]")
        return
    
    dev1, dev2 = multi_ctx.devices[0], multi_ctx.devices[1]
    h1, h2 = dev1.hostname, dev2.hostname
    
    # ═══════════════════════════════════════════════════════════════════════
    # SECTION 1: System Info Comparison
    # ═══════════════════════════════════════════════════════════════════════
    console.print("\n[bold]━━━ System Information ━━━[/bold]")
    
    sum1 = multi_ctx.summaries.get(h1, DeviceSummary())
    sum2 = multi_ctx.summaries.get(h2, DeviceSummary())
    
    sys_table = Table(box=box.SIMPLE, show_header=True)
    sys_table.add_column("Property", style="cyan", width=20)
    sys_table.add_column(h1, width=30)
    sys_table.add_column(h2, width=30)
    sys_table.add_column("Match", justify="center", width=8)
    
    # DNOS Version
    v1, v2 = sum1.dnos_version or "N/A", sum2.dnos_version or "N/A"
    match = "[green]✓[/green]" if v1 == v2 else "[yellow]≠[/yellow]"
    sys_table.add_row("DNOS Version", v1, v2, match)
    
    # System Type
    t1, t2 = sum1.system_type or "N/A", sum2.system_type or "N/A"
    match = "[green]✓[/green]" if t1 == t2 else "[yellow]≠[/yellow]"
    sys_table.add_row("System Type", t1, t2, match)
    
    # Uptime
    u1, u2 = sum1.uptime or "N/A", sum2.uptime or "N/A"
    sys_table.add_row("Uptime", u1, u2, "[dim]-[/dim]")
    
    # BGP ASN
    asn1, asn2 = multi_ctx.bgp_asn.get(h1, 0), multi_ctx.bgp_asn.get(h2, 0)
    match = "[green]✓[/green]" if asn1 == asn2 else "[red]✗[/red]"
    sys_table.add_row("BGP ASN", str(asn1) if asn1 else "N/A", str(asn2) if asn2 else "N/A", match)
    
    # Loopback
    lo1, lo2 = multi_ctx.loopbacks.get(h1, "N/A"), multi_ctx.loopbacks.get(h2, "N/A")
    sys_table.add_row("Loopback IP", lo1, lo2, "[dim]-[/dim]")
    
    console.print(sys_table)
    
    # ═══════════════════════════════════════════════════════════════════════
    # SECTION 2: Scale Comparison
    # ═══════════════════════════════════════════════════════════════════════
    console.print("\n[bold]━━━ Scale & Counts ━━━[/bold]")
    
    # Gather data
    rt1 = multi_ctx.route_targets.get(h1, set())
    rt2 = multi_ctx.route_targets.get(h2, set())
    ifaces1 = set(multi_ctx.interfaces.get(h1, []))
    ifaces2 = set(multi_ctx.interfaces.get(h2, []))
    mh1 = multi_ctx.mh_config.get(h1, {})
    mh2 = multi_ctx.mh_config.get(h2, {})
    
    # Categorize interfaces
    pwhe1 = {i for i in ifaces1 if i.startswith('ph')}
    pwhe2 = {i for i in ifaces2 if i.startswith('ph')}
    l2_1 = {i for i in ifaces1 if re.match(r'^[gx]e[\d\-/]+\.\d+', i)}
    l2_2 = {i for i in ifaces2 if re.match(r'^[gx]e[\d\-/]+\.\d+', i)}
    bundle1 = {i for i in ifaces1 if 'lag' in i.lower() or 'ae' in i.lower()}
    bundle2 = {i for i in ifaces2 if 'lag' in i.lower() or 'ae' in i.lower()}
    
    # Parse services from config
    def count_services(config: str) -> dict:
        fxc = len(re.findall(r'flexible-cross-connect-group', config))
        l2vpn = len(re.findall(r'l2vpn-instance\s+\S+', config))
        evpn = len(re.findall(r'evpn-instance\s+\S+', config))
        vpws = len(re.findall(r'vpws-instance', config))
        return {'fxc': fxc, 'l2vpn': l2vpn, 'evpn': evpn, 'vpws': vpws}
    
    svc1 = count_services(multi_ctx.configs.get(h1, ""))
    svc2 = count_services(multi_ctx.configs.get(h2, ""))
    
    scale_table = Table(box=box.ROUNDED, show_header=True)
    scale_table.add_column("Category", style="cyan", width=22)
    scale_table.add_column(h1, justify="right", width=10)
    scale_table.add_column(h2, justify="right", width=10)
    scale_table.add_column("Shared", justify="right", style="green", width=10)
    scale_table.add_column(f"Only {h1}", justify="right", style="yellow", width=10)
    scale_table.add_column(f"Only {h2}", justify="right", style="yellow", width=10)
    scale_table.add_column("Status", justify="center", width=8)
    
    def add_compare_row(name, set1, set2):
        shared = set1 & set2
        only1 = set1 - set2
        only2 = set2 - set1
        status = "[green]✓ SYNC[/green]" if not only1 and not only2 else "[yellow]≠ DIFF[/yellow]"
        scale_table.add_row(
            name,
            f"{len(set1):,}",
            f"{len(set2):,}",
            f"{len(shared):,}",
            f"{len(only1):,}" if only1 else "-",
            f"{len(only2):,}" if only2 else "-",
            status
        )
        return only1, only2
    
    # Add rows
    rt_only1, rt_only2 = add_compare_row("Route Targets", rt1, rt2)
    add_compare_row("Total Interfaces", ifaces1, ifaces2)
    pwhe_only1, pwhe_only2 = add_compare_row("  └ PWHE (ph*)", pwhe1, pwhe2)
    l2_only1, l2_only2 = add_compare_row("  └ L2 Sub-interfaces", l2_1, l2_2)
    add_compare_row("  └ Bundles/LAG", bundle1, bundle2)
    mh_only1, mh_only2 = add_compare_row("Multihoming (ESI)", set(mh1.keys()), set(mh2.keys()))
    
    # Services (count comparison, not set)
    for svc_name in ['fxc', 'l2vpn', 'evpn']:
        c1, c2 = svc1.get(svc_name, 0), svc2.get(svc_name, 0)
        status = "[green]✓ SYNC[/green]" if c1 == c2 else "[yellow]≠ DIFF[/yellow]"
        diff = abs(c1 - c2)
        scale_table.add_row(
            f"Services: {svc_name.upper()}",
            f"{c1:,}",
            f"{c2:,}",
            f"{min(c1, c2):,}",
            f"+{diff}" if c1 > c2 else "-",
            f"+{diff}" if c2 > c1 else "-",
            status
        )
    
    # Stag usage
    stag1 = multi_ctx.stag_usage.get(h1, {})
    stag2 = multi_ctx.stag_usage.get(h2, {})
    s1, s2 = stag1.get('count', 0), stag2.get('count', 0)
    status = "[green]✓ OK[/green]"
    if stag1.get('at_risk') or stag2.get('at_risk'):
        status = "[yellow]⚠ HIGH[/yellow]"
    if stag1.get('exceeded') or stag2.get('exceeded'):
        status = "[red]⛔ OVER[/red]"
    scale_table.add_row(
        "Stag Usage (QinQ)",
        f"{s1:,} ({stag1.get('percentage', 0)}%)",
        f"{s2:,} ({stag2.get('percentage', 0)}%)",
        "-", "-", "-",
        status
    )
    
    console.print(scale_table)
    
    # ═══════════════════════════════════════════════════════════════════════
    # SECTION 3: Detailed Differences
    # ═══════════════════════════════════════════════════════════════════════
    has_diffs = pwhe_only1 or pwhe_only2 or l2_only1 or l2_only2 or rt_only1 or rt_only2
    
    if has_diffs:
        console.print("\n[bold]━━━ Detailed Differences ━━━[/bold]")
    
        if pwhe_only1 or pwhe_only2:
            console.print("\n[bold yellow]PWHE Interface Differences:[/bold yellow]")
            if pwhe_only1:
                sample = sorted(list(pwhe_only1))[:10]
                console.print(f"  [cyan]Only on {h1}[/cyan] ({len(pwhe_only1)} total):")
                console.print(f"    {', '.join(sample)}{'...' if len(pwhe_only1) > 10 else ''}")
            if pwhe_only2:
                sample = sorted(list(pwhe_only2))[:10]
                console.print(f"  [cyan]Only on {h2}[/cyan] ({len(pwhe_only2)} total):")
                console.print(f"    {', '.join(sample)}{'...' if len(pwhe_only2) > 10 else ''}")
        
        if l2_only1 or l2_only2:
            console.print("\n[bold yellow]L2 Sub-interface Differences:[/bold yellow]")
            if l2_only1:
                sample = sorted(list(l2_only1))[:10]
                console.print(f"  [cyan]Only on {h1}[/cyan] ({len(l2_only1)} total):")
                console.print(f"    {', '.join(sample)}{'...' if len(l2_only1) > 10 else ''}")
            if l2_only2:
                sample = sorted(list(l2_only2))[:10]
                console.print(f"  [cyan]Only on {h2}[/cyan] ({len(l2_only2)} total):")
                console.print(f"    {', '.join(sample)}{'...' if len(l2_only2) > 10 else ''}")
        
        if rt_only1 or rt_only2:
            console.print("\n[bold yellow]Route Target Differences:[/bold yellow]")
            if rt_only1:
                sample = sorted(list(rt_only1))[:5]
                console.print(f"  [cyan]Only on {h1}[/cyan]: {', '.join(sample)}{'...' if len(rt_only1) > 5 else ''}")
            if rt_only2:
                sample = sorted(list(rt_only2))[:5]
                console.print(f"  [cyan]Only on {h2}[/cyan]: {', '.join(sample)}{'...' if len(rt_only2) > 5 else ''}")
    
    # ═══════════════════════════════════════════════════════════════════════
    # SECTION 4: Multihoming ESI Validation
    # ═══════════════════════════════════════════════════════════════════════
    shared_mh = set(mh1.keys()) & set(mh2.keys())
    esi_mismatches = []  # Initialize before conditional block
    
    if shared_mh:
        console.print("\n[bold]━━━ Multihoming ESI Validation ━━━[/bold]")
        
        esi_mismatches = []
        for iface in shared_mh:
            val1 = mh1.get(iface, {})
            val2 = mh2.get(iface, {})
            esi1 = val1 if isinstance(val1, str) else val1.get('esi')
            esi2 = val2 if isinstance(val2, str) else val2.get('esi')
            if esi1 != esi2:
                esi_mismatches.append((iface, esi1, esi2))
        
        if esi_mismatches:
            console.print(f"\n[red]⚠ ESI MISMATCHES FOUND ({len(esi_mismatches)}):[/red]")
            console.print("[dim]  These interfaces have DIFFERENT ESI values - multihoming will NOT work correctly![/dim]")
            
            mismatch_table = Table(box=box.SIMPLE)
            mismatch_table.add_column("Interface", style="cyan")
            mismatch_table.add_column(f"{h1} ESI")
            mismatch_table.add_column(f"{h2} ESI")
            
            for iface, e1, e2 in esi_mismatches[:10]:
                mismatch_table.add_row(iface, str(e1)[:30], str(e2)[:30])
            
            console.print(mismatch_table)
            if len(esi_mismatches) > 10:
                console.print(f"  [dim]... and {len(esi_mismatches) - 10} more mismatches[/dim]")
        else:
            console.print(f"\n[green]✓ All {len(shared_mh):,} shared MH interfaces have MATCHING ESI values[/green]")
            console.print("[dim]  EVPN multihoming is correctly configured across both devices[/dim]")
    
    if mh_only1 or mh_only2:
        console.print("\n[bold yellow]Multihoming Asymmetry:[/bold yellow]")
        if mh_only1:
            console.print(f"  [yellow]⚠ {len(mh_only1)} interfaces with ESI only on {h1}[/yellow]")
        if mh_only2:
            console.print(f"  [yellow]⚠ {len(mh_only2)} interfaces with ESI only on {h2}[/yellow]")
        console.print("[dim]  Note: For multihoming, both devices need matching ESI on the same interface[/dim]")
    
    # ═══════════════════════════════════════════════════════════════════════
    # Summary
    # ═══════════════════════════════════════════════════════════════════════
    console.print("\n[bold]━━━ Summary ━━━[/bold]")
    
    issues = []
    if pwhe_only1 or pwhe_only2:
        issues.append(f"PWHE differences: +{len(pwhe_only1)}/{h1}, +{len(pwhe_only2)}/{h2}")
    if l2_only1 or l2_only2:
        issues.append(f"L2 sub-if differences: +{len(l2_only1)}/{h1}, +{len(l2_only2)}/{h2}")
    if rt_only1 or rt_only2:
        issues.append(f"RT differences: +{len(rt_only1)}/{h1}, +{len(rt_only2)}/{h2}")
    if mh_only1 or mh_only2:
        issues.append(f"MH asymmetry: +{len(mh_only1)}/{h1}, +{len(mh_only2)}/{h2}")
    if esi_mismatches:
        issues.append(f"ESI mismatches: {len(esi_mismatches)}")
    
    if not issues:
        console.print("[bold green]✓ Devices are SYNCHRONIZED - no significant differences found[/bold green]")
    else:
        console.print(f"[bold yellow]⚠ {len(issues)} difference categories found:[/bold yellow]")
        for issue in issues:
            console.print(f"  • {issue}")
    
    # Options
    console.print("\n[bold]Options:[/bold]")
    console.print("  [1] Export detailed diff to file")
    console.print("  [2] Show raw config diff (side-by-side)")
    console.print("  [B] Back")
    
    choice = Prompt.ask("Select", choices=["1", "2", "b", "B"], default="b").lower()
    
    if choice == "1":
        # Export diff
        diff_path = Path(f"db/configs/compare_{h1}_vs_{h2}_{datetime.now().strftime('%Y%m%d_%H%M')}.txt")
        with open(diff_path, 'w') as f:
            f.write(f"Configuration Comparison: {h1} vs {h2}\n")
            f.write(f"Generated: {datetime.now().isoformat()}\n")
            f.write("=" * 60 + "\n\n")
            f.write(f"PWHE only on {h1}: {sorted(pwhe_only1)}\n")
            f.write(f"PWHE only on {h2}: {sorted(pwhe_only2)}\n")
            f.write(f"L2 only on {h1}: {sorted(l2_only1)}\n")
            f.write(f"L2 only on {h2}: {sorted(l2_only2)}\n")
            f.write(f"RT only on {h1}: {sorted(rt_only1)}\n")
            f.write(f"RT only on {h2}: {sorted(rt_only2)}\n")
        console.print(f"[green]✓ Exported to {diff_path}[/green]")
    
    elif choice == "2":
        console.print("[dim]Raw config diff not yet implemented - use external diff tool[/dim]")
    
    Prompt.ask("\n[dim]Press Enter to continue[/dim]", default="")


def _check_single_device_status(device, saved_data: dict = None) -> dict:
    """Check upgrade status of a single device.
    
    Returns dict with: hostname, reachable, mode, stack_info, install_status, error
    """
    import paramiko
    import base64
    from datetime import datetime
    
    result = {
        'hostname': device.hostname,
        'reachable': False,
        'mode': 'Unknown',
        'stack_info': 'Unknown',
        'install_status': 'Unknown',
        'error': None
    }
    
    # Get saved data
    saved_stack = saved_data.get('stack') if saved_data else None
    saved_install_status = saved_data.get('install_status') if saved_data else None
    saved_install_start = saved_data.get('install_start') if saved_data else None
    
    try:
        ssh = paramiko.SSHClient()
        ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        
        # Get credentials
        password = device.password
        if hasattr(device, 'password') and device.password:
            try:
                password = base64.b64decode(device.password).decode('utf-8')
            except:
                password = device.password
        
        ssh.connect(device.ip, username=device.username or 'dnroot', password=password, timeout=15)
        result['reachable'] = True
        
        # Check if in GI mode (hostname contains -gi)
        stdin, stdout, stderr = ssh.exec_command("hostname", timeout=10)
        hostname_output = stdout.read().decode().strip()
        is_gi_mode = '-gi' in hostname_output.lower()
        result['mode'] = "GI Mode" if is_gi_mode else "DNOS"
        
        # Get current stack version using 'show system stack'
        if is_gi_mode:
            result['stack_info'] = "Deploying..."
            if saved_stack and saved_stack != '-':
                result['stack_info'] = saved_stack[:35]
        else:
            channel = ssh.invoke_shell()
            channel.settimeout(15)
            time.sleep(0.5)
            channel.recv(10000)
            
            channel.send("show system stack | no-more\n")
            time.sleep(1.5)
            stack_output = ""
            while channel.recv_ready():
                stack_output += channel.recv(65535).decode(errors='ignore')
                time.sleep(0.2)
            channel.close()
            
            for line in stack_output.split('\n'):
                if '|' in line and 'DNOS' in line:
                    parts = [p.strip() for p in line.split('|') if p.strip()]
                    if len(parts) >= 5:
                        current_version = parts[4]
                        if current_version and current_version != '-':
                            result['stack_info'] = current_version[:40]
                            break
        
        # Check install status
        channel = ssh.invoke_shell()
        channel.settimeout(30)
        time.sleep(0.5)
        channel.recv(10000)
        
        channel.send("show system install | no-more\n")
        time.sleep(2)
        install_output = ""
        while channel.recv_ready():
            install_output += channel.recv(65535).decode(errors='ignore')
            time.sleep(0.3)
        channel.close()
        
        # Parse install status
        running_tasks = []
        finished_tasks = []
        in_running_section = False
        in_finished_section = False
        
        for line in install_output.split('\n'):
            if 'Running tasks:' in line:
                in_running_section = True
                in_finished_section = False
                continue
            elif 'Finished tasks:' in line:
                in_running_section = False
                in_finished_section = True
                continue
            
            if '|' in line and 'Task ID' not in line and '---' not in line:
                parts = [p.strip() for p in line.split('|') if p.strip()]
                if len(parts) >= 6:
                    task_info = {
                        'task_id': parts[0] if len(parts) > 0 else '',
                        'status': parts[1] if len(parts) > 1 else '',
                        'start_time': parts[2] if len(parts) > 2 else '',
                        'finish_time': parts[3] if len(parts) > 3 else '',
                        'est_completion': parts[4] if len(parts) > 4 else '',
                        'pkg_type': parts[5] if len(parts) > 5 else '',
                        'pkg_name': parts[6] if len(parts) > 6 else '',
                    }
                    if in_running_section and task_info['status']:
                        running_tasks.append(task_info)
                    elif in_finished_section and task_info['status']:
                        finished_tasks.append(task_info)
        
        if running_tasks:
            task = running_tasks[0]
            pkg_type = task.get('pkg_type', 'Unknown')
            pkg_name = task.get('pkg_name', '')
            est_time = task.get('est_completion', '')
            
            if pkg_name and is_gi_mode:
                result['stack_info'] = pkg_name[:40]
            
            if est_time:
                time_part = est_time.split()[-1] if ' ' in est_time else est_time
                result['install_status'] = f"🔄 {pkg_type} IN-PROGRESS | ETA: {time_part}"
            else:
                result['install_status'] = f"🔄 {pkg_type} IN-PROGRESS"
        elif finished_tasks:
            dnos_done = any(t.get('pkg_type') == 'DNOS' and t.get('status') == 'DONE' for t in finished_tasks)
            gi_done = any(t.get('pkg_type') == 'GI' and t.get('status') == 'DONE' for t in finished_tasks)
            
            if dnos_done:
                last_task = [t for t in finished_tasks if t.get('pkg_type') == 'DNOS'][-1]
                finish_time = last_task.get('finish_time', '').split()[-1] if last_task.get('finish_time') else ''
                result['install_status'] = f"✅ DNOS DONE | {finish_time}"
            elif gi_done:
                result['install_status'] = "✓ GI done, waiting DNOS"
            else:
                result['install_status'] = "✅ COMPLETED"
        elif 'Task status: IN-PROGRESS' in install_output:
            result['install_status'] = "🔄 Deploying..."
        elif 'no install' in install_output.lower() or 'idle' in install_output.lower():
            result['install_status'] = "Idle"
        elif 'failed' in install_output.lower() or 'error' in install_output.lower():
            result['install_status'] = "❌ FAILED"
        
        ssh.close()
        
    except Exception as e:
        result['reachable'] = False
        result['error'] = str(e)[:30]
        
        if saved_stack and saved_stack != '-':
            result['stack_info'] = saved_stack[:35]
            result['mode'] = "Rebooting?"
        
        if saved_install_status:
            if 'completed' in saved_install_status.lower():
                result['install_status'] = "✅ COMPLETED"
            elif saved_install_start:
                try:
                    start = datetime.strptime(saved_install_start, "%Y-%m-%d %H:%M:%S")
                    elapsed = datetime.now() - start
                    mins = int(elapsed.total_seconds() / 60)
                    result['install_status'] = f"🔄 ~{mins}m since start"
                except:
                    result['install_status'] = f"🔄 {saved_install_status}"
            else:
                result['install_status'] = saved_install_status
        else:
            result['install_status'] = f"Conn: {result['error']}"
    
    return result


def _check_device_upgrade_status(multi_ctx: 'MultiDeviceContext'):
    """Check and display the upgrade/install status of all devices with auto-wait option."""
    from rich.table import Table as RichTable
    from rich.live import Live
    from pathlib import Path
    from datetime import datetime
    from concurrent.futures import ThreadPoolExecutor, as_completed
    
    def get_saved_data(hostname):
        """Get saved data from operational.json."""
        try:
            op_file = Path(f"db/configs/{hostname}/operational.json")
            if op_file.exists():
                with open(op_file) as f:
                    op_data = json.load(f)
                    return {
                        'stack': op_data.get('dnos_version') or op_data.get('last_dnos_stack') or op_data.get('dnos_url', '').split('/')[-1].replace('.tar', '')[:40],
                        'install_status': op_data.get('install_status'),
                        'install_start': op_data.get('install_start')
                    }
        except:
            pass
        return {}
    
    def check_all_devices():
        """Check all devices in parallel."""
        results = {}
        with ThreadPoolExecutor(max_workers=len(multi_ctx.devices)) as executor:
            futures = {}
            for device in multi_ctx.devices:
                saved = get_saved_data(device.hostname)
                futures[executor.submit(_check_single_device_status, device, saved)] = device.hostname
            
            for future in as_completed(futures):
                hostname = futures[future]
                try:
                    results[hostname] = future.result()
                except Exception as e:
                    results[hostname] = {
                        'hostname': hostname,
                        'reachable': False,
                        'mode': 'Error',
                        'stack_info': 'Error',
                        'install_status': str(e)[:30],
                        'error': str(e)
                    }
        return results
    
    def display_status_table(results: dict, attempt: int = 0, elapsed_mins: int = 0):
        """Display status table."""
        title = "Device Upgrade Status"
        if attempt > 0:
            title += f" (Attempt {attempt}, {elapsed_mins}m elapsed)"
        
        table = RichTable(title=title, box=box.ROUNDED)
        table.add_column("Device", style="cyan")
        table.add_column("Mode", style="yellow")
        table.add_column("Current Stack", style="green")
        table.add_column("Install Status")
        table.add_column("Status", justify="center")
        
        for device in multi_ctx.devices:
            r = results.get(device.hostname, {})
            
            # Style based on reachability
            if r.get('reachable'):
                mode_style = "[green]" if r.get('mode') == 'DNOS' else "[yellow]"
                status_icon = "[green]✓[/green]"
            else:
                mode_style = "[yellow]"
                status_icon = "[red]✗[/red]"
            
            mode_display = f"{mode_style}{r.get('mode', 'Unknown')}[/{mode_style.strip('[]')}]"
            
            # Color install status
            install_status = r.get('install_status', 'Unknown')
            if '✅' in install_status or 'DONE' in install_status:
                install_display = f"[green]{install_status}[/green]"
            elif '🔄' in install_status or 'IN-PROGRESS' in install_status:
                install_display = f"[yellow]{install_status}[/yellow]"
            elif '❌' in install_status or 'FAILED' in install_status:
                install_display = f"[red]{install_status}[/red]"
            else:
                install_display = f"[dim]{install_status}[/dim]"
            
            table.add_row(
                device.hostname,
                mode_display,
                r.get('stack_info', 'Unknown')[:40],
                install_display,
                status_icon
            )
        
        return table
    
    # Initial check
    console.print("\n[dim]Checking device status...[/dim]")
    results = check_all_devices()
    
    # Display initial results
    console.print(display_status_table(results))
    
    # Check for unreachable devices
    unreachable = [h for h, r in results.items() if not r.get('reachable')]
    all_done = all(
        '✅' in r.get('install_status', '') or 'DONE' in r.get('install_status', '') or 'Idle' in r.get('install_status', '')
        for r in results.values() if r.get('reachable')
    )
    
    if not unreachable and all_done:
        console.print("\n[green]✓ All devices online and upgrade complete![/green]")
        return
    
    if unreachable:
        console.print(f"\n[yellow]⚠ {len(unreachable)} device(s) unreachable:[/yellow] {', '.join(unreachable)}")
        console.print("[dim]Devices may be rebooting after upgrade...[/dim]")
    
    # Offer options
    console.print("\n[bold]Options:[/bold]")
    console.print("  [W] 🔄 Wait & auto-retry (poll every 60s until all online)")
    console.print("  [R] Refresh now (manual check)")
    console.print("  [B] Back")
    
    choice = Prompt.ask("Select", choices=["w", "W", "r", "R", "b", "B"], default="w").lower()
    
    if choice == "b":
        return
    elif choice == "r":
        # Just refresh once
        return _check_device_upgrade_status(multi_ctx)
    elif choice == "w":
        # Auto-wait loop
        max_attempts = 20
        poll_interval = 60  # seconds
        start_time = time.time()
        
        console.print(f"\n[cyan]🔄 Auto-waiting for devices to come online...[/cyan]")
        console.print(f"[dim]Polling every {poll_interval}s, max {max_attempts} attempts. Press Ctrl+C to stop.[/dim]\n")
        
        try:
            for attempt in range(1, max_attempts + 1):
                elapsed_mins = int((time.time() - start_time) / 60)
                
                # Build status line
                status_parts = []
                for device in multi_ctx.devices:
                    r = results.get(device.hostname, {})
                    if r.get('reachable'):
                        stack_short = r.get('stack_info', '')[:20]
                        status_parts.append(f"[green]✓ {device.hostname}[/green] ({stack_short})")
                    else:
                        status_parts.append(f"[red]✗ {device.hostname}[/red]")
                
                console.print(f"  ⏳ Attempt {attempt}/{max_attempts} - Elapsed: {elapsed_mins}m | {' | '.join(status_parts)}")
                
                # Check if all online
                all_reachable = all(r.get('reachable') for r in results.values())
                if all_reachable:
                    console.print(f"\n[bold green]✓ All {len(multi_ctx.devices)} devices online![/bold green]")
                    console.print(display_status_table(results, attempt, elapsed_mins))
                    
                    # Update operational.json with completed status
                    for device in multi_ctx.devices:
                        try:
                            op_file = Path(f"db/configs/{device.hostname}/operational.json")
                            if op_file.exists():
                                with open(op_file, 'r') as f:
                                    op_data = json.load(f)
                                op_data['upgrade_in_progress'] = False
                                op_data['install_status'] = 'completed'
                                with open(op_file, 'w') as f:
                                    json.dump(op_data, f, indent=4)
                        except:
                            pass
                    return
                
                # Wait before next poll
                if attempt < max_attempts:
                    for remaining in range(poll_interval, 0, -1):
                        console.print(f"\r[dim]Next check in {remaining}s... (Ctrl+C to stop)[/dim]", end="")
                        time.sleep(1)
                    console.print("\r" + " " * 50 + "\r", end="")  # Clear line
                    
                    # Re-check all devices
                    results = check_all_devices()
            
            # Max attempts reached
            console.print(f"\n[yellow]⚠ Max attempts ({max_attempts}) reached. Some devices still unreachable.[/yellow]")
            console.print(display_status_table(results, max_attempts, int((time.time() - start_time) / 60)))
            
        except KeyboardInterrupt:
            console.print("\n\n[yellow]⚠ Auto-wait cancelled by user.[/yellow]")
            console.print(display_status_table(results))


def _show_build_failure_log(jenkins: 'JenkinsClient', branch: str, build_number: int):
    """Fetch and display the failure reason from Jenkins console log."""
    from rich.panel import Panel
    from rich.syntax import Syntax
    
    console.print("\n[bold red]📋 Fetching Failure Details...[/bold red]")
    
    try:
        # Get the failed stage and relevant log lines
        success, failed_stage, log_content = jenkins.get_failed_stage_log(branch, build_number)
        
        if success:
            console.print(f"\n[bold yellow]Failed Stage: {failed_stage}[/bold yellow]")
            
            # Display log in a panel
            console.print(Panel(
                log_content[:3000],  # Limit to 3000 chars
                title="[red]Error Log[/red]",
                border_style="red",
                expand=False
            ))
            
            # Offer to show full log
            if Confirm.ask("\nShow more log lines?", default=False):
                success2, full_log = jenkins.get_console_log(branch, build_number, tail_lines=500)
                if success2:
                    console.print(Panel(
                        full_log[:8000],
                        title="[yellow]Console Output (last 500 lines)[/yellow]",
                        border_style="yellow",
                        expand=False
                    ))
        else:
            console.print(f"[yellow]Could not fetch log: {log_content}[/yellow]")
            
    except Exception as e:
        console.print(f"[yellow]Error fetching failure log: {e}[/yellow]")


def _handle_build_failure(jenkins: 'JenkinsClient', branch: str, build_number: int, 
                          build_result: str, multi_ctx: 'MultiDeviceContext',
                          with_baseos: bool = True, auto_push: bool = True) -> Tuple[bool, Optional[Dict]]:
    """Handle a failed build - detect infrastructure issues and offer retry.
    
    Args:
        jenkins: Jenkins client
        branch: Branch name
        build_number: Failed build number
        build_result: The build result (e.g., 'FAILURE')
        multi_ctx: Multi-device context
        with_baseos: Whether to include baseos on retry
        auto_push: Whether to auto-push on successful retry
        
    Returns:
        Tuple of (should_continue_to_push, stack_dict or None)
    """
    console.print(f"\n[red]✗ Build #{build_number} {build_result}[/red]")
    
    # Check if it's an infrastructure failure
    is_infra, reason, node_name = jenkins.is_infrastructure_failure(branch, build_number)
    
    if is_infra:
        console.print(f"[yellow]⚠ Infrastructure failure detected: {reason}[/yellow]")
        console.print(f"[dim]Node: {node_name} (added to blocklist for 24h)[/dim]")
        console.print("\n  [1] 🔄 Auto-retry (will trigger new build)")
        console.print("  [2] 📋 Show failure log first")
        console.print("  [B] Back to menu (no retry)")
        retry_choice = Prompt.ask("Select", choices=["1", "2", "b", "B"], default="1").lower()
        
        if retry_choice == "2":
            _show_build_failure_log(jenkins, branch, build_number)
            # Ask again after showing log
            if not Confirm.ask("\nRetry build?", default=True):
                return False, None
        elif retry_choice == "b":
            return False, None
        
        # Trigger retry
        console.print(f"\n[bold yellow]🔄 Retrying build for {branch}...[/bold yellow]")
        console.print("[dim]Note: The failed node has been blocklisted for 24 hours[/dim]\n")
        
        success, message = jenkins.trigger_build(branch, with_baseos=with_baseos, qa_version=False)
        if not success:
            console.print(f"[red]✗ Failed to trigger retry: {message}[/red]")
            return False, None
        
        console.print(f"[green]✓ {message}[/green]")
        console.print("[dim]Waiting for new build to start...[/dim]")
        
        new_build_number = jenkins.wait_for_build_start(branch, timeout=180)
        if not new_build_number:
            console.print("[yellow]Build queued but not started. Try monitoring later.[/yellow]")
            return False, None
        
        console.print(f"[green]✓ New build #{new_build_number} started![/green]")
        
        # Monitor the new build
        console.print("\n[yellow]📊 Monitoring retry build...[/yellow]")
        console.print("[dim]Press Ctrl+C to detach[/dim]\n")
        
        from rich.progress import Progress, SpinnerColumn, TextColumn, BarColumn, TimeElapsedColumn
        
        with Progress(
            SpinnerColumn(),
            TextColumn("[progress.description]{task.description}"),
            BarColumn(),
            TextColumn("{task.fields[status]}"),
            TimeElapsedColumn(),
            console=console
        ) as progress:
            task = progress.add_task(f"Building #{new_build_number}...", total=100, status="Starting...")
            
            def update_progress(msg, pct):
                progress.update(task, completed=pct, description=msg, status=f"{pct}%")
            
            try:
                new_build = jenkins.wait_for_build_completion(
                    branch, new_build_number,
                    timeout=3600, poll_interval=30,
                    progress_callback=update_progress
                )
                
                if new_build and new_build.result == "SUCCESS":
                    console.print(f"\n[bold green]✓ Retry build #{new_build_number} SUCCEEDED![/bold green]")
                    
                    urls = jenkins.get_stack_urls(branch, new_build_number)
                    console.print("\n[bold]Artifacts Ready:[/bold]")
                    console.print(f"  • DNOS: {'✓' if urls.get('dnos') else '✗'}")
                    console.print(f"  • GI: {'✓' if urls.get('gi') else '✗'}")
                    console.print(f"  • BaseOS: {'✓' if urls.get('baseos') else '✗'}")
                    
                    if auto_push:
                        console.print(f"\n[bold cyan]🚀 Auto-pushing to devices...[/bold cyan]")
                        return True, {
                            'branch': branch,
                            'build': new_build_number,
                            'dnos_url': urls.get('dnos'),
                            'gi_url': urls.get('gi'),
                            'baseos_url': urls.get('baseos') if with_baseos else None,
                            'age_hours': 0,
                        }
                    else:
                        return False, None
                elif new_build:
                    # Retry also failed - check if infra again (recursive retry up to 3 times)
                    retry_count = getattr(multi_ctx, '_infra_retry_count', 0) + 1
                    if retry_count < 3:
                        multi_ctx._infra_retry_count = retry_count
                        console.print(f"\n[yellow]Retry also failed. Attempt {retry_count}/3[/yellow]")
                        return _handle_build_failure(jenkins, branch, new_build_number, 
                                                    new_build.result, multi_ctx,
                                                    with_baseos, auto_push)
                    else:
                        console.print(f"\n[red]✗ All 3 retry attempts failed[/red]")
                        _show_build_failure_log(jenkins, branch, new_build_number)
                        return False, None
                else:
                    console.print("\n[yellow]Build timed out[/yellow]")
                    return False, None
                    
            except KeyboardInterrupt:
                console.print("\n[yellow]Detached. Build continues in Jenkins.[/yellow]")
                return False, None
    else:
        # Not an infrastructure failure - real code issue
        console.print("[dim]This appears to be a code/build issue, not infrastructure.[/dim]")
        _show_build_failure_log(jenkins, branch, build_number)
        return False, None


def _monitor_triggered_builds(jenkins: 'JenkinsClient', multi_ctx: 'MultiDeviceContext'):
    """Monitor and display status of recently triggered/running builds."""
    from rich.table import Table as RichTable
    from rich.live import Live
    from rich.panel import Panel
    from rich.text import Text
    
    console.print("\n[bold magenta]📊 Monitor Triggered Builds[/bold magenta]")
    console.print("[dim]Check build status, monitor progress, trigger new builds[/dim]\n")
    
    # Check if we have a recently triggered branch (from session or history)
    recently_triggered = getattr(multi_ctx, '_last_triggered_branch', None)
    
    # Also check upgrade history for recent branches if no session branch
    recent_from_history = []
    if not recently_triggered:
        try:
            history_path = Path("db/upgrade_sources_history.json")
            if history_path.exists():
                with open(history_path) as f:
                    history_data = json.load(f)
                    # Get unique branches from history (most recent first)
                    seen = set()
                    for entry in history_data.get('recent_branches', [])[:5]:
                        branch = entry.get('branch')
                        if branch and branch not in seen:
                            recent_from_history.append(branch)
                            seen.add(branch)
        except:
            pass
    
    # Ask for branch or show recent
    has_recent = recently_triggered or recent_from_history
    if recently_triggered:
        console.print(f"  [0] [bold yellow]⚡ Monitor: {recently_triggered}[/bold yellow] (just triggered)")
    elif recent_from_history:
        console.print(f"  [0] [bold yellow]⚡ Recent: {recent_from_history[0]}[/bold yellow] (from history)")
    console.print("  [1] Enter branch name to monitor")
    console.print("  [2] Show dev branches (dev_v*)")
    console.print("  [3] Show feature branches (feature/*)")
    console.print("  [4] Show recent from history")
    console.print("  [B] Back")
    
    choices = ["0", "1", "2", "3", "4", "b", "B"] if has_recent else ["1", "2", "3", "4", "b", "B"]
    mon_choice = Prompt.ask("Select", choices=choices, default="0" if has_recent else "1").lower()
    
    if mon_choice == "b":
        return
    
    # Handle recently triggered or history branch
    if mon_choice == "0":
        if recently_triggered:
            branch = recently_triggered
        elif recent_from_history:
            branch = recent_from_history[0]
        else:
            branch = None
        
        if branch:
            console.print(f"\n[bold yellow]⚡ Monitoring: {branch}[/bold yellow]")
            # Fall through to the single-branch monitoring logic below
            mon_choice = "_monitor_single"
        else:
            console.print("[yellow]No recent branch to monitor[/yellow]")
            return
    
    if mon_choice == "4":
        # Show branches from history instead of Jenkins API
        console.print("\n[bold]Recent Branches from History:[/bold]")
        
        try:
            history_path = Path("db/upgrade_sources_history.json")
            if history_path.exists():
                with open(history_path) as f:
                    history_data = json.load(f)
                    branches_to_check = []
                    seen = set()
                    for entry in history_data.get('recent_branches', []):
                        branch = entry.get('branch')
                        if branch and branch not in seen:
                            branches_to_check.append(branch)
                            seen.add(branch)
                    
                    if not branches_to_check:
                        console.print("[yellow]No branches in history[/yellow]")
                        Prompt.ask("\n[dim]Press Enter to continue[/dim]", default="")
                        return
                    
                    from rich.table import Table as RichTable
                    table = RichTable(title="Recent Branch Builds", box=box.ROUNDED)
                    table.add_column("Branch", style="cyan", max_width=50)
                    table.add_column("Build #", justify="right")
                    table.add_column("Status")
                    table.add_column("Age", justify="right")
                    
                    console.print(f"[dim]Checking {len(branches_to_check)} branches from history...[/dim]")
                    
                    for branch in branches_to_check[:10]:
                        try:
                            build = jenkins.get_build_info(branch)
                            if build:
                                status_icon = "🔄" if build.building else ("✅" if build.result == "SUCCESS" else "❌")
                                status_text = "Building..." if build.building else (build.result or "Unknown")
                                age = f"{build.age_hours:.1f}h" if build.age_hours < 24 else f"{build.age_hours/24:.1f}d"
                                branch_style = "bold yellow" if build.building else ("green" if build.age_hours < 2 else "cyan")
                                
                                table.add_row(
                                    f"[{branch_style}]{branch[:50]}[/{branch_style}]",
                                    f"#{build.build_number}",
                                    f"{status_icon} {status_text}",
                                    age
                                )
                            else:
                                table.add_row(branch[:50], "-", "[dim]No builds[/dim]", "-")
                        except Exception as e:
                            table.add_row(branch[:50], "-", f"[red]Error[/red]", "-")
                    
                    console.print(table)
                    console.print("\n[dim]Yellow = building, Green = recent (<2h)[/dim]")
            else:
                console.print("[yellow]No history file found[/yellow]")
        except Exception as e:
            console.print(f"[red]Error loading history: {e}[/red]")
        
        Prompt.ask("\n[dim]Press Enter to continue[/dim]", default="")
        return
    
    if mon_choice in ["2", "3"]:
        # Show builds for different branch patterns from Jenkins API
        if mon_choice == "2":
            pattern = r'^dev_v\d+'
            title = "Dev Branch Builds (dev_v*)"
        else:  # mon_choice == "3"
            # Match both feature/ and feature%2F (URL-encoded)
            pattern = r'(^feature[/%]|feature%2F)'
            title = "Feature Branch Builds (feature/*)"
        
        console.print(f"\n[dim]Fetching {title.lower()} (this may take a moment)...[/dim]")
        try:
            # Get branches matching pattern
            branches = jenkins.list_cheetah_branches(pattern=pattern)[:20]
            
            if not branches:
                console.print(f"[yellow]No branches found matching pattern[/yellow]")
                Prompt.ask("\n[dim]Press Enter to continue[/dim]", default="")
                return
            
            table = RichTable(title=title, box=box.ROUNDED)
            table.add_column("Branch", style="cyan", max_width=50)
            table.add_column("Build #", justify="right")
            table.add_column("Status")
            table.add_column("Age", justify="right")
            table.add_column("ETA", justify="right")
            
            builds_found = 0
            console.print(f"[dim]Checking {len(branches)} branches...[/dim]")
            
            for i, branch in enumerate(branches):
                # Fetch the latest build for this branch
                try:
                    build = jenkins.get_build_info(branch.name)
                    if build:
                        builds_found += 1
                        status_icon = "🔄" if build.building else ("✅" if build.result == "SUCCESS" else "❌")
                        status_text = "Building..." if build.building else (build.result or "Unknown")
                        
                        # Calculate ETA for building
                        if build.building:
                            # Estimate ~45 min total build time
                            elapsed_min = build.age_hours * 60
                            eta_min = max(0, 45 - elapsed_min)
                            eta = f"~{int(eta_min)}m" if eta_min > 0 else "Soon"
                        else:
                            eta = "-"
                        
                        age = f"{build.age_hours:.1f}h" if build.age_hours < 24 else f"{build.age_hours/24:.1f}d"
                        
                        # Highlight building or recent builds
                        branch_style = "bold yellow" if build.building else ("green" if build.age_hours < 2 else "cyan")
                        
                        table.add_row(
                            f"[{branch_style}]{branch.name[:50]}[/{branch_style}]",
                            f"#{build.build_number}",
                            f"{status_icon} {status_text}",
                            age,
                            eta
                        )
                except Exception:
                    # Skip branches we can't fetch
                    pass
            
            if builds_found > 0:
                console.print(table)
                console.print(f"\n[dim]Showing {builds_found} branches. Yellow = building, Green = recent (<2h).[/dim]")
            else:
                console.print("[yellow]No builds found for any branches[/yellow]")
            
        except Exception as e:
            console.print(f"[red]Error fetching builds: {e}[/red]")
            import traceback
            console.print(f"[dim]{traceback.format_exc()}[/dim]")
        
        Prompt.ask("\n[dim]Press Enter to continue[/dim]", default="")
        return
    
    # Monitor specific branch (either entered manually or from recently triggered)
    if mon_choice != "_monitor_single":
        console.print("[dim]Enter branch name (e.g., feature/dev_v26_1/flowspec_vpn, dev_v26_1)[/dim]")
        console.print("[dim]Do NOT include build number like '#8-' prefix[/dim]")
        branch = Prompt.ask("Branch name [B to cancel]")
        if not branch or branch.lower() == 'b':
            return
    
    console.print(f"\n[dim]Checking {branch}...[/dim]")
    
    try:
        build = jenkins.get_build_info(branch)
        
        if not build:
            console.print(f"[yellow]No builds found for {branch}[/yellow]")
            console.print("[dim]Note: Branch name should NOT include build number (e.g., use 'feature/dev_v26_1/flowspec_vpn' not '#8-feature/...').[/dim]")
            
            console.print("\n  [Y] Yes - Trigger a new build")
            console.print("  [N] No - Go back")
            console.print("  [B] Back to menu")
            trigger_choice = Prompt.ask("Trigger new build?", choices=["y", "Y", "n", "N", "b", "B"], default="n").lower()
            
            if trigger_choice == "y":
                with_baseos = Confirm.ask("Build with BaseOS containers?", default=True)
                qa_version = Confirm.ask("QA version (60-day retention)?", default=False)
                
                success, message = jenkins.trigger_build(branch, with_baseos=with_baseos, qa_version=qa_version)
                if success:
                    console.print(f"[green]✓ {message}[/green]")
                else:
                    console.print(f"[red]✗ {message}[/red]")
            return
        
        # Show current build status
        console.print(f"\n[bold]Build #{build.build_number} for {branch}[/bold]")
        
        if build.building:
            console.print(f"[yellow]🔄 Status: BUILDING[/yellow]")
            
            # Calculate estimated time
            elapsed_min = build.age_hours * 60
            total_estimate_min = 45  # Typical build time
            remaining_min = max(0, total_estimate_min - elapsed_min)
            progress_pct = min(95, int((elapsed_min / total_estimate_min) * 100))
            
            console.print(f"  Elapsed: {int(elapsed_min)} minutes")
            console.print(f"  Estimated remaining: ~{int(remaining_min)} minutes")
            console.print(f"  Progress: ~{progress_pct}%")
            
            # Progress bar
            bar_width = 40
            filled = int(bar_width * progress_pct / 100)
            bar = '█' * filled + '░' * (bar_width - filled)
            console.print(f"  [{bar}] {progress_pct}%")
            
            console.print(f"\n[cyan]Jenkins URL: {build.url}[/cyan]")
            
            if Confirm.ask("\nMonitor until completion?", default=True):
                console.print("\n[yellow]Monitoring build progress...[/yellow]")
                console.print("[dim]Press Ctrl+C to stop monitoring (build continues in Jenkins)[/dim]\n")
                
                from rich.progress import Progress, SpinnerColumn, TextColumn, BarColumn, TimeElapsedColumn
                
                with Progress(
                    SpinnerColumn(),
                    TextColumn("[progress.description]{task.description}"),
                    BarColumn(),
                    TextColumn("{task.fields[eta]}"),
                    TimeElapsedColumn(),
                    console=console
                ) as progress:
                    task = progress.add_task(f"Building {branch}...", total=100, eta="Calculating...")
                    
                    try:
                        while True:
                            build = jenkins.get_build_info(branch, build.build_number)
                            if not build:
                                break
                            
                            if not build.building:
                                # Build finished!
                                progress.update(task, completed=100, description=f"Build #{build.build_number}")
                                break
                            
                            elapsed_min = build.age_hours * 60
                            remaining_min = max(0, total_estimate_min - elapsed_min)
                            progress_pct = min(95, int((elapsed_min / total_estimate_min) * 100))
                            
                            progress.update(
                                task, 
                                completed=progress_pct,
                                description=f"Building {branch} #{build.build_number}",
                                eta=f"~{int(remaining_min)}m remaining"
                            )
                            
                            time.sleep(30)
                            
                    except KeyboardInterrupt:
                        console.print("\n[yellow]Stopped monitoring. Build continues in Jenkins.[/yellow]")
                        return
                
                # Build finished - show result
                if build.result == "SUCCESS":
                    console.print(f"\n[green]✓ Build #{build.build_number} COMPLETED SUCCESSFULLY![/green]")
                    console.print("[cyan]Artifacts should now be available.[/cyan]")
                    console.print("[dim]Return to Image Upgrade menu and select this branch to push.[/dim]")
                else:
                    console.print(f"\n[red]✗ Build #{build.build_number} {build.result}[/red]")
                    # Fetch and display failure reason
                    _show_build_failure_log(jenkins, branch, build.build_number)
        
        else:
            # Build already completed
            status_icon = "✅" if build.result == "SUCCESS" else "❌"
            console.print(f"{status_icon} Status: {build.result}")
            console.print(f"  Completed: {build.age_hours:.1f} hours ago")
            console.print(f"  URL: {build.url}")
            
            # If failed, offer to show logs
            if build.result != "SUCCESS":
                if Confirm.ask("\nShow failure log?", default=True):
                    _show_build_failure_log(jenkins, branch, build.build_number)
            
            if build.result == "SUCCESS":
                # Check for artifacts
                urls = jenkins.get_stack_urls(branch, build.build_number)
                has_dnos = urls.get('dnos') and urls.get('dnos') != 'N/A'
                has_gi = urls.get('gi') and urls.get('gi') != 'N/A'
                
                console.print(f"\n[bold]Artifacts:[/bold]")
                console.print(f"  DNOS: {'✓ Available' if has_dnos else '✗ N/A'}")
                console.print(f"  GI: {'✓ Available' if has_gi else '✗ N/A'}")
                
                if build.is_expired:
                    console.print(f"\n[yellow]⚠ Build is expired ({build.age_hours:.0f}h old) - artifacts may be unavailable[/yellow]")
    
    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")
    
    Prompt.ask("\n[dim]Press Enter to continue[/dim]", default="")


def _verify_device_stacks_live(multi_ctx: 'MultiDeviceContext'):
    """SSH to devices and verify current stack versions."""
    import paramiko
    from rich.table import Table as RichTable
    
    table = RichTable(title="Live Stack Verification", box=box.ROUNDED)
    table.add_column("Device", style="cyan")
    table.add_column("Mode", style="yellow")
    table.add_column("DNOS Stack")
    table.add_column("GI Stack")
    table.add_column("BaseOS")
    
    for device in multi_ctx.devices:
        try:
            ssh = paramiko.SSHClient()
            ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
            
            # Get credentials
            password = device.password
            if hasattr(device, 'password') and device.password:
                import base64
                try:
                    password = base64.b64decode(device.password).decode('utf-8')
                except:
                    password = device.password
            
            ssh.connect(device.ip, username=device.username or 'dnroot', password=password, timeout=15)
            
            # Check if in GI mode
            stdin, stdout, stderr = ssh.exec_command("hostname", timeout=10)
            hostname_output = stdout.read().decode().strip()
            is_gi_mode = '-gi' in hostname_output.lower()
            mode = "[yellow]GI[/yellow]" if is_gi_mode else "[green]DNOS[/green]"
            
            dnos_ver = "N/A"
            gi_ver = "N/A"
            baseos_ver = "N/A"
            
            # Use interactive shell for reliable output
            channel = ssh.invoke_shell()
            channel.settimeout(20)
            time.sleep(0.5)
            channel.recv(10000)  # Clear initial output
            
            if is_gi_mode:
                # In GI mode, get info from show system install
                channel.send("show system install | no-more\n")
                time.sleep(2)
                output = ""
                while channel.recv_ready():
                    output += channel.recv(65535).decode(errors='ignore')
                    time.sleep(0.3)
                
                # Parse install table for target versions
                for line in output.split('\n'):
                    if '|' in line and 'DNOS' in line:
                        parts = [p.strip() for p in line.split('|') if p.strip()]
                        if len(parts) >= 7:
                            dnos_ver = parts[6][:25] if parts[6] else "N/A"  # Target Version column
                    elif '|' in line and 'GI' in line:
                        parts = [p.strip() for p in line.split('|') if p.strip()]
                        if len(parts) >= 7:
                            gi_ver = parts[6][:25] if parts[6] else "N/A"
                    elif '|' in line and 'BASEOS' in line:
                        parts = [p.strip() for p in line.split('|') if p.strip()]
                        if len(parts) >= 7:
                            baseos_ver = parts[6][:15] if parts[6] else "N/A"
            else:
                # DNOS mode - use 'show system stack' for accurate Current versions
                channel.send("show system stack | no-more\n")
                time.sleep(1.5)
                output = ""
                while channel.recv_ready():
                    output += channel.recv(65535).decode(errors='ignore')
                    time.sleep(0.2)
                
                # Parse the table: | Component | HW Model | HW Revision | Revert | Current | Target |
                for line in output.split('\n'):
                    if '|' in line and '---' not in line and 'Component' not in line:
                        parts = [p.strip() for p in line.split('|') if p.strip()]
                        # parts[0]=Component, [1]=HW Model, [2]=HW Revision, [3]=Revert, [4]=Current, [5]=Target
                        if len(parts) >= 5:
                            component = parts[0].upper()
                            current = parts[4] if parts[4] != '-' else 'N/A'
                            
                            if component == 'DNOS':
                                dnos_ver = current[:25]
                            elif component == 'GI':
                                gi_ver = current[:25]
                            elif component == 'BASEOS':
                                baseos_ver = current[:15]
            
            channel.close()
            
            ssh.close()
            
            table.add_row(device.hostname, mode, dnos_ver, gi_ver, baseos_ver)
            
        except Exception as e:
            table.add_row(device.hostname, "[red]Err[/red]", str(e)[:20], "-", "-")
    
    console.print(table)


def _save_to_upgrade_history(history_path: Path, recent_urls: list, recent_branches: list, 
                              stack: dict, choice: str, url: str = ""):
    """Save a valid source to upgrade history for Recent Sources."""
    history_data = {'recent_urls': recent_urls, 'recent_branches': recent_branches, 'max_entries': 10}
    
    # Extract version info from URL
    dnos_version = 'N/A'
    if stack.get('dnos_url') and stack.get('dnos_url') != 'N/A':
        try:
            dnos_version = stack.get('dnos_url', '').split('/')[-1].replace('.tar', '')[:40]
        except:
            pass
    
    new_entry = {
        'url': url,
        'timestamp': datetime.now().isoformat(),
        'dnos_version': dnos_version,
        'branch': stack.get('branch'),
        'build': stack.get('build'),
        'source_type': {
            "1": "dev_branch",
            "2": "release_branch",
            "3": "manual_branch",
            "4": "jenkins_url",
            "5": "minio_url",
        }.get(choice, "other"),
        'has_dnos': bool(stack.get('dnos_url') and stack.get('dnos_url') != 'N/A'),
        'has_gi': bool(stack.get('gi_url') and stack.get('gi_url') != 'N/A'),
        'has_baseos': bool(stack.get('baseos_url') and stack.get('baseos_url') != 'N/A'),
    }
    
    if choice == "4":
        # For Jenkins URLs, add to recent_urls
        history_data['recent_urls'] = [new_entry] + [u for u in recent_urls if u.get('branch') != new_entry.get('branch') or u.get('build') != new_entry.get('build')][:9]
    else:
        # For branches (options 1, 2, 3, 5), add to recent_branches
        history_data['recent_branches'] = [new_entry] + [b for b in recent_branches if b.get('branch') != new_entry.get('branch') or b.get('build') != new_entry.get('build')][:9]
    
    history_path.parent.mkdir(parents=True, exist_ok=True)
    with open(history_path, 'w') as f:
        json.dump(history_data, f, indent=2)


def run_image_upgrade_wizard(multi_ctx: 'MultiDeviceContext') -> bool:
    """
    Interactive wizard for upgrading DNOS/GI/BaseOS from Jenkins builds.
    
    Args:
        multi_ctx: MultiDeviceContext with selected devices
        
    Returns:
        True if upgrade was successful
    """
    from .jenkins_integration import JenkinsClient, get_stack_from_url, list_dev_branches, validate_stack_artifacts
    
    console.print("\n[bold cyan]═══════════════════════════════════════════════════════════════════[/bold cyan]")
    console.print("[bold cyan]              📦 Image Upgrade Wizard                              [/bold cyan]")
    console.print("[bold cyan]═══════════════════════════════════════════════════════════════════[/bold cyan]")
    
    device_names = ", ".join([d.hostname for d in multi_ctx.devices])
    console.print(f"[dim]Target devices: {device_names}[/dim]\n")
    
    # Show current stacks
    console.print("[bold]Current Device Stacks:[/bold]")
    device_stacks = {}
    for dev in multi_ctx.devices:
        dnos_version = "Unknown"
        
        # Try 1: Parse from config header
        config = multi_ctx.configs.get(dev.hostname, "")
        for line in config.split('\n'):
            if 'DNOS:' in line:
                match = re.search(r'DNOS:\s*(\S+)', line)
                if match:
                    dnos_version = match.group(1)
                    break
        
        # Try 2: Check operational.json for last_pushed_stack
        if dnos_version == "Unknown":
            try:
                op_file = Path(f"db/configs/{dev.hostname}/operational.json")
                if op_file.exists():
                    with open(op_file) as f:
                        op_data = json.load(f)
                        # Check for stack info saved after upgrade
                        if op_data.get('last_dnos_stack'):
                            dnos_version = op_data.get('last_dnos_stack')
                        # Also check dnos_version field
                        elif op_data.get('dnos_version') and op_data.get('dnos_version') != 'N/A':
                            dnos_version = op_data.get('dnos_version')
            except:
                pass
        
        # Mark if still unknown (device may be rebooting)
        if dnos_version == "Unknown":
            status_suffix = " [yellow](rebooting?)[/yellow]"
        else:
            status_suffix = ""
        
        device_stacks[dev.hostname] = dnos_version
        console.print(f"  • {dev.hostname}: {dnos_version}{status_suffix}")
    
    # Initialize Jenkins client early for pending build check
    jenkins = JenkinsClient()
    
    # === CHECK FOR PENDING/IN-PROGRESS BUILDS ===
    # If a build was triggered earlier, offer to monitor and push
    last_branch = getattr(multi_ctx, '_last_triggered_branch', None)
    if last_branch:
        console.print(f"\n[bold yellow]🔔 Pending Build Detected![/bold yellow]")
        console.print(f"   Branch: {last_branch}")
        
        # Check build status
        try:
            build = jenkins.get_build_info(last_branch)
            if build:
                with_baseos = getattr(multi_ctx, '_last_build_with_baseos', True)
                
                if build.building:
                    # Build still in progress
                    console.print(f"   Status: [yellow]🔄 Building (#{build.build_number})[/yellow]")
                    console.print(f"\n  [1] 🚀 Monitor & auto-push when complete (recommended)")
                    console.print("  [2] Skip (continue to menu)")
                    pending_choice = Prompt.ask("Select", choices=["1", "2"], default="1")
                    
                    if pending_choice == "1":
                        console.print(f"\n[yellow]📊 Monitoring build #{build.build_number}...[/yellow]")
                        console.print("[dim]Press Ctrl+C to detach (build continues in Jenkins)[/dim]")
                        console.print(f"[dim]Will auto-push to: {', '.join([d.hostname for d in multi_ctx.devices])}[/dim]\n")
                        
                        from rich.progress import Progress, SpinnerColumn, TextColumn, BarColumn, TimeElapsedColumn
                        
                        with Progress(
                            SpinnerColumn(),
                            TextColumn("[progress.description]{task.description}"),
                            BarColumn(),
                            TextColumn("{task.fields[status]}"),
                            TimeElapsedColumn(),
                            console=console
                        ) as progress:
                            task = progress.add_task("Building...", total=100, status="In progress...")
                            
                            def update_progress(msg, pct):
                                progress.update(task, completed=pct, description=msg, status=f"{pct}%")
                            
                            try:
                                completed_build = jenkins.wait_for_build_completion(
                                    last_branch, build.build_number,
                                    timeout=3600, poll_interval=30,
                                    progress_callback=update_progress
                                )
                                if completed_build and completed_build.result == "SUCCESS":
                                    console.print(f"\n[bold green]✓ Build #{build.build_number} COMPLETED![/bold green]")
                                    
                                    urls = jenkins.get_stack_urls(last_branch, build.build_number)
                                    console.print("\n[bold]Artifacts Ready:[/bold]")
                                    console.print(f"  • DNOS: {'✓' if urls.get('dnos') else '✗'}")
                                    console.print(f"  • GI: {'✓' if urls.get('gi') else '✗'}")
                                    console.print(f"  • BaseOS: {'✓' if urls.get('baseos') else '✗'}")
                                    
                                    console.print(f"\n[bold cyan]🚀 Auto-pushing to devices...[/bold cyan]")
                                    stack = {
                                        'branch': last_branch,
                                        'build': build.build_number,
                                        'dnos_url': urls.get('dnos'),
                                        'gi_url': urls.get('gi'),
                                        'baseos_url': urls.get('baseos') if with_baseos else None,
                                        'age_hours': 0,
                                    }
                                    # Clear the pending build marker
                                    multi_ctx._last_triggered_branch = None
                                    # Skip to artifact selection (jump past menu)
                                    # We'll handle this by setting a flag and continuing below
                                elif completed_build:
                                    console.print(f"\n[red]✗ Build #{build.build_number} {completed_build.result}[/red]")
                                    multi_ctx._last_triggered_branch = None
                                else:
                                    console.print("\n[yellow]Build timed out - check Jenkins manually[/yellow]")
                            except KeyboardInterrupt:
                                console.print("\n[yellow]Detached. Build continues in Jenkins.[/yellow]")
                                # Don't clear _last_triggered_branch so we can pick it up next time
                                return run_image_upgrade_wizard(multi_ctx)
                        
                        # If we got a successful stack, proceed to push
                        if stack:
                            # Jump directly to artifact selection
                            pass  # Continue below to artifact selection section
                        else:
                            return run_image_upgrade_wizard(multi_ctx)
                            
                elif build.result == "SUCCESS":
                    # Build completed successfully
                    console.print(f"   Status: [green]✓ Completed (#{build.build_number})[/green] - {build.age_hours:.1f}h ago")
                    console.print(f"\n  [1] 🚀 Push this build to devices now")
                    console.print("  [2] Skip (continue to menu)")
                    pending_choice = Prompt.ask("Select", choices=["1", "2"], default="1")
                    
                    if pending_choice == "1":
                        urls = jenkins.get_stack_urls(last_branch, build.build_number)
                        stack = {
                            'branch': last_branch,
                            'build': build.build_number,
                            'dnos_url': urls.get('dnos'),
                            'gi_url': urls.get('gi'),
                            'baseos_url': urls.get('baseos') if with_baseos else None,
                            'age_hours': build.age_hours,
                        }
                        multi_ctx._last_triggered_branch = None
                        # Continue to artifact selection below
                    else:
                        multi_ctx._last_triggered_branch = None  # Clear it since user chose to skip
                else:
                    # Build failed
                    console.print(f"   Status: [red]✗ {build.result} (#{build.build_number})[/red]")
                    console.print("   [dim]Build failed - you may want to trigger a new one[/dim]")
                    multi_ctx._last_triggered_branch = None
        except Exception as e:
            console.print(f"   [dim]Could not check build status: {e}[/dim]")
    
    # If we got a stack from pending build, skip to artifact selection
    # Otherwise show the normal menu
    if not stack:
        # Check for recent sources history
        history_path = Path("db/upgrade_sources_history.json")
        has_history = history_path.exists()
        recent_urls = []
        recent_branches = []
        if has_history:
            try:
                with open(history_path) as f:
                    history = json.load(f)
                    recent_urls = history.get('recent_urls', [])
                    recent_branches = history.get('recent_branches', [])
            except:
                pass
    
        console.print("\n[bold]Step 1: Select Source[/bold]")
        if has_history and (recent_urls or recent_branches):
            console.print("  [0] [yellow]⚡ Recent Sources[/yellow] (quick load from history)")
        console.print("  [1] Browse development branches (dev_v*)")
        console.print("  [2] Browse release branches (rel_v*)")
        console.print("  [3] Enter branch name manually")
        console.print("  [4] [cyan]Paste Jenkins URL[/cyan] (Blue Ocean or classic)")
        console.print("  [5] Enter direct Minio URLs")
        console.print("  [6] [green]🔨 Trigger New Build[/green] (build from source)")
        console.print("  [T] [magenta]📊 Monitor Triggered Builds[/magenta] (watch build progress)")
        console.print("  [S] 📊 Check Upgrade Status (show install progress on devices)")
        console.print("  [V] 🔄 Verify Stacks Live (SSH to devices)")
        console.print("  [B] Back")
    
        choices = ["0", "1", "2", "3", "4", "5", "6", "t", "T", "s", "S", "v", "V", "b", "B"] if has_history else ["1", "2", "3", "4", "5", "6", "t", "T", "s", "S", "v", "V", "b", "B"]
        choice = Prompt.ask("Select", choices=choices, default="b").lower()
    
        if choice == "b":
            return False
    
        stack = None
    
        try:
            if choice == "0" and has_history:
                # Recent sources - show all saved sources with better formatting
                console.print("\n[bold]Recent Sources:[/bold]")
                items = []
            
                # Combine and sort by timestamp
                all_entries = []
                for entry in recent_urls:
                    entry['_type'] = 'url'
                    all_entries.append(entry)
                for entry in recent_branches:
                    entry['_type'] = 'branch'
                    all_entries.append(entry)
            
                # Sort by timestamp (most recent first)
                all_entries.sort(key=lambda x: x.get('timestamp', ''), reverse=True)
            
                for i, entry in enumerate(all_entries[:10], 1):
                    branch = entry.get('branch', 'Unknown')
                    build = entry.get('build', '?')
                    version = entry.get('dnos_version', 'N/A')
                    source_type = entry.get('source_type', entry.get('_type', 'unknown'))
                    has_dnos = "✓" if entry.get('has_dnos') else "✗"
                    has_gi = "✓" if entry.get('has_gi') else "✗"
                    has_baseos = "✓" if entry.get('has_baseos') else "✗"
                
                    # Format display string
                    type_label = {
                        'dev_branch': '[cyan]dev[/cyan]',
                        'release_branch': '[green]rel[/green]',
                        'manual_branch': '[yellow]branch[/yellow]',
                        'jenkins_url': '[blue]url[/blue]',
                        'minio_url': '[magenta]minio[/magenta]',
                        'url': '[blue]url[/blue]',
                        'branch': '[yellow]branch[/yellow]',
                    }.get(source_type, source_type)
                
                    # Truncate branch name if too long
                    branch_display = branch[:45] + "..." if len(branch) > 48 else branch
                
                    # Show artifacts status with BaseOS
                    artifacts_status = f"DNOS:{has_dnos} GI:{has_gi} BaseOS:{has_baseos}"
                
                    items.append((str(i), f"{type_label} {branch_display} #{build} | {artifacts_status}", entry))
            
                for idx, desc, _ in items:
                    console.print(f"  [{idx}] {desc}")
                console.print("  [B] Back")
            
                sel = Prompt.ask("Select", choices=[i[0] for i in items] + ["b", "B"], default="b").lower()
                if sel == "b":
                    return run_image_upgrade_wizard(multi_ctx)
            
                selected = next((i for i in items if i[0] == sel), None)
                if selected:
                    entry = selected[2]
                    # Check if it's a URL entry (has non-empty url) or a branch entry
                    if entry.get('url'):
                        console.print(f"[dim]Loading from URL...[/dim]")
                        stack = get_stack_from_url(entry['url'])
                    else:
                        # It's a branch entry - CHECK FOR LATEST BUILD first!
                        branch = entry.get('branch')
                        cached_build_num = entry.get('build')
                    
                        console.print(f"[dim]Checking {branch} for latest build...[/dim]")
                    
                        # Get latest build info from Jenkins
                        latest_build = jenkins.get_build_info(branch)
                    
                        if latest_build:
                            latest_build_num = latest_build.build_number
                        
                            # Notify user if newer build exists
                            if latest_build_num > int(cached_build_num):
                                console.print(f"\n[bold green]🆕 Newer build available![/bold green]")
                                console.print(f"   History: #{cached_build_num}  →  Latest: #{latest_build_num}")
                                console.print(f"   [dim]Latest build is {latest_build.age_hours:.1f} hours old[/dim]")
                            
                                use_latest = Prompt.ask("Use latest build?", choices=["y", "n", "Y", "N"], default="y").lower()
                                build_num = latest_build_num if use_latest == "y" else int(cached_build_num)
                            else:
                                build_num = latest_build_num
                                console.print(f"[dim]Build #{build_num} is the latest ({latest_build.age_hours:.1f}h old)[/dim]")
                        else:
                            # Couldn't get latest, use cached
                            build_num = cached_build_num
                            console.print(f"[yellow]Using cached build #{build_num} (couldn't check latest)[/yellow]")
                    
                        console.print(f"[dim]Loading branch {branch} #{build_num}...[/dim]")
                    
                        # Get fresh artifact URLs
                        urls = jenkins.get_stack_urls(branch, build_num)
                        stack = {
                            'branch': branch, 
                            'build': build_num,
                            'dnos_url': urls.get('dnos'),
                            'gi_url': urls.get('gi'),
                            'baseos_url': urls.get('baseos'),
                        }
        
            elif choice == "1":
                # Browse dev branches
                console.print("\n[dim]Loading development branches...[/dim]")
                branches = jenkins.list_dev_branches()
                if not branches:
                    console.print("[yellow]No development branches found[/yellow]")
                    return False
            
                console.print("\n[bold]Development Branches:[/bold]")
                for i, b in enumerate(branches[:15], 1):
                    age = f"{b.build.age_hours:.0f}h" if b.build else "N/A"
                    console.print(f"  [{i}] {b.name} - {b.version} ({age})")
                console.print("  [B] Back")
            
                sel = Prompt.ask("Select", choices=[str(i) for i in range(1, min(16, len(branches)+1))] + ["b", "B"], default="b").lower()
                if sel == "b":
                    return run_image_upgrade_wizard(multi_ctx)
            
                branch = branches[int(sel) - 1]
                console.print(f"[dim]Loading {branch.name}...[/dim]")
                urls = jenkins.get_stack_urls(branch.name)
                stack = {
                    'branch': branch.name, 
                    'build': branch.build.build_number if branch.build else 0,
                    'dnos_url': urls.get('dnos'),
                    'gi_url': urls.get('gi'),
                    'baseos_url': urls.get('baseos'),
                }
        
            elif choice == "2":
                # Browse release branches
                console.print("\n[dim]Loading release branches...[/dim]")
                branches = jenkins.list_release_branches()
                if not branches:
                    console.print("[yellow]No release branches found[/yellow]")
                    return False
            
                console.print("\n[bold]Release Branches:[/bold]")
                for i, b in enumerate(branches[:15], 1):
                    age = f"{b.build.age_hours:.0f}h" if b.build else "N/A"
                    console.print(f"  [{i}] {b.name} - {b.version} ({age})")
                console.print("  [B] Back")
            
                sel = Prompt.ask("Select", choices=[str(i) for i in range(1, min(16, len(branches)+1))] + ["b", "B"], default="b").lower()
                if sel == "b":
                    return run_image_upgrade_wizard(multi_ctx)
            
                branch = branches[int(sel) - 1]
                console.print(f"[dim]Loading {branch.name}...[/dim]")
                urls = jenkins.get_stack_urls(branch.name)
                stack = {
                    'branch': branch.name, 
                    'build': branch.build.build_number if branch.build else 0,
                    'dnos_url': urls.get('dnos'),
                    'gi_url': urls.get('gi'),
                    'baseos_url': urls.get('baseos'),
                }
        
            elif choice == "3":
                # Manual branch entry
                branch = Prompt.ask("Enter branch name (e.g., dev_v26.1, PR-12345)")
                if not branch:
                    return False
            
                # Auto-detect if it's a URL
                if branch.startswith("http"):
                    console.print("[dim]Detected URL, fetching...[/dim]")
                    stack = get_stack_from_url(branch)
                else:
                    console.print(f"[dim]Looking up {branch}...[/dim]")
                    build = jenkins.get_build_info(branch)
                    if build:
                        urls = jenkins.get_stack_urls(branch, build.build_number)
                        # Map the keys to match expected format (dnos -> dnos_url, etc.)
                        stack = {
                            'branch': branch, 
                            'build': build.build_number,
                            'dnos_url': urls.get('dnos'),
                            'gi_url': urls.get('gi'),
                            'baseos_url': urls.get('baseos'),
                        }
        
            elif choice == "4":
                # Jenkins URL
                url = Prompt.ask("Paste Jenkins URL")
                if not url:
                    return False
            
                console.print("[dim]Fetching build info...[/dim]")
                stack = get_stack_from_url(url)
        
            elif choice == "5":
                # Direct Minio URLs
                console.print("\n[bold]Enter Minio URLs:[/bold]")
                dnos_url = Prompt.ask("DNOS URL (required)")
                if not dnos_url:
                    return False
                gi_url = Prompt.ask("GI URL (optional)", default="")
                baseos_url = Prompt.ask("BaseOS URL (optional)", default="")
            
                stack = {'dnos_url': dnos_url, 'gi_url': gi_url or None, 'baseos_url': baseos_url or None, 'branch': 'manual'}
        
            elif choice == "6":
                # Trigger new build
                console.print("\n[bold green]🔨 Trigger New Build[/bold green]")
                console.print("[dim]Enter branch name to build (e.g., dev_v26_1, feature/dev_v26_1/my-feature)[/dim]")
                branch = Prompt.ask("\nBranch name [B to cancel]")
                if not branch or branch.lower() == 'b':
                    return run_image_upgrade_wizard(multi_ctx)
            
                console.print(f"\n[bold]Build Options for: {branch}[/bold]")
                with_baseos = Confirm.ask("Build with BaseOS containers?", default=True)
                qa_version = Confirm.ask("QA version (60-day retention)?", default=False)
            
                console.print(f"\n[yellow]Triggering build for {branch}...[/yellow]")
                success, message = jenkins.trigger_build(branch, with_baseos=with_baseos, qa_version=qa_version)
            
                if success:
                    console.print(f"[green]✓ {message}[/green]")
                    # Store for easy monitoring
                    multi_ctx._last_triggered_branch = branch
                    multi_ctx._last_build_with_baseos = with_baseos
                    console.print("\n[dim]Waiting for build to start...[/dim]")
                
                    # Wait for build to start
                    build_number = jenkins.wait_for_build_start(branch, timeout=120)
                    if build_number:
                        console.print(f"[green]✓ Build #{build_number} started![/green]")
                        console.print(f"\n[cyan]Jenkins URL: {jenkins.CHEETAH_BASE}/job/{quote(quote(branch, safe=''), safe='')}/{build_number}/[/cyan]")
                    
                        # Ask about auto-monitor and push
                        console.print("\n[bold]Build Options:[/bold]")
                        console.print("  [1] 🚀 Auto-monitor & push when complete (recommended)")
                        console.print("  [2] 📊 Monitor only (push manually later)")
                        console.print("  [3] ⏸️  Detach (build continues in background)")
                        build_option = Prompt.ask("Select", choices=["1", "2", "3"], default="1")
                    
                        if build_option == "3":
                            console.print("\n[cyan]Build running in background.[/cyan]")
                            console.print("[dim]Use [T] Monitor Triggered Builds to check status.[/dim]")
                            return run_image_upgrade_wizard(multi_ctx)
                    
                        auto_push = (build_option == "1")
                    
                        console.print("\n[yellow]📊 Monitoring build progress...[/yellow]")
                        console.print("[dim]Press Ctrl+C to detach (build continues in Jenkins)[/dim]")
                        if auto_push:
                            console.print(f"[dim]Will auto-push to: {', '.join([d.hostname for d in multi_ctx.devices])}[/dim]\n")
                    
                        from rich.progress import Progress, SpinnerColumn, TextColumn, BarColumn, TimeElapsedColumn
                    
                        with Progress(
                            SpinnerColumn(),
                            TextColumn("[progress.description]{task.description}"),
                            BarColumn(),
                            TextColumn("{task.fields[status]}"),
                            TimeElapsedColumn(),
                            console=console
                        ) as progress:
                            task = progress.add_task("Building...", total=100, status="Starting...")
                        
                            def update_progress(msg, pct):
                                progress.update(task, completed=pct, description=msg, status=f"{pct}%")
                        
                            try:
                                build = jenkins.wait_for_build_completion(branch, build_number, 
                                                                          timeout=3600, poll_interval=30,
                                                                          progress_callback=update_progress)
                                if build:
                                    if build.result == "SUCCESS":
                                        console.print(f"\n[bold green]✓ Build #{build_number} COMPLETED SUCCESSFULLY![/bold green]")
                                    
                                        # Get artifact URLs
                                        urls = jenkins.get_stack_urls(branch, build_number)
                                        console.print("\n[bold]Artifacts Ready:[/bold]")
                                        console.print(f"  • DNOS: {'✓' if urls.get('dnos') else '✗'}")
                                        console.print(f"  • GI: {'✓' if urls.get('gi') else '✗'}")
                                        console.print(f"  • BaseOS: {'✓' if urls.get('baseos') else '✗ (not requested)'}")
                                    
                                        if auto_push:
                                            console.print(f"\n[bold cyan]🚀 Auto-pushing to devices...[/bold cyan]")
                                            stack = {
                                                'branch': branch, 
                                                'build': build_number,
                                                'dnos_url': urls.get('dnos'),
                                                'gi_url': urls.get('gi'),
                                                'baseos_url': urls.get('baseos') if with_baseos else None,
                                            }
                                            # Continue to push flow below
                                        else:
                                            console.print("\n[bold]What would you like to do?[/bold]")
                                            console.print("  [1] Push artifacts to devices now")
                                            console.print("  [2] Return to menu (push later)")
                                            post_build = Prompt.ask("Select", choices=["1", "2"], default="1")
                                        
                                            if post_build == "2":
                                                console.print("[dim]Return to Image Upgrade menu to push when ready.[/dim]")
                                                return run_image_upgrade_wizard(multi_ctx)
                                        
                                            stack = {
                                                'branch': branch, 
                                                'build': build_number,
                                                'dnos_url': urls.get('dnos'),
                                                'gi_url': urls.get('gi'),
                                                'baseos_url': urls.get('baseos'),
                                            }
                                    else:
                                        # Build failed - use helper to handle retry
                                        should_push, new_stack = _handle_build_failure(
                                            jenkins, branch, build_number, build.result,
                                            multi_ctx, with_baseos, auto_push
                                        )
                                        if should_push and new_stack:
                                            stack = new_stack
                                            # Continue to push flow
                                        else:
                                            return run_image_upgrade_wizard(multi_ctx)
                                else:
                                    console.print("\n[yellow]Build timed out - check Jenkins manually[/yellow]")
                                    return run_image_upgrade_wizard(multi_ctx)
                            except KeyboardInterrupt:
                                console.print("\n[yellow]Detached from build monitoring. Build continues in Jenkins.[/yellow]")
                                console.print("[dim]Use [T] Monitor Triggered Builds to check status later.[/dim]")
                                return run_image_upgrade_wizard(multi_ctx)
                    else:
                        console.print("[yellow]Build queued but not started yet. Check Jenkins manually.[/yellow]")
                        return run_image_upgrade_wizard(multi_ctx)
                else:
                    console.print(f"[red]✗ {message}[/red]")
                    return run_image_upgrade_wizard(multi_ctx)
        
            elif choice == "s":
                # Check upgrade status
                console.print("\n[bold cyan]📊 Checking Upgrade Status on Devices[/bold cyan]")
                _check_device_upgrade_status(multi_ctx)
                return run_image_upgrade_wizard(multi_ctx)
        
            elif choice == "v":
                # Verify stacks live
                console.print("\n[bold cyan]🔄 Verifying Stacks Live from Devices[/bold cyan]")
                _verify_device_stacks_live(multi_ctx)
                return run_image_upgrade_wizard(multi_ctx)
        
            elif choice == "t":
                # Monitor triggered builds
                _monitor_triggered_builds(jenkins, multi_ctx)
                return run_image_upgrade_wizard(multi_ctx)
        
            # Display stack info
            if not stack:
                console.print("[red]Could not find valid stack[/red]")
                return False
        
            if 'error' in stack:
                console.print(f"[red]Error: {stack['error']}[/red]")
                return False
        
                # === DISPLAY BUILD INFO WITH AGE ===
                age_hours = stack.get('age_hours', 0)
                if age_hours > 0:
                    if age_hours < 1:
                        age_str = f"{int(age_hours * 60)} min old"
                    elif age_hours < 24:
                        age_str = f"{age_hours:.1f}h old"
                    else:
                        age_str = f"{age_hours/24:.1f} days old"
            
                    # Calculate expiration status
                    if age_hours > 48:
                        age_display = f"[red]{age_str} ⚠ EXPIRED[/red]"
                    elif age_hours > 40:
                        hours_left = 48 - age_hours
                        age_display = f"[yellow]{age_str} (expires in {hours_left:.1f}h)[/yellow]"
                    else:
                        hours_left = 48 - age_hours
                        age_display = f"[green]{age_str}[/green] [dim](expires in {hours_left:.0f}h)[/dim]"
                else:
                    age_display = "[dim]age unknown[/dim]"
        
            console.print(f"\n[green]✓ Found build:[/green]")
            console.print(f"  Branch: {stack.get('branch', 'N/A')}")
            console.print(f"  Build: #{stack.get('build', 'N/A')} - {age_display}")
            console.print(f"  DNOS: {stack.get('dnos_url', 'N/A')[:60] + '...' if stack.get('dnos_url') else 'N/A'}")
            console.print(f"  GI: {stack.get('gi_url', 'N/A')[:60] + '...' if stack.get('gi_url') else 'N/A'}")
            console.print(f"  BaseOS: {stack.get('baseos_url', 'N/A')[:60] + '...' if stack.get('baseos_url') else 'N/A'}")
        
            # Check if artifacts are missing (N/A)
            dnos_missing = not stack.get('dnos_url') or stack.get('dnos_url') == 'N/A'
            gi_missing = not stack.get('gi_url') or stack.get('gi_url') == 'N/A'
        
            # Save to history immediately when a valid build is found (even if user doesn't proceed)
            # This makes it available in Recent Sources for next time
            if stack.get('branch') and (not dnos_missing or not gi_missing):
                try:
                    _save_to_upgrade_history(
                        history_path, recent_urls, recent_branches, stack, choice,
                        url if choice == "4" else ""
                    )
                except:
                    pass  # Don't fail if history can't be saved
        
            if dnos_missing and gi_missing:
                console.print(f"\n[red]⚠ No artifacts found for this build![/red]")
                console.print("[dim]Build may have failed, or artifacts expired (48h retention).[/dim]")
                console.print("\n  [1] 🔨 Trigger new build (auto-monitor & push)")
                console.print("  [2] Try a different source")
                console.print("  [B] Back")
